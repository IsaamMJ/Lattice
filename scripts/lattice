#!/usr/bin/env bash
# lattice — unified CLI dispatcher (v0.9.17)
#
# Version banner above is informational only — runtime version is read from
# .claude-plugin/plugin.json (or ~/.claude/lattice/VERSION when installed
# globally). Keep this comment in sync via release checklist.
#
# Discoverability layer over the lifecycle helpers. Wraps the existing
# scripts/lattice-*.sh + scripts/lattice-regenerate.sh so users have one
# command to learn instead of five script paths.
#
# Subcommands:
#   lattice close <id> --reason <reason> [--commit <sha>] [--pr <num>]
#   lattice close <id> --partial "<text>" [--commit <sha>]
#   lattice reopen <id> --reason "<text>"
#   lattice sync [--check]                 # alias: regenerate
#   lattice defer <id> --until <YYYY-MM-DD> [--reason "<text>"]
#   lattice list [--module X] [--tier Y] [--status Z] [--dimension D] [--due-for-review]
#   lattice show <id>
#   lattice sweeps
#   lattice version | --version
#   lattice help   | --help
#
# Exits with the subcommand's exit code. Unknown subcommands → exit 2.
#
# Resolution: every subcommand operates on the current working directory's
# .lattice/findings/. Helpers are looked up next to this script (works in
# both the source repo and the installed location ~/.claude/lattice/scripts/).

set -euo pipefail

SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
# v2.1.2 (#70): helpers may not live next to a stale/literal-copy shim.
# Resolve via: SELF_DIR first, then canonical install, then fail.
_resolve_helper() {
  local name="$1"
  for d in "${SELF_DIR}" "${HOME}/.claude/lattice/scripts" "/usr/local/lattice/scripts"; do
    if [ -f "${d}/${name}" ]; then
      printf '%s' "${d}/${name}"
      return 0
    fi
  done
  printf '%s' "${SELF_DIR}/${name}"  # default to first-tried; require_helper will surface the error
}
HELPER_CLOSE="$(_resolve_helper lattice-close.sh)"
HELPER_REOPEN="$(_resolve_helper lattice-reopen.sh)"
HELPER_REGEN="$(_resolve_helper lattice-regenerate.sh)"

PROG="lattice"

usage() {
  cat <<'USAGE'
lattice — Lattice findings CLI

Lattice has two interfaces:

  Slash commands (run inside Claude Code) PRODUCE findings:
    /audit           — doc-vs-code drift
    /security-audit  — auth gaps, secret leaks, OWASP Top 10
    /scale-audit     — horizontal-scaling killers
    /flow-audit      — customer-flow gaps
    /audit-sweep .   — runs every dimension across every module
    /lattice-fix     — auto-fixes one low-risk PATCH_DOC finding
  Slash command markdown lives in ~/.claude/commands/ (or this repo's commands/).

  CLI (this script) MANAGES the lifecycle of findings produced above:
    list, show, next, sync (CLAUDE.md), close, verify, defer, reopen.

  Canonical loop:
    slash command -> .lattice/findings/open/*.yml -> lattice list/next/sync/close.

Usage:
  lattice close <id> --reason <fixed|false-positive|wont-fix|out-of-scope|duplicate> [--commit <sha>|--pending] [--pr <num>]
  lattice close <id> --partial "<text>" [--commit <sha>]
  lattice resolve-pending [--commit <sha>]
  lattice test-fixture <slug> [--tier T] [--dimension D] [--exposure E] [--verify-pattern P] [--out PATH] [--force]
  lattice install-hooks [--force]
  lattice stats
  lattice mode [classic|substrate|hybrid]
  lattice decide <slug> --title "..." --because "..." [--status S] [--supersedes ID] [--cite PATH[:lines]] [--relates-to SLUG]
  lattice decisions list [--status S]
  lattice decisions show <id-or-slug>
  lattice invariants derive [--print] | show | diff
  lattice context
  lattice report <bug|enhancement|ux|docs|perf|security> --title "..." --body "..." [--severity LOW|MED|HIGH]
  lattice report <category> --title "..." --body-file <path> [--severity ...]
  lattice reopen <id> --reason "<text>"
  lattice sync [--check]
  lattice defer <id> --until <YYYY-MM-DD> [--reason "<text>"]
  lattice list [--module M] [--tier T] [--status S] [--dimension D] [--milestone N] [--exposure K] [--effective-tier] [--due-for-review] [--blocked|--unblocked]
  lattice show <id>
  lattice bulk-close --pattern <glob> [--commit <sha>] [--yes]
  lattice handoff <id>
  lattice next [--module M]
  lattice verify <id> [--run | --rerun-grep [--close-clean]]
  lattice ci-check [--tier <TIERS>]
  lattice wire-hooks [--apply] [--yes] [--session-start] [--statusline]
  lattice mcp setup [--apply] [--yes] [--scope user|project]
  lattice mcp serve | mcp build | mcp status
  lattice grow init | propose <slug> ... | list | show <slug> | run <slug> --commit <sha>
  lattice grow measure <slug> [--json] | check [--state running] [--json]
  lattice grow rollback <slug> --reason "..." | auto-rollback <slug> [--execute] [--yes]
  lattice grow close <slug> --result won|lost|inconclusive [--observed-value <n>] [--rationale "..."]
  lattice grow attach-measurement <slug> --metric-name --measurement-source ...
  lattice grow schedule install [--time HH:MM] [--day mon] [--utc] | status | uninstall | trigger
  lattice profile init | show | set <k>=<v> [...]
  lattice normalize [--apply]
  lattice diff <sweep-a> <sweep-b> | diff --latest
  lattice write-manifest --sweep-id ... --sweep-date ... ...
  lattice audit-infra [--path .] [--write]
  lattice release-notes [--since <tag-or-date>] [--version <v>]
  lattice setup [--global]
  lattice uninstall [--global] [--purge] [--yes]
  lattice ci-check-dead [--days N]
  lattice usage [--since <days>] [--unused <days>] [--json]
  lattice update --check|--self|--enable-auto|--disable-auto
  lattice config init|show|telemetry on|off|show
  lattice validate
  lattice sweeps
  lattice sweep-id
  lattice id-gen <dimension> <rule> <file> <code_context>
  lattice doctor
  lattice export --format markdown [--tier T] [--dimension D] [--module M] [--closed]
  lattice changelog --since <YYYY-MM-DD> [--until <YYYY-MM-DD>] [--tier T] [--module M]
  lattice version
  lattice help

Subcommands:
  close       mark a finding closed (or partially closed with --partial)
  reopen      move a closed finding back to open (regression)
  sync        regenerate the CLAUDE.md checklist block from YAML
              (alias: regenerate; exits 1 on drift, 2 on parse/schema error)
  defer       mark a finding status: deferred until a date, with reason
  list        list open findings, optionally filtered
  show        pretty-print one or more matching finding YAMLs
  bulk-close  close every finding whose slug matches a glob pattern
  handoff     emit a Markdown executor brief for a finding (stdout)
  next        print the highest-priority actionable open finding
  verify      print (or --run) the simulate: steps for a finding
  ci-check    exit 1 if any non-deferred CRITICAL/BLOCKER finding is open
  wire-hooks  merge SessionStart + statusLine into ~/.claude/settings.json
              (dry-run by default; --apply writes with backup; idempotent)
  mcp         manage the Lattice MCP server: setup | serve | build | status
              (v1.0.0; wires mcpServers.lattice into ~/.claude.json)
  grow        hypothesis lifecycle (v2.0+): init/propose/run/measure/check/
              auto-rollback/rollback/close/attach-measurement/schedule.
              Forward-looking experiments, parallel to findings.
  profile     operator profile for tier reweighting + suggested_fix bias
              (v1.4.0; ~/.lattice/profile.yml; init | show | set)
  normalize   canonicalize finding ids + filenames in .lattice/findings/open/
              (v1.1.2; re-derives ids per v0.7 sha1; default dry-run)
  diff        compare two sweep manifests by slug sets (v1.2.0; --latest)
  audit-infra audit Claude Code infra adequacy: hooks + MCPs for detected stack
              (v1.3.0; new dimension; --write emits YAMLs)
  release-notes  auto-generate CHANGELOG entry from git commits since last tag
              (v1.1.1; conventional-commit categorization)
  setup       one-command per-project bootstrap (v1.0.3)
  onboard     full per-project bootstrap: setup + wire-hooks + mcp + grow init
              + grow schedule install. Collapses ~3h setup to ~30s. (v2.2 #77)
  uninstall   remove Lattice from cwd or --global  (v1.0.2)
  usage       summarize local command usage from .lattice/usage/events.jsonl
  update      check for or apply Lattice updates using .lattice/config.yml
  config      create a project-local .lattice/config.yml
  validate    scan every YAML, report per-file parse/schema errors
              (does not touch CLAUDE.md; exits 2 if any error found)
  sweeps      list sweep manifests under .lattice/findings/sweeps/
  sweep-id    generate a deterministic sweep ID (YYYYMMDD + 6-hex)
  id-gen      compute stable v0.7 finding id (sha1-based, line-shift proof)
  version     print the installed Lattice version

All subcommands run against the .lattice/findings/ tree in the current
working directory. Run with no args from a project root.

<id> can be:
  * A full YAML path:          .lattice/findings/open/HIGH-payments-leak.yml
  * A filename slug:           HIGH-payments-leak
  * The display format:        src/modules/payments/leak    (module/rule)
  * A substring of any slug:   payments-leak               (last resort)
USAGE
}

die() {
  echo "[${PROG}] error: $*" >&2
  exit 2
}

require_helper() {
  local h="$1"
  [ -x "${h}" ] || [ -f "${h}" ] || die "missing helper: ${h}"
}

current_version() {
  local plugin="${SELF_DIR}/../.claude-plugin/plugin.json"
  local v=""
  if [ -f "${plugin}" ]; then
    v="$(grep -oE '"version"\s*:\s*"[^"]+"' "${plugin}" | head -n1 | sed -E 's/.*"version"\s*:\s*"([^"]+)".*/\1/')"
  fi
  if [ -z "${v}" ] && [ -f "${HOME}/.claude/lattice/VERSION" ]; then
    v="$(cat "${HOME}/.claude/lattice/VERSION" 2>/dev/null || true)"
  fi
  [ -n "${v}" ] && printf "%s" "${v}" || printf "unknown"
}

json_escape() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/ }"
  s="${s//$'\r'/ }"
  printf "%s" "${s}"
}

config_get() {
  local section="$1" key="$2" default="$3"
  local cfg=".lattice/config.yml"
  [ -f "${cfg}" ] || { printf "%s" "${default}"; return; }
  local val
  val="$(awk -v section="${section}" -v key="${key}" '
    /^[[:space:]]*#/ || /^[[:space:]]*$/ { next }
    /^[^[:space:]][^:]*:[[:space:]]*$/ {
      cur=$1; sub(/:.*/, "", cur); next
    }
    cur == section {
      line=$0
      sub(/^[[:space:]]+/, "", line)
      split(line, parts, ":")
      if (parts[1] == key) {
        sub(/^[^:]*:[[:space:]]*/, "", line)
        gsub(/^["'\'']|["'\'']$/, "", line)
        print line
        exit
      }
    }
  ' "${cfg}" 2>/dev/null || true)"
  [ -n "${val}" ] && printf "%s" "${val}" || printf "%s" "${default}"
}

ensure_project_dirs() {
  mkdir -p ".lattice/usage" ".lattice/cache" 2>/dev/null || true
}

args_shape() {
  local out=()
  for arg in "$@"; do
    case "${arg}" in
      --*) out+=("${arg}") ;;
      -*) out+=("${arg}") ;;
    esac
  done
  printf "%s" "${out[*]:-}"
}

log_usage_event() {
  local command="$1"; shift || true
  local enabled
  enabled="$(config_get usage enabled true)"
  case "${enabled}" in
    false|off|0|no) return 0 ;;
  esac
  ensure_project_dirs
  local ts ver shape project cwd
  ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  ver="$(current_version)"
  shape="$(args_shape "$@")"
  project="$(basename "$(pwd)")"
  cwd="$(pwd)"
  # Local per-project log (debug-friendly, gitignored)
  {
    printf '{"ts":"%s","version":"%s","command":"%s","args_shape":"%s","project":"%s"}\n' \
      "$(json_escape "${ts}")" \
      "$(json_escape "${ver}")" \
      "$(json_escape "${command}")" \
      "$(json_escape "${shape}")" \
      "$(json_escape "${project}")"
  } >> ".lattice/usage/events.jsonl" 2>/dev/null || true
  # Global aggregate (v0.7.2): every invocation across every project. This is
  # the maintainer dashboard data — NOT surfaced into client Claude sessions.
  # Disabled by setting usage.global=false in .lattice/config.yml.
  local global_enabled
  global_enabled="$(config_get usage global true)"
  case "${global_enabled}" in
    false|off|0|no) return 0 ;;
  esac
  local global_dir="${HOME}/.claude/lattice/usage"
  mkdir -p "${global_dir}" 2>/dev/null || true
  {
    printf '{"ts":"%s","version":"%s","command":"%s","args_shape":"%s","project":"%s","cwd":"%s"}\n' \
      "$(json_escape "${ts}")" \
      "$(json_escape "${ver}")" \
      "$(json_escape "${command}")" \
      "$(json_escape "${shape}")" \
      "$(json_escape "${project}")" \
      "$(json_escape "${cwd}")"
  } >> "${global_dir}/global.jsonl" 2>/dev/null || true
}

latest_remote_version() {
  if [ -n "${LATTICE_TEST_LATEST_VERSION:-}" ]; then
    printf "%s" "${LATTICE_TEST_LATEST_VERSION}"
    return 0
  fi
  local raw="https://raw.githubusercontent.com/IsaamMJ/Lattice/main/.claude-plugin/plugin.json"
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "${raw}" 2>/dev/null | grep -oE '"version"\s*:\s*"[^"]+"' | head -n1 | sed -E 's/.*"version"\s*:\s*"([^"]+)".*/\1/'
  elif command -v wget >/dev/null 2>&1; then
    wget -qO- "${raw}" 2>/dev/null | grep -oE '"version"\s*:\s*"[^"]+"' | head -n1 | sed -E 's/.*"version"\s*:\s*"([^"]+)".*/\1/'
  else
    return 1
  fi
}

version_newer() {
  local latest="$1" current="$2"
  [ "${latest}" = "${current}" ] && return 1
  node -e '
    const latest = process.argv[1].replace(/^v/, "").split(".").map(Number);
    const current = process.argv[2].replace(/^v/, "").split(".").map(Number);
    for (let i = 0; i < Math.max(latest.length, current.length); i++) {
      const a = latest[i] || 0, b = current[i] || 0;
      if (a > b) process.exit(0);
      if (a < b) process.exit(1);
    }
    process.exit(1);
  ' "${latest}" "${current}" 2>/dev/null
}

maybe_update_check() {
  local command="$1"
  case "${command}" in
    update|config|version|--version|-v|help|--help|-h) return 0 ;;
    # v0.9.15 ROOT CAUSE FIX: tick-invoked commands MUST NOT hit the network.
    # Claude Code calls `statusline` every ~2 seconds; each tick was firing
    # `latest_remote_version` (curl to GitHub) on the hot path. On Windows
    # + Git Bash where fork is slow, the curl blocked long enough that the
    # next tick spawned before the previous finished → 12+ orphan bash.exe
    # processes, 29% CPU, 77% RAM, "infinite cmd opening" pile-up.
    # `sessions` and `review` are also internal-data subcommands that have
    # no business doing a network check.
    statusline|sessions|review) return 0 ;;
  esac
  [ -f ".lattice/config.yml" ] || return 0
  local mode interval now last cache current latest
  mode="$(config_get updates mode notify)"
  case "${mode}" in off|pinned) return 0 ;; esac
  interval="$(config_get updates check_interval_hours 24)"
  [[ "${interval}" =~ ^[0-9]+$ ]] || interval=24
  ensure_project_dirs
  cache=".lattice/cache/update-check.env"
  now="$(date +%s)"
  last=0
  [ -f "${cache}" ] && . "${cache}" 2>/dev/null || true
  last="${checked_at:-0}"
  if [ $((now - last)) -lt $((interval * 3600)) ]; then
    return 0
  fi
  current="$(current_version)"
  latest="$(latest_remote_version || true)"
  [ -z "${latest}" ] && return 0
  {
    printf "checked_at=%s\n" "${now}"
    printf "current_version=%q\n" "${current}"
    printf "latest_version=%q\n" "${latest}"
  } > "${cache}" 2>/dev/null || true
  if version_newer "${latest}" "${current}"; then
    if [ "${mode}" = "auto" ]; then
      echo "[${PROG}] update: ${current} -> ${latest} (auto mode)"
      cmd_update --self || true
    else
      echo "[${PROG}] update available: ${current} -> ${latest}. Run: lattice update --self" >&2
    fi
  fi
}

# ---------------------------------------------------------------------------
# Telemetry — sanitized error reports to lattice-telemetry Worker.
#
# Sends ONLY on failed lattice invocations. Wire format spec:
#   docs/telemetry-protocol.md
# Worker source:
#   worker/lattice-telemetry.js
# Server-side audit (every issue is public, label = telemetry):
#   https://github.com/IsaamMJ/Lattice/issues?q=is%3Aissue+label%3Atelemetry
#
# Disable: lattice config telemetry off  OR  export LATTICE_TELEMETRY=0
# Debug:   export LATTICE_TELEMETRY_DEBUG=1   (prints payload, does not send)
# ---------------------------------------------------------------------------

_LATTICE_TELEMETRY_URL="${LATTICE_TELEMETRY_URL:-https://lattice-telemetry.isaam-mj.workers.dev}"

_telemetry_enabled() {
  # Precedence (highest first):
  #   1. project OFF  — explicit per-project veto wins over everything
  #   2. env LATTICE_TELEMETRY=0 / =1
  #   3. project ON
  #   4. global config ON / OFF
  #   5. LATTICE_OWNER_MODE=1 — owner of the Lattice repo: default ON for own projects
  #   6. default OFF (opt-in, per v0.8.0 polish #12)
  if [ -f .lattice/config.yml ] && grep -qE '^telemetry:[[:space:]]*off' .lattice/config.yml 2>/dev/null; then
    return 1
  fi
  case "${LATTICE_TELEMETRY:-}" in
    0) return 1 ;;
    1) return 0 ;;
  esac
  if [ -f .lattice/config.yml ] && grep -qE '^telemetry:[[:space:]]*on' .lattice/config.yml 2>/dev/null; then
    return 0
  fi
  if [ -f "${HOME}/.claude/lattice/config.yml" ]; then
    if grep -qE '^telemetry:[[:space:]]*off' "${HOME}/.claude/lattice/config.yml" 2>/dev/null; then return 1; fi
    if grep -qE '^telemetry:[[:space:]]*on'  "${HOME}/.claude/lattice/config.yml" 2>/dev/null; then return 0; fi
  fi
  # Owner mode: flip default to ON when the user is auditing their own projects.
  # Set in shell rc (e.g. `export LATTICE_OWNER_MODE=1`) — no per-project config needed.
  [ "${LATTICE_OWNER_MODE:-0}" = "1" ] && return 0
  return 1
}

_maybe_show_telemetry_disclosure() {
  # First-run informational notice only — does NOT enable telemetry.
  # Telemetry stays OFF unless the user explicitly runs `lattice config telemetry on`.
  local marker="${HOME}/.claude/lattice/.telemetry-acknowledged"
  [ -f "${marker}" ] && return 0
  # Only show in interactive-ish contexts (skip when stderr is not a TTY-like fd)
  # to avoid noise in CI / piped invocations.
  [ -t 2 ] 2>/dev/null || { mkdir -p "${HOME}/.claude/lattice" 2>/dev/null || true; touch "${marker}" 2>/dev/null || true; return 0; }

  cat >&2 <<DISCLOSURE
[${PROG}] Telemetry is OFF by default. To help improve Lattice you can opt in to
[${PROG}]   sanitized failure reports (version, exit code, command name, OS only —
[${PROG}]   NEVER file paths, finding IDs, commit SHAs, source code, project names,
[${PROG}]   repo names, or usernames):
[${PROG}]     Per project:  lattice config telemetry on
[${PROG}]     All projects: lattice config telemetry on --global
[${PROG}] Audit:  github.com/IsaamMJ/Lattice/issues?q=label%3Atelemetry
[${PROG}] Source: worker/lattice-telemetry.js + docs/telemetry-protocol.md
DISCLOSURE

  mkdir -p "${HOME}/.claude/lattice" 2>/dev/null || true
  touch "${marker}" 2>/dev/null || true
}

_send_telemetry() {
  _telemetry_enabled || return 0

  local exit_code="$1" command="$2"

  # Skip on help/version/doctor/config/update — not real failures even if exit code != 0.
  # `update --check` returns 1 BY DESIGN when an update is available (CI-friendly), so
  # telemetering on it floods the bug tracker with non-bugs. Same for usage typos like
  # `lattice update --version` which hit the *) die path. Update issues are usually
  # network / deployment, not Lattice bugs.
  case "${command}" in
    help|--help|-h|version|--version|-v|doctor|config|update) return 0 ;;
    # v0.9.13: statusline is invoked on a tick by Claude Code. Any failure
    # there is environmental (missing git on subprocess PATH, locale issues,
    # etc.) — NOT a Lattice bug worth telemetering. Without this skip, every
    # failed statusline tick would auto-file an issue. Caught via #35 on
    # Windows where exit 127 hit 3+ times in 5 minutes.
    statusline) return 0 ;;
  esac

  local version os timestamp fingerprint user_hash payload
  version="$(current_version 2>/dev/null || echo 0.0.0)"

  case "$(uname -s 2>/dev/null)" in
    Linux*)   os="linux" ;;
    Darwin*)  os="darwin" ;;
    CYGWIN*|MINGW*|MSYS*|Windows*) os="windows" ;;
    *)        os="linux" ;;
  esac

  timestamp="$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo 1970-01-01T00:00:00Z)"

  # Fingerprint = sha256(command + ":" + exit_code). Stable across machines so
  # the same failure dedupes to one issue regardless of who hits it.
  fingerprint="$(printf '%s:%s' "${command}" "${exit_code}" | sha256sum 2>/dev/null | cut -d' ' -f1)"
  [ -z "${fingerprint}" ] && return 0

  # user_hash = sha256(hostname + home dir). Machine-stable, NOT
  # personally identifiable to anyone but the user themselves.
  user_hash="$(printf '%s:%s' "$(uname -n 2>/dev/null || echo unknown)" "${HOME:-}" | sha256sum 2>/dev/null | cut -d' ' -f1)"

  payload="{\"version\":\"${version}\",\"command\":\"${command}\",\"exit_code\":${exit_code},\"os\":\"${os}\",\"msg_fingerprint\":\"${fingerprint}\",\"user_hash\":\"${user_hash}\",\"timestamp\":\"${timestamp}\"}"

  if [ "${LATTICE_TELEMETRY_DEBUG:-0}" = "1" ]; then
    {
      echo "[${PROG}-telemetry] payload (would send):"
      echo "${payload}"
      echo "[${PROG}-telemetry] (debug mode — not sent)"
    } >&2
    return 0
  fi

  # 2s timeout. Silent failure — never surface telemetry errors to user.
  curl -sS -X POST "${_LATTICE_TELEMETRY_URL}" \
    -H "content-type: application/json" \
    -d "${payload}" \
    --max-time 2 \
    >/dev/null 2>&1 || true
}

_on_telemetry_exit() {
  local code=$?
  # Exit 141 = SIGPIPE (128 + 13). Happens when the user pipes lattice output
  # into a consumer that closes early (e.g. `lattice list | head`). That is a
  # benign UX pattern, not a bug — skip telemetry so we don't flood the tracker.
  # Same for 130 (SIGINT — user Ctrl-C) and 143 (SIGTERM).
  # Resolve subcommand via the dedicated global so loop-scope reassignments
  # in cmd_doctor (`for sub in findings/open ...`) can't poison this trap.
  local _scmd="${_LATTICE_SUBCMD:-${sub:-}}"
  if [ ${code} -ne 0 ] && [ ${code} -ne 141 ] && [ ${code} -ne 130 ] && [ ${code} -ne 143 ] && [ -n "${_scmd}" ]; then
    # Debug mode keeps stderr so the payload is visible; otherwise silent.
    if [ "${LATTICE_TELEMETRY_DEBUG:-0}" = "1" ]; then
      _send_telemetry "${code}" "${_scmd}" || true
    else
      _send_telemetry "${code}" "${_scmd}" >/dev/null 2>&1 || true
    fi
  fi
  # MAT log (v0.9.6) — local-only post-execution trace, foundation for v0.9.7
  # friction predicates ("PATH workaround used", "command retried after fail",
  # "manual yaml edit instead of helper", etc). Writes after telemetry so any
  # telemetry failure cannot block the local log.
  _write_mat_entry "${code}" "${_scmd:-unknown}" || true
}

# ---------------------------------------------------------------------------
# MAT (Message-Action Trace) log — passive observer layer (v0.9.6).
#
# Every `lattice <cmd>` invocation appends one JSON line to
# `.lattice/sessions/<YYYYMMDD>.jsonl` in the project's cwd. Per-day, per-project
# rolling. Captures: timestamp, subcommand, raw args, exit code, duration
# (when shell supports nanosecond `date +%s%N`), invocation method (PATH vs
# full-path workaround), cwd. Local-only — never POSTed anywhere; v0.9.3
# manual telemetry is a separate lane with strict sanitization.
#
# v0.9.7 will read this log to derive friction candidates and surface them via
# `lattice review`. The MAT layer is INTENTIONALLY passive so that recording is
# never optional — Claude/agent sessions cannot "forget" to write events.
# ---------------------------------------------------------------------------
_write_mat_entry() {
  local code="$1" subcmd="$2"
  # Skip if user disabled via env (parity with usage log)
  case "${LATTICE_MAT:-1}" in
    0|off|false|no) return 0 ;;
  esac
  # No-op for help/version/sessions/statusline/review to avoid infinite chatter.
  # v0.9.15: statusline + review added — these are tick/read-only commands
  # that have no business writing MAT events. Without this skip, every
  # statusline tick (~every 2s) was appending a JSONL row, and growing the
  # session log made subsequent ticks read more data → exponential work.
  case "${subcmd}" in
    help|--help|-h|version|--version|-v|sessions|statusline|review|unknown) return 0 ;;
  esac
  # Must be in a directory where we can write .lattice/ — silently bail otherwise
  [ -w . ] 2>/dev/null || return 0
  mkdir -p .lattice/sessions 2>/dev/null || return 0

  local day ts duration_ms args_json invoked_via cwd_esc
  day="$(date -u +%Y%m%d 2>/dev/null || echo unknown)"
  ts="$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo unknown)"

  # Duration: only computable if start nanos captured AND `date +%s%N` is real
  # (Git Bash on Windows reports literal "%N" — guard against that).
  duration_ms=0
  if [ -n "${_LATTICE_START_NS:-}" ] && [ "${_LATTICE_START_NS}" != "0" ]; then
    local now_ns
    now_ns="$(date +%s%N 2>/dev/null || echo 0)"
    if [[ "${now_ns}" =~ ^[0-9]+$ ]] && [[ "${_LATTICE_START_NS}" =~ ^[0-9]+$ ]]; then
      duration_ms=$(( (now_ns - _LATTICE_START_NS) / 1000000 ))
      # Guard nonsense values from clock skew / overflow
      [ "${duration_ms}" -lt 0 ] && duration_ms=0
    fi
  fi

  # Build args JSON array from the saved entry argv (set at script start).
  # Each arg is JSON-escaped; we keep them verbatim because the MAT log is
  # local-only and is meant to drive friction detection on real argv shapes.
  args_json="["
  local first=1 a esc
  for a in "${_LATTICE_ARGV[@]:-}"; do
    esc="${a//\\/\\\\}"
    esc="${esc//\"/\\\"}"
    esc="${esc//$'\n'/\\n}"
    esc="${esc//$'\r'/\\r}"
    esc="${esc//$'\t'/\\t}"
    if [ "${first}" -eq 1 ]; then
      args_json+="\"${esc}\""
      first=0
    else
      args_json+=",\"${esc}\""
    fi
  done
  args_json+="]"

  invoked_via="${_LATTICE_INVOKED_VIA:-path}"
  cwd_esc="$(pwd 2>/dev/null || echo unknown)"
  cwd_esc="${cwd_esc//\\/\\\\}"
  cwd_esc="${cwd_esc//\"/\\\"}"

  # One JSON object per line — easy to parse line-by-line in v0.9.7 friction
  # predicates without pulling jq as a dependency.
  printf '{"ts":"%s","cmd":"%s","args":%s,"exit":%d,"duration_ms":%d,"invoked_via":"%s","cwd":"%s"}\n' \
    "${ts}" "${subcmd}" "${args_json}" "${code}" "${duration_ms}" "${invoked_via}" "${cwd_esc}" \
    >> ".lattice/sessions/${day}.jsonl" 2>/dev/null || true
}

# ---------------------------------------------------------------------------
# Locate a finding YAML by id, slug, or <module>/<rule> form.
# Search order:
#   1. Exact filename match (slug like CRITICAL-payments-stack-leak)
#   2. <module>/<rule> form (the display format from `lattice list`) —
#      walks all YAMLs and matches "${module}/${rule}" against <id>
#   3. Filename substring match (last resort)
# Echoes the path of the first match; non-zero exit if none. Open/ first,
# then closed/.
# ---------------------------------------------------------------------------
locate_finding() {
  local raw="${1%.yml}"
  shopt -s nullglob

  # 1) Exact filename match. nullglob skips empty globs but does NOT skip
  # literal paths that don't exist — the second pattern in each loop is
  # fixed-string and will be added even if the file is absent. Filter with -f.
  local matches=()
  for f in .lattice/findings/open/*/"${raw}.yml" .lattice/findings/open/"${raw}.yml"; do
    [ -f "${f}" ] || continue
    matches+=("${f}")
  done
  if [ "${#matches[@]}" -eq 0 ]; then
    for f in .lattice/findings/closed/*/"${raw}.yml" .lattice/findings/closed/"${raw}.yml"; do
      [ -f "${f}" ] || continue
      matches+=("${f}")
    done
  fi

  # 2) <module>/<rule> form — only if no exact match and the input contains a slash
  if [ "${#matches[@]}" -eq 0 ] && [[ "${raw}" == */* ]]; then
    local f mod rule
    for f in .lattice/findings/open/*/*.yml .lattice/findings/open/*.yml \
             .lattice/findings/closed/*/*.yml .lattice/findings/closed/*.yml; do
      [ -f "${f}" ] || continue
      mod="$(yaml_field "${f}" "module")"
      rule="$(yaml_field "${f}" "rule")"
      if [ "${mod}/${rule}" = "${raw}" ]; then
        matches+=("${f}")
      fi
    done
  fi

  # 3) Substring match on basename
  if [ "${#matches[@]}" -eq 0 ]; then
    local f base
    for f in .lattice/findings/open/*/*.yml .lattice/findings/open/*.yml \
             .lattice/findings/closed/*/*.yml .lattice/findings/closed/*.yml; do
      [ -f "${f}" ] || continue
      base="$(basename "${f}" .yml)"
      if [[ "${base}" == *"${raw}"* ]]; then
        matches+=("${f}")
      fi
    done
  fi

  if [ "${#matches[@]}" -eq 0 ]; then
    return 1
  fi
  IFS=$'\n' sorted=($(printf '%s\n' "${matches[@]}" | sort))
  unset IFS
  printf '%s\n' "${sorted[0]}"
}

# ---------------------------------------------------------------------------
# locate_finding_all — return ALL matches (newline-separated) for a given id/slug.
# Supports flat (v0.7) and legacy nested layouts.
# ---------------------------------------------------------------------------
locate_finding_all() {
  local raw="${1%.yml}"
  # Strip leading path prefixes so users can paste full YAML paths (U4)
  raw="${raw#.lattice/findings/open/}"
  raw="${raw#.lattice/findings/closed/}"
  # Strip one level of date/ or sha/ subdir if it looks like a prefix
  if [[ "${raw}" == */* ]]; then
    local maybe_stripped="${raw#*/}"
    if [[ "${maybe_stripped}" =~ ^(CRITICAL|HIGH|MEDIUM|LOW|BLOCKER|RISK|WATCH|DRIFT|INTENTIONAL|UNVERIFIABLE|OK)- ]]; then
      raw="${maybe_stripped}"
    fi
  fi

  shopt -s nullglob
  local matches=()

  # 1) Exact filename match — flat first, then legacy nested
  for f in ".lattice/findings/open/${raw}.yml" .lattice/findings/open/*/"${raw}.yml" \
            ".lattice/findings/closed/${raw}.yml" .lattice/findings/closed/*/"${raw}.yml"; do
    [ -f "${f}" ] && matches+=("${f}")
  done

  # 2) <module>/<rule> form
  if [ "${#matches[@]}" -eq 0 ] && [[ "${raw}" == */* ]]; then
    local f mod rule
    for f in ".lattice/findings/open"/*.yml .lattice/findings/open/*/*.yml \
              ".lattice/findings/closed"/*.yml .lattice/findings/closed/*/*.yml; do
      [ -f "${f}" ] || continue
      mod="$(yaml_field "${f}" "module")"
      rule="$(yaml_field "${f}" "rule")"
      [ "${mod}/${rule}" = "${raw}" ] && matches+=("${f}")
    done
  fi

  # 2.5) Hex id field match (v0.7.7) — the `id:` field is the first thing in YAML
  # and natural for users to copy. Match when raw looks like 8-40 hex chars and
  # no other strategy hit. Scans `id:` field of every YAML.
  if [ "${#matches[@]}" -eq 0 ] && [[ "${raw}" =~ ^[0-9a-fA-F]{8,40}$ ]]; then
    local f fid
    for f in ".lattice/findings/open"/*.yml .lattice/findings/open/*/*.yml \
              ".lattice/findings/closed"/*.yml .lattice/findings/closed/*/*.yml; do
      [ -f "${f}" ] || continue
      fid="$(yaml_field "${f}" "id")"
      [ "${fid}" = "${raw}" ] && matches+=("${f}")
    done
  fi

  # 3) Substring match on basename
  if [ "${#matches[@]}" -eq 0 ]; then
    local f base
    for f in ".lattice/findings/open"/*.yml .lattice/findings/open/*/*.yml \
              ".lattice/findings/closed"/*.yml .lattice/findings/closed/*/*.yml; do
      [ -f "${f}" ] || continue
      base="$(basename "${f}" .yml)"
      [[ "${base}" == *"${raw}"* ]] && matches+=("${f}")
    done
  fi

  [ "${#matches[@]}" -eq 0 ] && return 1
  printf '%s\n' "${matches[@]}" | sort
}

# Resolve interactively when multiple matches. Echoes the chosen path.
# If exactly 1 match: echoes it. If >1 and TTY: prompts. If no TTY: prints list and exits non-zero.
locate_finding_interactive() {
  local raw="$1"
  local all_matches=()
  while IFS= read -r line; do
    [ -n "${line}" ] && all_matches+=("${line}")
  done < <(locate_finding_all "${raw}" 2>/dev/null || true)

  if [ "${#all_matches[@]}" -eq 0 ]; then
    return 1
  fi
  if [ "${#all_matches[@]}" -eq 1 ]; then
    printf '%s\n' "${all_matches[0]}"
    return 0
  fi

  # Multiple matches
  if [ ! -t 0 ]; then
    echo "[${PROG}] error: '${raw}' matches ${#all_matches[@]} findings; use exact slug" >&2
    for m in "${all_matches[@]}"; do echo "  - $(basename "${m}" .yml)"; done >&2
    return 2
  fi

  echo "[${PROG}] '${raw}' matches ${#all_matches[@]} findings:" >&2
  local i=0
  for m in "${all_matches[@]}"; do
    i=$((i + 1))
    local tier; tier="$(yaml_field "${m}" "tier")"
    local mod; mod="$(yaml_field "${m}" "module")"
    echo "  ${i}) $(basename "${m}" .yml)  [${tier}  ${mod}]" >&2
  done
  printf "[${PROG}] select [1-${#all_matches[@]}] (or q to cancel): " >&2
  local choice
  read -r choice </dev/tty || { echo "" >&2; return 2; }
  case "${choice}" in
    q|Q) echo "[${PROG}] cancelled" >&2; return 2 ;;
    ''|*[!0-9]*) echo "[${PROG}] invalid choice" >&2; return 2 ;;
  esac
  if [ "${choice}" -lt 1 ] || [ "${choice}" -gt "${#all_matches[@]}" ]; then
    echo "[${PROG}] out of range" >&2; return 2
  fi
  printf '%s\n' "${all_matches[$((choice - 1))]}"
}

# Read a top-level scalar field from a YAML file (single-line values only).
# Echo empty if absent. Strips surrounding quotes.
yaml_field() {
  local file="$1" key="$2"
  local line
  line=$(grep -E "^${key}[[:space:]]*:" "${file}" 2>/dev/null | head -n1 || true)
  [ -z "${line}" ] && return 0
  # Strip quotes only when they wrap the entire value (matched pair). Previous
  # form stripped a trailing " independently of a leading one, which truncated
  # titles like: `code points at "lattice help"` to `code points at "lattice help`.
  printf '%s' "${line}" | sed -E "s/^${key}[[:space:]]*:[[:space:]]*//; s/^\"(.*)\"$/\1/; s/^'(.*)'$/\1/"
}

# ---------------------------------------------------------------------------
# Effective tier — applies the v0.8.0 exposure multiplier.
#
# Rules (#8):
#   production-critical / user-facing / "" → no demotion
#   admin-only / internal                  → demote 1 step
#   test-only / dead-code                  → demote 2 steps
# Tier sequence (highest → lowest):  CRITICAL > HIGH > MEDIUM > LOW > OK
# BLOCKER and dimension-specific tiers (RISK/WATCH, DRIFT/INTENTIONAL) are
# treated as opaque — no demotion is applied beyond the four-step ladder.
# ---------------------------------------------------------------------------
effective_tier() {
  local tier="$1" exposure="$2"
  local steps=0
  case "${exposure}" in
    production-critical|user-facing|"") steps=0 ;;
    admin-only|internal) steps=1 ;;
    test-only|dead-code) steps=2 ;;
    *) steps=0 ;;
  esac
  local cur="${tier}" i=0
  while [ ${i} -lt ${steps} ]; do
    case "${cur}" in
      CRITICAL) cur=HIGH ;;
      HIGH)     cur=MEDIUM ;;
      MEDIUM)   cur=LOW ;;
      LOW)      cur=OK ;;
      *)        break ;;
    esac
    i=$((i+1))
  done
  printf '%s' "${cur}"
}

# ---------------------------------------------------------------------------
# close
# ---------------------------------------------------------------------------
cmd_close() {
  require_helper "${HELPER_CLOSE}"
  [ "$#" -ge 1 ] || die "close: usage: lattice close <id> --reason <reason> [--commit <sha>] [--pr <num>] [--partial <text>]"
  # Guard against empty <id> (Git Bash strips "" between bash→bash invocations,
  # so the helper alone is not sufficient; substring-matcher otherwise hits all).
  [ -z "${1// }" ] && die "close: <finding-id> is required (empty arg)"
  local find_id="$1"; shift
  local matches=() src
  while IFS= read -r line; do
    [[ "${line}" == .lattice/findings/open/* ]] && matches+=("${line}")
  done < <(locate_finding_all "${find_id}" 2>/dev/null || true)
  if [ "${#matches[@]}" -eq 0 ]; then
    src="$(locate_finding "${find_id}" 2>/dev/null || true)"
    if [[ "${src}" == .lattice/findings/closed/* ]]; then
      echo "[${PROG}] already closed: ${src}"
      return 0
    fi
    die "close: not found: ${find_id}"
  fi
  if [ "${#matches[@]}" -gt 1 ]; then
    if [ ! -t 0 ]; then
      echo "[${PROG}] error: '${find_id}' matches ${#matches[@]} findings; use exact slug" >&2
      for src in "${matches[@]}"; do echo "  - $(basename "${src}" .yml)" >&2; done
      return 2
    fi
    echo "[${PROG}] '${find_id}' matches ${#matches[@]} open findings:" >&2
    local i=0 choice
    for src in "${matches[@]}"; do
      i=$((i + 1))
      echo "  ${i}) $(basename "${src}" .yml)" >&2
    done
    printf "[${PROG}] select [1-${#matches[@]}] (or q to cancel): " >&2
    read -r choice </dev/tty || return 2
    [[ "${choice}" =~ ^[0-9]+$ ]] || return 2
    [ "${choice}" -ge 1 ] && [ "${choice}" -le "${#matches[@]}" ] || return 2
    src="${matches[$((choice - 1))]}"
  else
    src="${matches[0]}"
  fi
  local slug
  slug="$(basename "${src}" .yml)"
  # v2.2: print related-finding nudge before delegating to helper.
  _close_print_relates_nudge "${src}" || true
  local rc=0
  bash "${HELPER_CLOSE}" "${slug}" "$@" || rc=$?
  # v0.9.11: auto-refresh project CLAUDE.md state block. Quiet, best-effort,
  # respects LATTICE_NO_PROJECT_SYNC=1. Only fires when CLAUDE.md already has
  # a block (no surprise-creation on first close).
  [ "${rc}" -eq 0 ] && _lattice_project_sync_auto
  return "${rc}"
}

# ---------------------------------------------------------------------------
# v2.2: cross-reference primitive (#80, #83).
#
# `_relates_to_ids <yaml>` — emit each related-finding ID, one per line.
#     Accepts both shapes:
#       relates_to:
#         - HIGH-other-finding              (legacy string form)
#         - id: HIGH-other-finding          (v2.2 structured form)
#           kind: blocks
#           reason: "..."
#         - {id: HIGH-other-finding, kind: duplicate-of, reason: "..."}
#
# `_append_relates_to <yaml> <id> <kind> <reason>` — append a structured entry,
#     creating the relates_to: block if absent. Idempotent: skips if (id, kind)
#     pair already present. Reason gets quote-escaped.
# ---------------------------------------------------------------------------
_relates_to_ids() {
  local file="$1"
  [ -f "${file}" ] || return 0
  awk '
    /^relates_to:/ { inr=1; next }
    inr && /^[a-zA-Z_]/ { inr=0 }
    inr {
      # Strip leading whitespace + dash
      line=$0
      sub(/^[[:space:]]*-[[:space:]]*/, "", line)
      # Flow style: {id: X, kind: ..., reason: ...} OR block style id: X
      if (match(line, /id:[[:space:]]*"?[A-Za-z0-9_.-]+/)) {
        s=substr(line, RSTART, RLENGTH)
        sub(/^id:[[:space:]]*"?/, "", s)
        print s; next
      }
      # Plain string entry
      if (line ~ /^[A-Z]/) { gsub(/[" ]/, "", line); print line; next }
    }
  ' "${file}" 2>/dev/null | awk 'NF && !seen[$0]++'
}

_append_relates_to() {
  local file="$1" rid="$2" kind="$3" reason="${4:-}"
  [ -f "${file}" ] || { echo "[link] target yaml not found: ${file}" >&2; return 1; }
  # Idempotent: skip if id+kind already present
  if grep -qE "id:[[:space:]]*\"?${rid}\"?.*kind:[[:space:]]*${kind}" "${file}" 2>/dev/null; then
    return 0
  fi
  local esc_reason="${reason//\"/\\\"}"
  local entry="  - {id: ${rid}, kind: ${kind}, reason: \"${esc_reason}\"}"
  if grep -q '^relates_to:' "${file}"; then
    # Append inside existing block. Find the line range, insert after last item.
    awk -v entry="${entry}" '
      BEGIN { ins=0 }
      { lines[NR]=$0 }
      /^relates_to:/ { rstart=NR }
      rstart && NR>rstart && /^[a-zA-Z_]/ && !done { rend=NR-1; done=1 }
      END {
        if (!done) rend=NR
        for (i=1; i<=NR; i++) {
          print lines[i]
          if (i==rend) print entry
        }
      }
    ' "${file}" > "${file}.tmp" && mv "${file}.tmp" "${file}"
  else
    printf 'relates_to:\n%s\n' "${entry}" >> "${file}"
  fi
}

# v2.2 cmd_link — `lattice link <id-a> <id-b> --kind <blocks|duplicate-of>
# [--reason "..."]`. Writes structured entries to BOTH YAMLs (bidirectional).
# Default kinds (v2.2 start small): blocks, duplicate-of. More to come.
cmd_link() {
  local a="" b="" kind="" reason=""
  [ "$#" -ge 2 ] || die "link: usage: lattice link <id-a> <id-b> --kind <blocks|duplicate-of> [--reason \"...\"]"
  a="$1"; b="$2"; shift 2
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --kind)   kind="$2"; shift 2 ;;
      --reason) reason="$2"; shift 2 ;;
      --help|-h)
        echo "lattice link <id-a> <id-b> --kind <blocks|duplicate-of> [--reason \"...\"]"
        echo "  Bidirectional cross-ref between two findings (v2.2 #80 #83)."
        return 0 ;;
      *) die "link: unknown flag: $1" ;;
    esac
  done
  [ -n "${kind}" ] || die "link: --kind required (blocks | duplicate-of)"
  case "${kind}" in
    blocks|duplicate-of) ;;
    *) die "link: --kind must be one of: blocks, duplicate-of (v2.2 starts narrow; more kinds in v2.3)" ;;
  esac
  local fa fb
  fa="$(locate_finding "${a}" 2>/dev/null)" || die "link: not found: ${a}"
  fb="$(locate_finding "${b}" 2>/dev/null)" || die "link: not found: ${b}"
  local slug_a slug_b
  slug_a="$(basename "${fa}" .yml)"
  slug_b="$(basename "${fb}" .yml)"
  [ "${slug_a}" = "${slug_b}" ] && die "link: can't link a finding to itself"

  _append_relates_to "${fa}" "${slug_b}" "${kind}" "${reason}"
  # Reverse kind for the back-link: duplicate-of is symmetric; blocks reverses
  # to "blocked-by" — but to stay narrow, reuse `blocks` (the kind is "this
  # finding has a blocks-relationship with that one"; readers can disambiguate
  # via id ordering or by looking at the other side). Simpler than introducing
  # blocked-by in v2.2.
  _append_relates_to "${fb}" "${slug_a}" "${kind}" "${reason}"
  echo "[${PROG}] link: ${slug_a} <-${kind}-> ${slug_b}"
}

# Used by cmd_close before delegating to HELPER_CLOSE — prints related-finding
# nudge so the maintainer sees blocked/duplicate edges they're about to leave.
_close_print_relates_nudge() {
  local src="$1"
  local ids; ids="$(_relates_to_ids "${src}")"
  [ -z "${ids}" ] && return 0
  local rid rfile rtier rstate
  echo "[${PROG}] cross-references (v2.2):" >&2
  while IFS= read -r rid; do
    [ -z "${rid}" ] && continue
    rfile="$(locate_finding "${rid}" 2>/dev/null || true)"
    if [ -z "${rfile}" ]; then
      echo "  🔗 ${rid} (NOT FOUND — stale link)" >&2
      continue
    fi
    rtier="$(yaml_field "${rfile}" "tier" 2>/dev/null || echo '?')"
    if [[ "${rfile}" == .lattice/findings/closed/* ]]; then rstate="closed"; else rstate="open"; fi
    echo "  🔗 ${rid} (tier=${rtier}, ${rstate}) — closing this may affect it" >&2
  done <<< "${ids}"
}

# ---------------------------------------------------------------------------
# reopen
# ---------------------------------------------------------------------------
cmd_reopen() {
  require_helper "${HELPER_REOPEN}"
  if [ "$#" -eq 0 ] || [ -z "${1// }" ]; then
    echo "[${PROG}] error: reopen: <finding-id> is required" >&2
    return 2
  fi
  local rc=0
  bash "${HELPER_REOPEN}" "$@" || rc=$?
  return "${rc}"
}

# ---------------------------------------------------------------------------
# sync (alias: regenerate)
# ---------------------------------------------------------------------------
cmd_sync() {
  require_helper "${HELPER_REGEN}"
  # Explicit exit-code propagation. `set -e` propagation through function
  # boundaries has historically been unreliable in some bash builds (notably
  # Git Bash on Windows) — `cmd ... || rc=$?` captures it deterministically.
  local rc=0
  bash "${HELPER_REGEN}" "$@" || rc=$?
  return "${rc}"
}

# ---------------------------------------------------------------------------
# validate — diagnostic scan over every YAML. Reports per-file parse/schema
# errors. Does not touch CLAUDE.md. Exits 2 if any error found.
# ---------------------------------------------------------------------------
cmd_validate() {
  require_helper "${HELPER_REGEN}"
  local rc=0
  bash "${HELPER_REGEN}" --validate-only "$@" || rc=$?
  return "${rc}"
}

# ---------------------------------------------------------------------------
# defer — set status: deferred + defer_until + defer_reason. Stays in open/.
# ---------------------------------------------------------------------------
cmd_defer() {
  if [ "$#" -lt 1 ]; then
    die "defer: usage: lattice defer <id> --until <YYYY-MM-DD> [--reason \"<text>\"]"
  fi
  local find_id="$1"; shift
  local until=""
  local reason=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --until)
        [ -z "${2:-}" ] || [[ "${2:-}" == --* ]] && die "defer: --until requires a date"
        until="$2"; shift 2 ;;
      --reason)
        [ -z "${2:-}" ] || [[ "${2:-}" == --* ]] && die "defer: --reason requires a value"
        reason="$2"; shift 2 ;;
      *) die "defer: unknown arg: $1" ;;
    esac
  done

  [ -z "${until}" ] && die "defer: --until <YYYY-MM-DD> is required"
  [[ "${until}" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]] || die "defer: --until must be YYYY-MM-DD (got: ${until})"

  local src
  src="$(locate_finding_interactive "${find_id}")" || die "defer: not found or cancelled: ${find_id}"
  if [[ "${src}" == .lattice/findings/closed/* ]]; then
    die "defer: ${find_id} is closed; reopen first if it needs deferring"
  fi

  local now
  now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

  # Strip prior defer/status lines, then append canonical block.
  local tmp
  tmp="$(mktemp)"
  grep -v -E '^(status|defer_until|defer_reason|deferred_at)[[:space:]]*:|^# Defer \(set by lattice defer\)$' "${src}" > "${tmp}" || true
  mv "${tmp}" "${src}"

  {
    printf "\n# Defer (set by lattice defer)\n"
    printf "status: deferred\n"
    printf "defer_until: %s\n" "${until}"
    printf "deferred_at: %s\n" "${now}"
    if [ -n "${reason}" ]; then
      if [[ "${reason}" == *$'\n'* ]]; then
        printf "defer_reason: |\n"
        printf "%s\n" "${reason}" | sed 's/^/  /'
      else
        local esc_reason
        esc_reason="$(printf "%s" "${reason}" | sed 's/\\/\\\\/g; s/"/\\"/g')"
        printf "defer_reason: \"%s\"\n" "${esc_reason}"
      fi
    fi
  } >> "${src}"

  echo "[${PROG}] deferred ${find_id} until ${until}"
  [ -n "${reason}" ] && echo "[${PROG}] reason: ${reason}"
  echo "[${PROG}] file: ${src}"
}

# ---------------------------------------------------------------------------
# list — print open findings, optional filters. Format: <tier> <module>/<rule> <file>:<line>
# ---------------------------------------------------------------------------
cmd_list() {
  local filter_module="" filter_tier="" filter_status="" filter_dim=""
  local filter_milestone="" filter_exposure=""
  local due_for_review=0
  local blocked_filter=""   # "" = no filter, "blocked" = only blocked, "unblocked" = only unblocked
  local show_effective=0    # --effective-tier: render tier post-demotion
  # v1.3.1 (#16): OK-tier findings hidden by default. They're audit-passed
  # markers, not actionable work. --include-ok or --tier OK shows them.
  local include_ok=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --module)    filter_module="$2"; shift 2 ;;
      --tier)      filter_tier="$2"; shift 2 ;;
      --status)    filter_status="$2"; shift 2 ;;
      --dimension) filter_dim="$2"; shift 2 ;;
      --milestone) filter_milestone="$2"; shift 2 ;;
      --exposure)  filter_exposure="$2"; shift 2 ;;
      --effective-tier) show_effective=1; shift ;;
      --due-for-review) due_for_review=1; shift ;;
      --unblocked) blocked_filter="unblocked"; shift ;;
      --blocked)   blocked_filter="blocked"; shift ;;
      --include-ok|--all) include_ok=1; shift ;;
      *) die "list: unknown arg: $1" ;;
    esac
  done
  # If user explicitly filters --tier OK, they want OK — let it through.
  [ "${filter_tier^^}" = "OK" ] && include_ok=1
  # Normalize "partial" alias → "in_progress" (B2)
  [ "${filter_status}" = "partial" ] && filter_status="in_progress"

  [ -d ".lattice/findings/open" ] || { echo "[${PROG}] no .lattice/findings/open/ in cwd" >&2; return 0; }

  local today
  today="$(date -u +%Y-%m-%d)"

  shopt -s nullglob
  local count=0
  for f in .lattice/findings/open/*/*.yml .lattice/findings/open/*.yml; do
    [ -f "${f}" ] || continue

    local rule module tier dimension status defer_until file_field line_field
    rule="$(yaml_field "${f}" "rule")"
    module="$(yaml_field "${f}" "module")"
    tier="$(yaml_field "${f}" "tier")"
    dimension="$(yaml_field "${f}" "dimension")"
    status="$(yaml_field "${f}" "status")"
    defer_until="$(yaml_field "${f}" "defer_until")"
    file_field="$(yaml_field "${f}" "file")"
    line_field="$(yaml_field "${f}" "line")"
    [ -z "${status}" ] && status="open"

    # --module: case-insensitive substring match against the module: field.
    # Lets `--module booking` match a `module: src/modules/booking/...` value.
    if [ -n "${filter_module}" ]; then
      local mod_lower="${module,,}"
      local fil_lower="${filter_module,,}"
      [[ "${mod_lower}" == *"${fil_lower}"* ]] || continue
    fi
    [ -n "${filter_tier}" ]   && [ "${tier}"   != "${filter_tier}" ]   && continue
    [ -n "${filter_status}" ] && [ "${status}" != "${filter_status}" ] && continue
    [ -n "${filter_dim}" ]    && [ "${dimension}" != "${filter_dim}" ] && continue
    # v1.3.1 (#16): hide OK by default
    [ "${include_ok}" -eq 0 ] && [ "${tier}" = "OK" ] && continue

    if [ -n "${blocked_filter}" ]; then
      local blocked_by
      blocked_by="$(yaml_field "${f}" "blocked_by")"
      case "${blocked_filter}" in
        unblocked) [ -n "${blocked_by}" ] && continue ;;
        blocked)   [ -z "${blocked_by}" ] && continue ;;
      esac
    fi

    if [ -n "${filter_milestone}" ]; then
      local milestone
      milestone="$(yaml_field "${f}" "milestone")"
      [ "${milestone}" = "${filter_milestone}" ] || continue
    fi

    local exposure
    exposure="$(yaml_field "${f}" "exposure")"
    if [ -n "${filter_exposure}" ]; then
      [ "${exposure}" = "${filter_exposure}" ] || continue
    fi

    if [ "${due_for_review}" -eq 1 ]; then
      [ "${status}" != "deferred" ] && continue
      [ -z "${defer_until}" ] && continue
      [[ ! "${defer_until}" > "${today}" ]] || continue   # only past-due
    fi

    local extra=""
    [ "${status}" = "deferred" ] && [ -n "${defer_until}" ] && extra=" (defer_until: ${defer_until})"
    [ "${status}" = "in_progress" ] && extra=" (in_progress)"
    [ "${status}" = "wont_fix" ] && extra=" (wont_fix)"

    local display_tier="${tier}"
    if [ -n "${exposure}" ]; then
      if [ "${show_effective}" -eq 1 ]; then
        local eff
        eff="$(effective_tier "${tier}" "${exposure}")"
        if [ "${eff}" != "${tier}" ]; then
          display_tier="${eff}"
          extra="${extra} (was ${tier}, ${exposure})"
        else
          extra="${extra} (${exposure})"
        fi
      else
        extra="${extra} (${exposure})"
      fi
    fi
    # v1.4.0 (#55 #56): apply operator-profile-based reweighting on top of
    # exposure demotion. Only when --effective-tier is set, to keep the
    # default `lattice list` view stable (and surfacing the raw audit signal).
    if [ "${show_effective}" -eq 1 ]; then
      local fix_text
      fix_text="$(yaml_field "${f}" "fix")"
      local reweighted
      reweighted="$(_profile_reweight_tier "${display_tier}" "${dimension}" "${rule}" "${fix_text}")"
      if [ "${reweighted}" != "${display_tier}" ]; then
        extra="${extra} [profile: ${display_tier}->${reweighted}]"
        display_tier="${reweighted}"
      fi
    fi

    # v1.1.2 (#50): hide the "—  :" tail when both file and line are empty,
    # which happens for finding YAMLs that lack file:/line: fields (e.g. some
    # audit-sweep emissions). Renders cleanly as just `module/rule` then extra.
    if [ -z "${file_field}" ] && [ -z "${line_field}" ]; then
      printf "%-9s %-12s %s/%s%s\n" "${display_tier}" "${dimension}" "${module}" "${rule}" "${extra}"
    else
      printf "%-9s %-12s %s/%s — %s:%s%s\n" "${display_tier}" "${dimension}" "${module}" "${rule}" "${file_field}" "${line_field}" "${extra}"
    fi
    count=$((count + 1))
  done

  echo ""
  if [ "${count}" -eq 0 ] && [ "${due_for_review}" -eq 1 ]; then
    echo "[${PROG}] 0 finding(s) past their defer_until date"
  else
    echo "[${PROG}] ${count} finding(s)"
  fi
}

# ---------------------------------------------------------------------------
# show — print one YAML, with a header line.
# ---------------------------------------------------------------------------
cmd_show() {
  [ "$#" -ge 1 ] || die "show: usage: lattice show <id>"
  local find_id="$1"
  local all_matches=()
  while IFS= read -r line; do
    [ -n "${line}" ] && all_matches+=("${line}")
  done < <(locate_finding_all "${find_id}" 2>/dev/null || true)
  [ "${#all_matches[@]}" -eq 0 ] && die "show: not found: ${find_id}.yml"

  local idx=0
  for src in "${all_matches[@]}"; do
    idx=$((idx + 1))
    local where="open"
    [[ "${src}" == .lattice/findings/closed/* ]] && where="closed"
    if [ "${#all_matches[@]}" -gt 1 ]; then
      echo ""
      echo "--- [${idx}/${#all_matches[@]}] ---"
    fi
    echo "[${PROG}] ${src} (${where})"
    echo "----------------------------------------------------------------------"
    cat "${src}"
  done
}

# ---------------------------------------------------------------------------
# sweeps — list sweep manifests under .lattice/findings/sweeps/
# (Manifest writer ships in v0.7; until then this lists what's there or notes
# that no manifests exist.)
# ---------------------------------------------------------------------------
cmd_sweeps() {
  local dir=".lattice/findings/sweeps"
  if [ ! -d "${dir}" ]; then
    echo "[${PROG}] no ${dir}/ — run an audit sweep to generate manifests"
    return 0
  fi
  shopt -s nullglob
  local count=0
  for f in "${dir}"/*.yml; do
    [ -f "${f}" ] || continue
    local sweep_id sweep_date dims
    sweep_id="$(yaml_field "${f}" "sweep_id")"
    sweep_date="$(yaml_field "${f}" "sweep_date")"
    dims="$(yaml_field "${f}" "dimensions")"
    printf "%s  %s  %s\n" "${sweep_date:-?}" "${sweep_id:-$(basename "${f}" .yml)}" "${dims}"
    count=$((count + 1))
  done
  echo ""
  echo "[${PROG}] ${count} sweep manifest(s)"
}

# ---------------------------------------------------------------------------
# bulk-close — close every open finding whose slug matches a glob pattern.
# Always confirms unless --yes is passed.
# ---------------------------------------------------------------------------
cmd_bulk_close() {
  local pattern=""
  local commit=""
  local reason=""
  local rationale=""
  local pending=0
  local yes=0
  # v0.9.5 (#23): added --reason / --rationale / --pending so a migration that
  # closes N findings for the same architectural reason (ADR adoption, refactor,
  # deprecation) can pass the rationale ONCE instead of looping `lattice close`.
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --pattern)   pattern="$2"; shift 2 ;;
      --commit)    commit="$2"; shift 2 ;;
      --reason)    reason="$2"; shift 2 ;;
      --rationale) rationale="$2"; shift 2 ;;
      --pending)   pending=1; shift ;;
      --yes|-y)    yes=1; shift ;;
      *) die "bulk-close: unknown arg: $1" ;;
    esac
  done
  [ -z "${pattern}" ] && die "bulk-close: --pattern <glob> is required (e.g. --pattern \"LOW-results-*\")"
  if [ -n "${reason}" ]; then
    case "${reason}" in
      fixed|false-positive|wont-fix|out-of-scope|duplicate) ;;
      *) die "bulk-close: --reason must be one of: fixed | false-positive | wont-fix | out-of-scope | duplicate" ;;
    esac
  fi

  shopt -s nullglob
  local matches=()
  for f in .lattice/findings/open/*/${pattern}.yml .lattice/findings/open/${pattern}.yml; do
    [ -f "${f}" ] || continue
    matches+=("${f}")
  done

  if [ "${#matches[@]}" -eq 0 ]; then
    echo "[${PROG}] bulk-close: 0 findings match pattern '${pattern}'"
    return 0
  fi

  echo "[${PROG}] bulk-close: ${#matches[@]} match(es) for '${pattern}':"
  local f
  for f in "${matches[@]}"; do
    echo "  - $(basename "${f}" .yml)"
  done

  if [ "${yes}" -ne 1 ]; then
    if [ ! -t 0 ]; then
      die "bulk-close: refusing to close without --yes when stdin is not a TTY"
    fi
    printf "[${PROG}] proceed? [y/N] "
    local ans; read -r ans </dev/tty || ans=""
    case "${ans}" in
      y|Y|yes|YES) ;;
      *) echo "[${PROG}] bulk-close: aborted"; return 0 ;;
    esac
  fi

  local closed=0 failed=0
  for f in "${matches[@]}"; do
    local slug="$(basename "${f}" .yml)"
    local args=( "${slug}" )
    [ -n "${commit}" ]    && args+=( "--commit" "${commit}" )
    [ -n "${reason}" ]    && args+=( "--reason" "${reason}" )
    [ -n "${rationale}" ] && args+=( "--rationale" "${rationale}" )
    [ "${pending}" -eq 1 ] && args+=( "--pending" )
    if bash "${HELPER_CLOSE}" "${args[@]}"; then
      closed=$((closed + 1))
    else
      failed=$((failed + 1))
      echo "[${PROG}] (close failed for ${slug}; continuing)"
    fi
  done
  echo ""
  echo "[${PROG}] bulk-close: ${closed} closed, ${failed} failed"
  [ "${failed}" -eq 0 ]
}

# ---------------------------------------------------------------------------
# id-gen — compute stable v0.7 finding id from dimension, rule, file, code_context.
# Usage: lattice id-gen <dimension> <rule> <file> <code_context...>
# Algorithm: sha1(dimension:rule:file:code_context_normalized)[:12]
# The id survives line shifts because no line number is included in the hash.
# ---------------------------------------------------------------------------
cmd_id_gen() {
  [ "$#" -ge 4 ] || die "id-gen: usage: lattice id-gen <dimension> <rule> <file> <code_context>"
  local dimension="$1" rule="$2" file="$3"
  shift 3
  local code_context="$*"
  # Normalize: collapse all whitespace runs to single space, strip leading/trailing
  local normalized
  normalized="$(printf '%s' "${code_context}" | tr -s '[:space:]' ' ' | sed 's/^ //; s/ $//')"
  local input="${dimension}:${rule}:${file}:${normalized}"
  local hash
  if command -v sha1sum >/dev/null 2>&1; then
    hash="$(printf '%s' "${input}" | sha1sum | cut -c1-12)"
  elif command -v shasum >/dev/null 2>&1; then
    hash="$(printf '%s' "${input}" | shasum -a 1 | cut -c1-12)"
  else
    die "id-gen: sha1sum or shasum is required but not found"
  fi
  printf '%s\n' "${hash}"
}

# ---------------------------------------------------------------------------
# sweep-id — emit <YYYYMMDD><6-hex>. Used by audit skills to tag findings
# and the sweep manifest with a stable, sortable, collision-resistant ID.
# ---------------------------------------------------------------------------
cmd_sweep_id() {
  # 24 bits of entropy from two $RANDOM draws (15 bits each, masked).
  # Not cryptographic — just enough to avoid collision among same-day sweeps.
  # Avoids /dev/urandom + tr|head SIGPIPE issues on Git Bash.
  local date_part rand_part
  date_part="$(date -u +%Y%m%d)"
  rand_part="$(printf "%06x" $(( ((RANDOM << 15) | RANDOM) & 0xFFFFFF )))"
  printf "%s%s\n" "${date_part}" "${rand_part}"
}

# ---------------------------------------------------------------------------
# version
# ---------------------------------------------------------------------------
cmd_version() {
  # Prefer plugin.json next to the script (source repo); fall back to the
  # installed VERSION sentinel. Strip a leading BOM if present (some Windows
  # writers prepend U+FEFF).
  local v=""
  local plugin="${SELF_DIR}/../.claude-plugin/plugin.json"
  if [ -f "${plugin}" ]; then
    v="$(grep -oE '"version"\s*:\s*"[^"]+"' "${plugin}" | head -n1 | sed -E 's/.*"version"\s*:\s*"([^"]+)".*/\1/')"
  fi
  if [ -z "${v}" ] && [ -f "${HOME}/.claude/lattice/VERSION" ]; then
    v="$(cat "${HOME}/.claude/lattice/VERSION" 2>/dev/null || true)"
    v="${v#$'\xef\xbb\xbf'}"  # strip UTF-8 BOM if present
    v="${v%$'\r'}"
  fi
  echo "lattice ${v:-unknown}"
}

# ---------------------------------------------------------------------------
# handoff — emit a Markdown executor brief for a finding (stdout).
# ---------------------------------------------------------------------------
cmd_handoff() {
  [ "$#" -ge 1 ] || die "handoff: usage: lattice handoff <id>"
  local find_id="$1"
  local src
  src="$(locate_finding_interactive "${find_id}")" || die "handoff: not found or cancelled: ${find_id}"

  local slug tier module rule dimension title file_field line_field fix
  slug="$(basename "${src}" .yml)"
  tier="$(yaml_field "${src}" "tier")"
  module="$(yaml_field "${src}" "module")"
  rule="$(yaml_field "${src}" "rule")"
  dimension="$(yaml_field "${src}" "dimension")"
  title="$(yaml_field "${src}" "title")"
  file_field="$(yaml_field "${src}" "file")"
  line_field="$(yaml_field "${src}" "line")"
  fix="$(yaml_field "${src}" "fix")"

  local description simulate
  description="$(awk '/^description[[:space:]]*:/{found=1;next} found && /^[a-zA-Z_][a-zA-Z0-9_]*[[:space:]]*:/{exit} found{sub(/^  /,""); print}' "${src}")"
  simulate="$(awk '/^simulate[[:space:]]*:/{found=1;next} found && /^[a-zA-Z_][a-zA-Z0-9_]*[[:space:]]*:/{exit} found && /^[[:space:]]*-/{sub(/^[[:space:]]*-[[:space:]]*/,""); print}' "${src}")"

  printf '# Executor Brief: %s\n\n' "${slug}"
  printf '**Tier:** %s  \n**Dimension:** %s  \n**Module:** %s  \n**Rule:** %s  \n**File:** %s:%s\n\n' \
    "${tier}" "${dimension}" "${module}" "${rule}" "${file_field}" "${line_field}"
  printf '## Summary\n%s\n\n' "${title:-*(see YAML)*}"
  printf '## Fix\n%s\n\n' "${fix:-*(see YAML)*}"
  [ -n "${description}" ] && printf '## Description\n%s\n\n' "${description}"
  printf '## Verification Steps\n'
  if [ -n "${simulate}" ]; then
    local i=0
    while IFS= read -r step; do
      [ -z "${step}" ] && continue
      i=$((i + 1))
      printf '%d. %s\n' "${i}" "${step}"
    done <<< "${simulate}"
  else
    printf '*(no simulate: steps — add them to %s)*\n' "${src}"
  fi
  printf '\n## Source\n`%s`\n' "${src}"
}

# ---------------------------------------------------------------------------
# next — pick the highest-priority open (non-deferred) finding.
# Tier order: CRITICAL > BLOCKER > HIGH > MEDIUM > LOW > WATCH > RISK > DRIFT
# ---------------------------------------------------------------------------
cmd_next() {
  local filter_module=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --module) [ -z "${2:-}" ] && die "next: --module requires a value"
                filter_module="$2"; shift 2 ;;
      *) die "next: unknown arg: $1" ;;
    esac
  done

  [ -d ".lattice/findings/open" ] || { echo "[${PROG}] next: no open findings directory"; return 0; }

  _tier_pri() {
    case "$1" in
      CRITICAL) echo 1 ;; BLOCKER) echo 2 ;; HIGH)    echo 3 ;;
      MEDIUM)   echo 4 ;; LOW)     echo 5 ;; WATCH)   echo 6 ;;
      RISK)     echo 7 ;; DRIFT)   echo 8 ;; *)        echo 99 ;;
    esac
  }

  shopt -s nullglob
  local best_path="" best_pri=999
  for f in .lattice/findings/open/*/*.yml .lattice/findings/open/*.yml; do
    [ -f "${f}" ] || continue
    local module tier status
    module="$(yaml_field "${f}" "module")"
    tier="$(yaml_field "${f}" "tier")"
    status="$(yaml_field "${f}" "status")"
    [ "${status}" = "deferred" ] && continue
    [ "${status}" = "wont_fix" ]  && continue
    if [ -n "${filter_module}" ]; then
      [[ "${module,,}" == *"${filter_module,,}"* ]] || continue
    fi
    local pri; pri="$(_tier_pri "${tier}")"
    if [ "${pri}" -lt "${best_pri}" ]; then
      best_pri="${pri}"; best_path="${f}"
    fi
  done

  if [ -z "${best_path}" ]; then
    echo "[${PROG}] next: no actionable open findings${filter_module:+ in module '${filter_module}'}"
    return 0
  fi

  local slug tier module rule file_field line_field title
  slug="$(basename "${best_path}" .yml)"
  tier="$(yaml_field "${best_path}" "tier")"
  module="$(yaml_field "${best_path}" "module")"
  rule="$(yaml_field "${best_path}" "rule")"
  file_field="$(yaml_field "${best_path}" "file")"
  line_field="$(yaml_field "${best_path}" "line")"
  title="$(yaml_field "${best_path}" "title")"

  echo "[${PROG}] next: ${tier}  ${module}/${rule}"
  [ -n "${title}" ] && echo "  title: ${title}"
  echo "  file:  ${file_field}:${line_field}"
  echo "  slug:  ${slug}"
  echo "  path:  ${best_path}"
}

# ---------------------------------------------------------------------------
# verify — print or run the simulate: steps for a finding.
# ---------------------------------------------------------------------------
cmd_verify() {
  local run_mode=0 rerun_grep=0 close_clean=0
  local find_id=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --run) run_mode=1; shift ;;
      --rerun-grep) rerun_grep=1; shift ;;
      --close-clean) close_clean=1; shift ;;
      -*) die "verify: unknown flag: $1" ;;
      *)  find_id="$1"; shift ;;
    esac
  done
  [ -z "${find_id}" ] && die "verify: usage: lattice verify <id> [--run | --rerun-grep [--close-clean]]"
  [ "${close_clean}" -eq 1 ] && [ "${rerun_grep}" -eq 0 ] && die "verify: --close-clean requires --rerun-grep"

  local src
  src="$(locate_finding_interactive "${find_id}")" || die "verify: not found or cancelled: ${find_id}"

  local slug tier module rule title
  slug="$(basename "${src}" .yml)"
  tier="$(yaml_field "${src}" "tier")"
  module="$(yaml_field "${src}" "module")"
  rule="$(yaml_field "${src}" "rule")"
  title="$(yaml_field "${src}" "title")"

  local simulate_steps
  simulate_steps="$(awk '/^simulate[[:space:]]*:/{found=1;next} found && /^[a-zA-Z_][a-zA-Z0-9_]*[[:space:]]*:/{exit} found && /^[[:space:]]*-/{sub(/^[[:space:]]*-[[:space:]]*/,""); print}' "${src}" 2>/dev/null || true)"

  echo "[${PROG}] verify: ${tier}  ${module}/${rule}"
  [ -n "${title}" ] && echo "  ${title}"
  echo ""

  if [ "${rerun_grep}" -eq 1 ]; then
    local pattern verify_file negate file_field file_path
    pattern="$(yaml_field "${src}" "verify_pattern")"
    verify_file="$(yaml_field "${src}" "verify_file")"
    negate="$(yaml_field "${src}" "verify_negate")"
    file_field="$(yaml_field "${src}" "file")"
    file_path="${verify_file:-${file_field}}"
    file_path="${file_path%%:*}"

    if [ -z "${pattern}" ]; then
      echo "[${PROG}] verify: no verify_pattern: field in ${slug}"
      echo "[${PROG}] hint: add verify_pattern: <regex> to the YAML so this command can re-run the grep that originally detected the issue."
      echo "[${PROG}]       optional fields: verify_file: <path> (default: file:), verify_negate: true|false"
      return 0
    fi
    if [ -z "${file_path}" ]; then
      echo "[${PROG}] verify: no file: or verify_file: field — cannot re-run grep"
      return 2
    fi
    if [ ! -f "${file_path}" ]; then
      echo "[${PROG}] verify: file no longer exists: ${file_path}"
      echo "[${PROG}] hint: file was deleted or moved — close with --reason fixed (if intentional) or duplicate (if relocated)"
      return 2
    fi

    local matched=0
    if grep -qE -- "${pattern}" "${file_path}" 2>/dev/null; then
      matched=1
    fi

    local is_clean=0 verdict
    if [ "${negate}" = "true" ]; then
      [ "${matched}" -eq 1 ] && is_clean=1
      verdict="pattern (negate) MATCH = clean"
    else
      [ "${matched}" -eq 0 ] && is_clean=1
      verdict="pattern NO-MATCH = clean"
    fi

    echo "  file:    ${file_path}"
    echo "  pattern: ${pattern}"
    echo "  mode:    ${verdict}"
    echo "  matched: $([ ${matched} -eq 1 ] && echo yes || echo no)"
    echo ""
    if [ "${is_clean}" -eq 1 ]; then
      echo "[${PROG}] verify: PASS — finding appears resolved (pattern check clean)"
      if [ "${close_clean}" -eq 1 ]; then
        local sha
        sha="$(git rev-parse --short HEAD 2>/dev/null || echo manual)"
        # Use the helper directly to avoid PATH/recursion oddities.
        bash "${HELPER_CLOSE}" "${slug}" --reason fixed --commit "${sha}" --rationale "auto-closed by lattice verify --rerun-grep --close-clean (pattern no longer matches)" >/dev/null 2>&1 \
          && echo "[${PROG}] verify: --close-clean moved ${slug} to .lattice/findings/closed/" \
          || echo "[${PROG}] verify: --close-clean FAILED to move finding — close manually"
      fi
      return 0
    else
      echo "[${PROG}] verify: STILL OPEN — pattern check did not pass (issue likely still present)"
      return 1
    fi
  fi

  if [ -z "${simulate_steps}" ]; then
    echo "[${PROG}] verify: no simulate: steps defined in ${slug}"
    echo "[${PROG}] hint: add a 'simulate:' list to the YAML to enable this command"
    return 0
  fi

  if [ "${run_mode}" -eq 0 ]; then
    echo "Verification steps:"
    local i=0
    while IFS= read -r step; do
      [ -z "${step}" ] && continue
      i=$((i + 1))
      printf '  %d. %s\n' "${i}" "${step}"
    done <<< "${simulate_steps}"
    echo ""
    echo "[${PROG}] hint: pass --run to execute these steps"
  else
    echo "Running verification steps:"
    local i=0 failed=0
    while IFS= read -r step; do
      [ -z "${step}" ] && continue
      i=$((i + 1))
      echo ""
      echo "  [${i}] \$ ${step}"
      step="${step#\"}"; step="${step%\"}"
      step="${step#\'}"; step="${step%\'}"
      if ! eval "${step}"; then
        echo "  [FAIL] step ${i} exited non-zero"
        failed=$((failed + 1))
      fi
    done <<< "${simulate_steps}"
    echo ""
    if [ "${failed}" -eq 0 ]; then
      echo "[${PROG}] verify: all ${i} step(s) passed"
    else
      echo "[${PROG}] verify: ${failed}/${i} step(s) failed"
      return 1
    fi
  fi
}

# ---------------------------------------------------------------------------
# ci-check — exit 1 if any non-deferred CRITICAL or BLOCKER finding is open.
# Designed for CI gates and pre-push hooks.
# ---------------------------------------------------------------------------
cmd_ci_check() {
  local fail_tiers="CRITICAL BLOCKER"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --tier) [ -z "${2:-}" ] && die "ci-check: --tier requires a value"
              fail_tiers="$2"; shift 2 ;;
      *) die "ci-check: unknown arg: $1" ;;
    esac
  done

  [ -d ".lattice/findings/open" ] || { echo "[${PROG}] ci-check: no open findings — clean"; return 0; }

  shopt -s nullglob
  local blockers=() missing_files=() closed_bad=() dupes=() seen=() total=0
  for f in .lattice/findings/open/*/*.yml .lattice/findings/open/*.yml; do
    [ -f "${f}" ] || continue
    total=$((total + 1))
    local tier status file_field module rule key
    tier="$(yaml_field "${f}" "tier")"
    status="$(yaml_field "${f}" "status")"
    file_field="$(yaml_field "${f}" "file")"
    module="$(yaml_field "${f}" "module")"
    rule="$(yaml_field "${f}" "rule")"
    [ "${status}" = "deferred" ] && continue
    [ "${status}" = "wont_fix" ]  && continue
    if [ -n "${file_field}" ] && [ ! -e "${file_field%%:*}" ]; then
      missing_files+=("$(basename "${f}" .yml)  file=${file_field}")
    fi
    key="${module}|${rule}"
    for prior in "${seen[@]:-}"; do
      if [ "${prior}" = "${key}" ]; then
        dupes+=("${module}/${rule}")
        break
      fi
    done
    seen+=("${key}")
    for t in ${fail_tiers}; do
      if [ "${tier}" = "${t}" ]; then
        blockers+=("$(basename "${f}" .yml)  [${tier}]")
        break
      fi
    done
  done

  for f in .lattice/findings/closed/*/*.yml .lattice/findings/closed/*.yml; do
    [ -f "${f}" ] || continue
    sha="$(yaml_field "${f}" "closed_by_commit")"
    [ -z "${sha}" ] && { closed_bad+=("$(basename "${f}" .yml)  missing closed_by_commit"); continue; }
    if git rev-parse --verify --quiet "${sha}^{commit}" >/dev/null 2>&1; then
      :
    else
      closed_bad+=("$(basename "${f}" .yml)  closed_by_commit=${sha} not in git")
    fi
  done

  echo "[${PROG}] ci-check: ${total} open finding(s), ${#blockers[@]} blocker(s), ${#missing_files[@]} missing file ref(s), ${#closed_bad[@]} bad closure ref(s), ${#dupes[@]} duplicate rule/module pair(s)"
  for entry in "${blockers[@]:-}"; do
    [ -n "${entry}" ] && echo "  FAIL  ${entry}"
  done
  for entry in "${missing_files[@]:-}"; do [ -n "${entry}" ] && echo "  FAIL  missing-file  ${entry}"; done
  for entry in "${closed_bad[@]:-}"; do [ -n "${entry}" ] && echo "  FAIL  closed-ref  ${entry}"; done
  for entry in "${dupes[@]:-}"; do [ -n "${entry}" ] && echo "  FAIL  duplicate-rule-module  ${entry}"; done
  [ "${#blockers[@]}" -eq 0 ] && [ "${#missing_files[@]}" -eq 0 ] && [ "${#closed_bad[@]}" -eq 0 ] && [ "${#dupes[@]}" -eq 0 ]
}

# ---------------------------------------------------------------------------
# usage — summarize repo-local command usage events.
# ---------------------------------------------------------------------------
cmd_usage() {
  local since_days=30 unused_days=90 json=0 global_mode=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --since)  [ -z "${2:-}" ] && die "usage: --since requires days"; since_days="$2"; shift 2 ;;
      --unused) [ -z "${2:-}" ] && die "usage: --unused requires days"; unused_days="$2"; shift 2 ;;
      --json)   json=1; shift ;;
      --global) global_mode=1; shift ;;
      *) die "usage: unknown arg: $1" ;;
    esac
  done
  [[ "${since_days}" =~ ^[0-9]+$ ]] || die "usage: --since must be a day count"
  [[ "${unused_days}" =~ ^[0-9]+$ ]] || die "usage: --unused must be a day count"

  local events
  if [ "${global_mode}" -eq 1 ]; then
    events="${HOME}/.claude/lattice/usage/global.jsonl"
  else
    events=".lattice/usage/events.jsonl"
  fi
  if [ ! -f "${events}" ]; then
    if [ "${json}" -eq 1 ]; then
      echo '{"events":0,"commands":[],"unused":[]}'
    else
      echo "[${PROG}] usage: no events yet (${events})"
      [ "${global_mode}" -eq 0 ] && echo "[${PROG}] usage logging is local and controlled by .lattice/config.yml"
      [ "${global_mode}" -eq 1 ] && echo "[${PROG}] global aggregate is at ${events} — populated as you run lattice across projects"
    fi
    return 0
  fi

  node --input-type=module - "${events}" "${since_days}" "${unused_days}" "${json}" <<'NODE'
import fs from 'node:fs';

const [eventsPath, sinceDaysRaw, unusedDaysRaw, jsonRaw] = process.argv.slice(2);
const sinceDays = Number(sinceDaysRaw);
const unusedDays = Number(unusedDaysRaw);
const jsonMode = jsonRaw === '1';
const known = [
  'close','reopen','sync','regenerate','defer','list','ls','show','cat',
  'cluster','bulk-close','handoff','next','timeline','verify','ci-check','pr-body',
  'validate','sweeps','sweep-id','id-gen','usage','update','config','version'
];
const now = Date.now();
const sinceCutoff = now - sinceDays * 86400_000;
const unusedCutoff = now - unusedDays * 86400_000;
const rows = fs.readFileSync(eventsPath, 'utf8')
  .split(/\r?\n/)
  .filter(Boolean)
  .map(line => {
    try { return JSON.parse(line); } catch { return null; }
  })
  .filter(Boolean);
const filtered = rows.filter(r => {
  const t = Date.parse(r.ts || '');
  return Number.isFinite(t) && t >= sinceCutoff;
});
const counts = new Map();
const lastSeen = new Map();
for (const r of rows) {
  const cmd = r.command || 'unknown';
  const t = Date.parse(r.ts || '');
  if (Number.isFinite(t)) {
    if (!lastSeen.has(cmd) || t > lastSeen.get(cmd)) lastSeen.set(cmd, t);
  }
}
for (const r of filtered) {
  const cmd = r.command || 'unknown';
  const item = counts.get(cmd) || { command: cmd, count: 0, last_seen: null, versions: new Map() };
  item.count += 1;
  const t = Date.parse(r.ts || '');
  if (Number.isFinite(t) && (!item.last_seen || t > Date.parse(item.last_seen))) {
    item.last_seen = new Date(t).toISOString();
  }
  const v = r.version || 'unknown';
  item.versions.set(v, (item.versions.get(v) || 0) + 1);
  counts.set(cmd, item);
}
const commands = [...counts.values()].sort((a, b) => b.count - a.count || a.command.localeCompare(b.command))
  .map(x => ({...x, versions: Object.fromEntries(x.versions)}));
const unused = known.filter(cmd => !lastSeen.has(cmd) || lastSeen.get(cmd) < unusedCutoff)
  .map(cmd => ({
    command: cmd,
    last_seen: lastSeen.has(cmd) ? new Date(lastSeen.get(cmd)).toISOString() : null,
  }));
if (jsonMode) {
  console.log(JSON.stringify({ events: rows.length, since_days: sinceDays, commands, unused_days: unusedDays, unused }, null, 2));
} else {
  console.log(`[lattice] usage: ${filtered.length} event(s) in last ${sinceDays} day(s), ${rows.length} total`);
  console.log('');
  console.log('Most used commands:');
  if (commands.length === 0) console.log('  (none in window)');
  for (const item of commands.slice(0, 12)) {
    console.log(`  ${String(item.count).padStart(4)}  ${item.command}  last=${item.last_seen || 'unknown'}`);
  }
  console.log('');
  console.log(`Unused candidates (${unusedDays}+ days or never used):`);
  for (const item of unused.slice(0, 20)) {
    console.log(`  - ${item.command}${item.last_seen ? ` (last ${item.last_seen})` : ' (never)'}`);
  }
}
NODE
}

# ---------------------------------------------------------------------------
# update — check for or apply Lattice updates.
# ---------------------------------------------------------------------------
cmd_update() {
  local action="--check"
  [ "$#" -gt 0 ] && action="$1"
  case "${action}" in
    --check)
      ensure_project_dirs
      local current latest now cache
      current="$(current_version)"
      latest="$(latest_remote_version || true)"
      [ -z "${latest}" ] && { echo "[${PROG}] update: could not check latest version" >&2; return 1; }
      now="$(date +%s)"
      cache=".lattice/cache/update-check.env"
      {
        printf "checked_at=%s\n" "${now}"
        printf "current_version=%q\n" "${current}"
        printf "latest_version=%q\n" "${latest}"
      } > "${cache}" 2>/dev/null || true
      if version_newer "${latest}" "${current}"; then
        echo "[${PROG}] update available: ${current} -> ${latest}"
        echo "[${PROG}] run: lattice update --self"
        return 1
      fi
      echo "[${PROG}] up to date: ${current}"
      ;;
    --self)
      # v1.4.1: capture the RUNNING version (what `lattice` resolves to on the
      # user's PATH) BEFORE update, so we can verify after that the version
      # actually moved. Without this, the update appears to succeed even when
      # it updated a copy the user's shim doesn't point at.
      local _pre_running=""
      if command -v lattice >/dev/null 2>&1; then
        _pre_running="$(lattice version 2>/dev/null | head -1 | awk '{print $NF}' || echo unknown)"
      fi

      # Search order (#18): project-local sibling, global install, fresh GitHub fetch.
      local updater="${SELF_DIR}/update.sh"
      if [ -f "${updater}" ]; then
        bash "${updater}"
      elif [ -f "${HOME}/.claude/lattice/scripts/update.sh" ]; then
        echo "[${PROG}] update: using global installer at ~/.claude/lattice/scripts/update.sh" >&2
        bash "${HOME}/.claude/lattice/scripts/update.sh"
      else
        echo "[${PROG}] update: no local update.sh found — fetching from GitHub" >&2
        if command -v curl >/dev/null 2>&1; then
          curl -fsSL https://raw.githubusercontent.com/IsaamMJ/Lattice/main/scripts/update.sh | bash
        elif command -v wget >/dev/null 2>&1; then
          wget -qO- https://raw.githubusercontent.com/IsaamMJ/Lattice/main/scripts/update.sh | bash
        else
          die "update: neither local update.sh nor curl/wget available"
        fi
      fi

      # v1.4.1: self-verify. Compare the version `lattice` resolves to NOW vs
      # the canonical install version. If they differ, the user's shim points
      # at a different script — update silently shipped a fake success.
      if command -v lattice >/dev/null 2>&1; then
        local _post_running _canonical_v _canonical="${HOME}/.claude/lattice/scripts/lattice"
        _post_running="$(lattice version 2>/dev/null | head -1 | awk '{print $NF}' || echo unknown)"
        if [ -f "${_canonical}" ]; then
          _canonical_v="$(bash "${_canonical}" version 2>/dev/null | head -1 | awk '{print $NF}' || echo unknown)"
        else
          _canonical_v="unknown"
        fi
        if [ -n "${_canonical_v}" ] && [ "${_canonical_v}" != "unknown" ] && [ "${_post_running}" != "${_canonical_v}" ]; then
          echo "" >&2
          echo "[${PROG}] !!! UPDATE INCOMPLETE — your \`lattice\` still resolves to ${_post_running}" >&2
          echo "[${PROG}] !!! but the canonical install at ${_canonical} is now ${_canonical_v}" >&2
          echo "[${PROG}] !!! your shim points elsewhere — likely $(command -v lattice 2>/dev/null)" >&2
          echo "[${PROG}] !!! Fix: re-run install.sh, OR repoint manually:" >&2
          echo "[${PROG}] !!!   ln -sfn ${_canonical} \"$(command -v lattice 2>/dev/null)\"" >&2
          return 2
        fi
        if [ -n "${_pre_running}" ] && [ "${_pre_running}" = "${_post_running}" ] && [ "${_pre_running}" != "${_canonical_v}" ]; then
          echo "" >&2
          echo "[${PROG}] !!! update.sh wrote to disk but your running version is unchanged (${_post_running})" >&2
          echo "[${PROG}] !!! this means your shim points at a copy update.sh didn't touch" >&2
          return 2
        fi
        echo "[${PROG}] update: verified — \`lattice version\` reports ${_post_running}"
      fi
      ;;
    --enable-auto)
      cmd_config init >/dev/null
      awk '
        BEGIN { in_updates=0; done=0 }
        /^updates:[[:space:]]*$/ { print; in_updates=1; next }
        in_updates && /^[^[:space:]][^:]*:/ {
          if (!done) { print "  mode: auto"; done=1 }
          in_updates=0
        }
        in_updates && /^[[:space:]]+mode:/ { if (!done) { print "  mode: auto"; done=1 } ; next }
        { print }
        END { if (in_updates && !done) print "  mode: auto" }
      ' .lattice/config.yml > .lattice/config.yml.tmp && mv .lattice/config.yml.tmp .lattice/config.yml
      echo "[${PROG}] updates.mode=auto"
      ;;
    --disable-auto)
      cmd_config init >/dev/null
      awk '
        BEGIN { in_updates=0; done=0 }
        /^updates:[[:space:]]*$/ { print; in_updates=1; next }
        in_updates && /^[^[:space:]][^:]*:/ {
          if (!done) { print "  mode: notify"; done=1 }
          in_updates=0
        }
        in_updates && /^[[:space:]]+mode:/ { if (!done) { print "  mode: notify"; done=1 } ; next }
        { print }
        END { if (in_updates && !done) print "  mode: notify" }
      ' .lattice/config.yml > .lattice/config.yml.tmp && mv .lattice/config.yml.tmp .lattice/config.yml
      echo "[${PROG}] updates.mode=notify"
      ;;
    *) die "update: usage: lattice update --check|--self|--enable-auto|--disable-auto" ;;
  esac
}

# ---------------------------------------------------------------------------
# config — project-local Lattice config.
# ---------------------------------------------------------------------------
cmd_config() {
  local action="${1:-}"
  case "${action}" in
    init)
      mkdir -p .lattice
      if [ -f .lattice/config.yml ]; then
        echo "[${PROG}] config exists: .lattice/config.yml"
        return 0
      fi
      cat > .lattice/config.yml <<'YML'
# v0.9+ — operating mode (classic | substrate | hybrid). See docs/v1.0-substrate-spec.md.
#   classic   : v0.8.x behavior. Findings + CLAUDE.md sync only.
#   substrate : full v1.0. Invariants + drift bounds + traces + ADRs + MCP.
#   hybrid    : findings + ADRs + MCP, no invariant derivation.
mode: classic

usage:
  enabled: true

updates:
  # notify | auto | pinned | off
  mode: notify
  channel: stable
  check_interval_hours: 24
  pinned_version:

security:
  # v2.2: the `cmd:` measurement.source scheme runs arbitrary shell on
  # `lattice grow measure`. Default deny. Flip to true ONLY if you understand
  # that any hypothesis YAML with `source: cmd:rm -rf ~` will execute on cron.
  allow_cmd_sources: false
YML
      echo "[${PROG}] wrote .lattice/config.yml"
      ;;
    show)
      if [ -f .lattice/config.yml ]; then
        cat .lattice/config.yml
      else
        echo "[${PROG}] no .lattice/config.yml (defaults: usage.enabled=true, updates.mode=notify, telemetry=off)"
      fi
      ;;
    telemetry)
      local action="${2:-show}"
      local scope="project"
      # Look for --global anywhere in remaining args
      local a
      for a in "$@"; do
        [ "${a}" = "--global" ] && scope="global"
      done
      case "${action}" in
        on|off)
          local cfg
          if [ "${scope}" = "global" ]; then
            mkdir -p "${HOME}/.claude/lattice" 2>/dev/null || true
            cfg="${HOME}/.claude/lattice/config.yml"
          else
            ensure_project_dirs
            cfg=".lattice/config.yml"
          fi
          local tmp; tmp="$(mktemp)"
          if [ -f "${cfg}" ]; then
            grep -v '^telemetry:' "${cfg}" > "${tmp}" || true
          fi
          printf "telemetry: %s\n" "${action}" >> "${tmp}"
          mv "${tmp}" "${cfg}"
          echo "[${PROG}] telemetry: ${action} (${scope}) — wrote ${cfg}"
          ;;
        show|"")
          local proj_state="unset" global_state="unset" env_state=""
          if [ -f .lattice/config.yml ]; then
            grep -qE '^telemetry:[[:space:]]*off' .lattice/config.yml 2>/dev/null && proj_state="off"
            grep -qE '^telemetry:[[:space:]]*on'  .lattice/config.yml 2>/dev/null && proj_state="on"
          fi
          if [ -f "${HOME}/.claude/lattice/config.yml" ]; then
            grep -qE '^telemetry:[[:space:]]*off' "${HOME}/.claude/lattice/config.yml" 2>/dev/null && global_state="off"
            grep -qE '^telemetry:[[:space:]]*on'  "${HOME}/.claude/lattice/config.yml" 2>/dev/null && global_state="on"
          fi
          case "${LATTICE_TELEMETRY:-}" in
            0) env_state=" (overridden OFF by LATTICE_TELEMETRY=0)" ;;
            1) env_state=" (overridden ON by LATTICE_TELEMETRY=1)" ;;
          esac
          echo "[${PROG}] telemetry status (default: OFF — opt-in):"
          echo "  project (.lattice/config.yml): ${proj_state}"
          echo "  global  (~/.claude/lattice/config.yml): ${global_state}"
          if _telemetry_enabled; then
            echo "  effective: ON${env_state}"
          else
            echo "  effective: OFF${env_state}"
          fi
          echo "  endpoint: ${_LATTICE_TELEMETRY_URL}"
          ;;
        *) die "config telemetry: usage: lattice config telemetry on|off|show [--global]" ;;
      esac
      ;;
    *) die "config: usage: lattice config init|show|telemetry <on|off|show> [--global]" ;;
  esac
}

# ---------------------------------------------------------------------------
# doctor — diagnose Lattice setup in the current repo. First-run UX.
# Output: PASS / WARN / FAIL per check, with fix hints.
# Exit code: 0 if no FAIL, 1 if any FAIL.
# ---------------------------------------------------------------------------
cmd_doctor() {
  local fails=0 warns=0 passes=0 infos=0
  local check_name fix_hint
  _check_pass() { printf "  [PASS] %s\n" "$1"; passes=$((passes+1)); }
  _check_warn() { printf "  [WARN] %s — %s\n" "$1" "$2"; warns=$((warns+1)); }
  _check_fail() { printf "  [FAIL] %s — %s\n" "$1" "$2"; fails=$((fails+1)); }
  # v1.0.2: distinguish "first-run, will heal itself" notices from real WARNs
  # so a fresh install doesn't look like a wall of failures.
  _check_info() { printf "  [INFO] %s — %s\n" "$1" "$2"; infos=$((infos+1)); }

  echo "[${PROG}] doctor: diagnosing Lattice setup in $(pwd)"
  # First-run detection — used to downgrade specific WARNs to INFOs.
  local _is_first_run=0
  if [ ! -f .lattice/cache/update-check.env ] && [ ! -f .lattice/config.yml ]; then
    _is_first_run=1
    echo "  (first-run state detected — [INFO] lines below are expected and will heal on first use)"
  fi
  echo ""

  echo "## Environment"
  if command -v git >/dev/null 2>&1; then
    _check_pass "git available"
  else
    _check_fail "git not found" "install git — required for close --commit and lifecycle stamping"
  fi
  if command -v node >/dev/null 2>&1; then
    _check_pass "node available (used by lattice-regenerate.sh)"
  else
    _check_fail "node not found" "install node ≥18 — required for lattice sync"
  fi
  if git rev-parse --git-dir >/dev/null 2>&1; then
    _check_pass "inside a git repo"
  else
    _check_warn "not in a git repo" "lattice close --commit will require explicit SHA arg outside git"
  fi
  # PATH discoverability (#14, #37) — false-green guard. The whole "autonomous
  # Claude loop" pitch breaks if `lattice` isn't reachable from a fresh shell.
  local found_path=""
  if command -v lattice >/dev/null 2>&1; then
    found_path="$(command -v lattice 2>/dev/null || true)"
  fi
  if [ -n "${found_path}" ]; then
    _check_pass "lattice in PATH (${found_path})"

    # v2.1.3 (#71): version-based drift detection. Previous (v1.4.1) approach
    # inspected the shim file shape (readlink for symlinks, grep for bash
    # `exec` wrappers) — missed LITERAL COPY shims entirely. New approach:
    # invoke `lattice version` through the shim, compare against canonical.
    # Catches ALL drift forms (symlink, wrapper, literal copy, alias, whatever)
    # because we're comparing output, not file structure.
    local canonical="${HOME}/.claude/lattice/scripts/lattice"
    local self_path
    self_path="$(realpath "${BASH_SOURCE[0]:-$0}" 2>/dev/null || echo "${BASH_SOURCE[0]:-$0}")"

    # Version reported when the user types `lattice version` from a fresh shell.
    # This is what actually executes for them — invoke the shim as the OS would.
    local shim_version
    shim_version="$(bash "${found_path}" version 2>/dev/null | head -1 | awk '{print $NF}' || echo unknown)"

    local canonical_version=""
    if [ -f "${canonical}" ]; then
      canonical_version="$(bash "${canonical}" version 2>/dev/null | head -1 | awk '{print $NF}' || echo unknown)"
    fi
    local self_version="$(current_version 2>/dev/null || echo unknown)"

    # Drift case 1: shim version != canonical version (the silent-update bug)
    if [ -n "${canonical_version}" ] && [ "${canonical_version}" != "unknown" ] \
        && [ "${shim_version}" != "${canonical_version}" ]; then
      _check_fail "shim drift: running=${shim_version} but canonical=${canonical_version}" "your \`lattice\` shim at ${found_path} runs ${shim_version}; \`~/.claude/lattice/scripts/lattice\` is at ${canonical_version}. \`lattice update --self\` touched the canonical install but not your shim. Fix: replace the shim with a wrapper pointing at the canonical install: cat > \"${found_path}\" <<<\"#!/usr/bin/env bash\\nexec bash ${canonical} \\\"\\\$@\\\"\" && chmod +x \"${found_path}\""
    elif [ -n "${canonical_version}" ] && [ "${canonical_version}" != "unknown" ]; then
      _check_pass "shim version ${shim_version} matches canonical install"
    else
      _check_pass "shim resolves and reports version ${shim_version} (no canonical install to compare)"
    fi

    # Drift case 2: shim version != the script running THIS doctor invocation
    if [ "${shim_version}" != "${self_version}" ] && [ "${shim_version}" != "unknown" ]; then
      _check_warn "doctor running from different lattice than the shim" "this doctor: ${self_version} (${self_path}); shim invokes: ${shim_version}. The user's \`lattice doctor\` sees the shim's view; this run sees the dev/canonical view. Run plain \`lattice doctor\` (not via full path) to see what users actually get."
    fi
  else
    # Walk personal-bin candidates and report which are on PATH so the user
    # can see exactly where to install the shim.
    local on_path_dirs="" candidate
    for candidate in "${HOME}/bin" "${HOME}/.local/bin" "${HOME}/.local/lattice/bin"; do
      case ":${PATH}:" in
        *":${candidate}:"*) on_path_dirs="${on_path_dirs}${candidate} " ;;
      esac
    done
    if [ -n "${on_path_dirs}" ]; then
      _check_warn "lattice not in PATH" "shim candidates on PATH: ${on_path_dirs}— re-run install.sh, or manually: ln -sf $(realpath "$0" 2>/dev/null || echo "$0") ${on_path_dirs%% *}/lattice"
    else
      _check_warn "lattice not in PATH; no personal-bin dir on PATH" "add to your shell rc: export PATH=\"\$HOME/.local/bin:\$PATH\"  (then re-run install.sh)"
    fi
  fi
  # v1.0.1 (#46): on Windows, also verify the .cmd wrapper + Windows PATH so
  # PowerShell users get a clear signal. Skip silently on non-Windows.
  case "$(uname -s 2>/dev/null)" in
    MINGW*|MSYS*|CYGWIN*)
      local cmd_found="" cmd_dir cmd_path
      for candidate in "${HOME}/bin" "${HOME}/.local/bin" "${HOME}/.local/lattice/bin"; do
        if [ -f "${candidate}/lattice.cmd" ]; then
          cmd_found="${candidate}/lattice.cmd"; cmd_dir="${candidate}"; break
        fi
      done
      if [ -z "${cmd_found}" ]; then
        _check_warn "no lattice.cmd wrapper found (PowerShell will fail)" "re-run install.sh to drop the Windows .cmd shim (#46)"
      else
        _check_pass "lattice.cmd wrapper present (${cmd_found})"
        # Check Windows User PATH
        local win_dir win_path
        win_dir="$(cygpath -w "${cmd_dir}" 2>/dev/null || echo "${cmd_dir}")"
        win_path="$(powershell.exe -NoProfile -Command "[Environment]::GetEnvironmentVariable('Path', 'User')" 2>/dev/null | tr -d '\r' || true)"
        case ";${win_path};" in
          *";${win_dir};"*|*";${win_dir}\\;"*)
            _check_pass "${win_dir} on Windows User PATH — lattice resolves in PowerShell"
            ;;
          *)
            _check_warn "${win_dir} NOT on Windows User PATH (PowerShell can't find lattice)" "run in PowerShell: [Environment]::SetEnvironmentVariable('Path', \$env:Path + ';${win_dir}', 'User') — then open a NEW PowerShell window"
            ;;
        esac
      fi
      ;;
  esac
  echo ""

  echo "## .lattice/ tree"
  if [ -d ".lattice" ]; then
    _check_pass ".lattice/ directory exists"
  else
    mkdir -p .lattice/findings/open .lattice/findings/closed 2>/dev/null || true
    if [ -d ".lattice/findings/open" ] && [ -d ".lattice/findings/closed" ]; then
      _check_warn ".lattice/ tree auto-created on first run" "created .lattice/findings/{open,closed}"
    else
      _check_fail ".lattice/ missing and could not auto-create" "check write permissions in $(pwd); or run: mkdir -p .lattice/findings/open .lattice/findings/closed"
      echo ""
      echo "  doctor: bailing — nothing else to check without .lattice/"
      return 1
    fi
  fi
  for sub in findings/open findings/closed; do
    if [ -d ".lattice/${sub}" ]; then
      _check_pass ".lattice/${sub}/ exists"
    else
      mkdir -p ".lattice/${sub}" 2>/dev/null || true
      if [ -d ".lattice/${sub}" ]; then
        _check_warn ".lattice/${sub}/ auto-created" "subtree was missing — bootstrapped"
      else
        _check_warn ".lattice/${sub}/ missing" "will be auto-created on first close/sync"
      fi
    fi
  done
  if [ -f ".lattice/config.yml" ]; then
    _check_pass ".lattice/config.yml present"
  elif [ "${_is_first_run}" -eq 1 ]; then
    _check_info ".lattice/config.yml not initialized" "will be created on first \`lattice config init\` or \`lattice sync\`"
  else
    _check_warn ".lattice/config.yml not initialized" "run: lattice config init  (enables usage tracking + update check tuning)"
  fi
  echo ""

  echo "## CLAUDE.md integration"
  if [ -f "CLAUDE.md" ]; then
    if grep -q "lattice:checklist:start" CLAUDE.md && grep -q "lattice:checklist:end" CLAUDE.md; then
      _check_pass "CLAUDE.md has lattice markers"
    else
      _check_warn "CLAUDE.md exists but no lattice markers" "run: lattice sync  (will append markers at end)"
    fi
  elif [ "${_is_first_run}" -eq 1 ]; then
    _check_info "CLAUDE.md not yet created" "auto-created on first \`lattice sync\`"
  else
    _check_warn "CLAUDE.md missing" "lattice sync will create one on first run"
  fi
  echo ""

  echo "## Open findings"
  shopt -s nullglob
  local open_count=0 malformed=0
  for f in .lattice/findings/open/*.yml .lattice/findings/open/*/*.yml; do
    [ -f "${f}" ] || continue
    open_count=$((open_count + 1))
    # Cheap parse check — required fields
    if ! grep -qE '^rule[[:space:]]*:' "${f}"; then malformed=$((malformed+1)); fi
  done
  if [ ${open_count} -eq 0 ]; then
    _check_pass "no open findings (clean slate)"
  elif [ ${malformed} -gt 0 ]; then
    _check_fail "${open_count} open findings, ${malformed} malformed" "run: lattice validate  (shows per-file errors)"
  else
    _check_pass "${open_count} open findings parse cleanly"
  fi
  echo ""

  echo "## Version + updates"
  local cur lat
  cur="$(current_version 2>/dev/null || echo unknown)"
  _check_pass "running ${PROG} ${cur}"
  if [ -f .lattice/cache/update-check.env ]; then
    local cache_age=0
    cache_age=$(($(date +%s) - $(stat -c %Y .lattice/cache/update-check.env 2>/dev/null || stat -f %m .lattice/cache/update-check.env 2>/dev/null || echo 0)))
    if [ ${cache_age} -lt 86400 ]; then
      _check_pass "update-check cache fresh (< 24h)"
    else
      _check_info "update-check cache stale" "next lattice invocation refreshes it (no action needed)"
    fi
  elif [ "${_is_first_run}" -eq 1 ]; then
    _check_info "no update-check cache" "created on next \`lattice ...\` invocation"
  else
    _check_warn "no update-check cache" "first run — will be created next invocation"
  fi
  echo ""

  echo "## Summary"
  if [ ${infos} -gt 0 ]; then
    echo "  ${passes} passed, ${warns} warnings, ${fails} failures, ${infos} first-run notices"
  else
    echo "  ${passes} passed, ${warns} warnings, ${fails} failures"
  fi
  if [ ${fails} -gt 0 ]; then
    echo "  doctor: setup has issues — see [FAIL] lines above"
    return 1
  fi
  if [ ${warns} -gt 0 ]; then
    echo "  doctor: setup is functional — see [WARN] lines for optional improvements"
  elif [ ${infos} -gt 0 ]; then
    echo "  doctor: setup is clean (first-run notices are expected, ignore them)"
  else
    echo "  doctor: setup is clean"
  fi
  return 0
}

# ---------------------------------------------------------------------------
# export — render findings as stakeholder-readable markdown.
# Usage:
#   lattice export --format markdown [--tier T] [--dimension D] [--module M] [--closed]
# Output: markdown table-grouped by tier, suitable for sharing with non-CLI users.
# ---------------------------------------------------------------------------
cmd_export() {
  local format="markdown"
  local filter_tier="" filter_dim="" filter_module="" include_closed=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --format)    [ -z "${2:-}" ] && die "export: --format requires a value"
                   format="$2"; shift 2 ;;
      --tier)      [ -z "${2:-}" ] && die "export: --tier requires a value"
                   filter_tier="${2^^}"; shift 2 ;;
      --dimension) [ -z "${2:-}" ] && die "export: --dimension requires a value"
                   filter_dim="${2,,}"; shift 2 ;;
      --module)    [ -z "${2:-}" ] && die "export: --module requires a value"
                   filter_module="$2"; shift 2 ;;
      --closed)    include_closed=1; shift ;;
      *) die "export: unknown arg: $1" ;;
    esac
  done

  case "${format}" in
    markdown|md) ;;
    *) die "export: unsupported format '${format}' (supported: markdown)" ;;
  esac

  [ -d ".lattice/findings/open" ] || { echo "[${PROG}] export: no findings directory"; return 0; }

  shopt -s nullglob
  local items=()
  for f in .lattice/findings/open/*.yml .lattice/findings/open/*/*.yml; do
    [ -f "${f}" ] || continue
    items+=("open|${f}")
  done
  if [ ${include_closed} -eq 1 ]; then
    for f in .lattice/findings/closed/*.yml .lattice/findings/closed/*/*.yml; do
      [ -f "${f}" ] || continue
      items+=("closed|${f}")
    done
  fi

  if [ ${#items[@]} -eq 0 ]; then
    echo "_No findings to export._"
    return 0
  fi

  # Tier ordering for grouping
  local tier_order="CRITICAL BLOCKER HIGH RISK DRIFT MEDIUM WATCH LOW INTENTIONAL UNVERIFIABLE OK"

  # Header
  echo "# Findings export"
  echo ""
  echo "Generated: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
  local filter_summary=""
  [ -n "${filter_tier}" ]    && filter_summary="${filter_summary} tier=${filter_tier}"
  [ -n "${filter_dim}" ]     && filter_summary="${filter_summary} dimension=${filter_dim}"
  [ -n "${filter_module}" ]  && filter_summary="${filter_summary} module=${filter_module}"
  [ ${include_closed} -eq 1 ] && filter_summary="${filter_summary} include=closed"
  if [ -n "${filter_summary}" ]; then
    echo "Filters:${filter_summary}"
  fi
  echo ""

  local total=0
  for tier in ${tier_order}; do
    local tier_items=()
    for entry in "${items[@]}"; do
      local state="${entry%%|*}" f="${entry#*|}"
      local t m d mod
      t="$(yaml_field "${f}" "tier" | tr '[:lower:]' '[:upper:]')"
      [ "${t}" = "${tier}" ] || continue
      [ -n "${filter_tier}" ] && [ "${t}" != "${filter_tier}" ] && continue
      d="$(yaml_field "${f}" "dimension" | tr '[:upper:]' '[:lower:]')"
      [ -n "${filter_dim}" ] && [ "${d}" != "${filter_dim}" ] && continue
      mod="$(yaml_field "${f}" "module")"
      if [ -n "${filter_module}" ]; then
        [[ "${mod,,}" == *"${filter_module,,}"* ]] || continue
      fi
      tier_items+=("${state}|${f}")
    done
    [ ${#tier_items[@]} -eq 0 ] && continue

    echo "## ${tier} (${#tier_items[@]})"
    echo ""
    echo "| State | Module | Rule | Where | Title |"
    echo "|-------|--------|------|-------|-------|"
    for entry in "${tier_items[@]}"; do
      local state="${entry%%|*}" f="${entry#*|}"
      local mod rule file line title
      mod="$(yaml_field "${f}" "module")"
      rule="$(yaml_field "${f}" "rule")"
      file="$(yaml_field "${f}" "file")"
      line="$(yaml_field "${f}" "line")"
      title="$(yaml_field "${f}" "title")"
      # Escape pipes in fields to avoid breaking the table
      title="${title//|/\\|}"
      mod="${mod//|/\\|}"
      rule="${rule//|/\\|}"
      printf "| %s | %s | %s | %s:%s | %s |\n" "${state}" "${mod}" "${rule}" "${file}" "${line}" "${title}"
      total=$((total + 1))
    done
    echo ""
  done

  echo "_Total: ${total} finding(s)._"
}

# ---------------------------------------------------------------------------
# changelog — render closed findings as release-note markdown.
# Usage:
#   lattice changelog --since <YYYY-MM-DD> [--until <YYYY-MM-DD>] [--tier T] [--module M]
# Output: markdown grouped by close_reason (fixed first), then tier.
# Skips findings without closed_at or with closed_at outside the window.
# ---------------------------------------------------------------------------
cmd_changelog() {
  local since="" until="" filter_tier="" filter_module=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --since)   [ -z "${2:-}" ] && die "changelog: --since requires YYYY-MM-DD"
                 since="$2"; shift 2 ;;
      --until)   [ -z "${2:-}" ] && die "changelog: --until requires YYYY-MM-DD"
                 until="$2"; shift 2 ;;
      --tier)    [ -z "${2:-}" ] && die "changelog: --tier requires a value"
                 filter_tier="${2^^}"; shift 2 ;;
      --module)  [ -z "${2:-}" ] && die "changelog: --module requires a value"
                 filter_module="$2"; shift 2 ;;
      *) die "changelog: unknown arg: $1" ;;
    esac
  done

  [ -z "${since}" ] && die "changelog: --since is required (format: YYYY-MM-DD)"
  [[ "${since}" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]] || die "changelog: --since must be YYYY-MM-DD"
  if [ -n "${until}" ]; then
    [[ "${until}" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]] || die "changelog: --until must be YYYY-MM-DD"
  fi

  [ -d ".lattice/findings/closed" ] || { echo "_No closed findings._"; return 0; }

  shopt -s nullglob
  # Collect: "reason|tier|module|rule|file|line|title|closed_by_commit|closed_at|path"
  local rows=()
  for f in .lattice/findings/closed/*.yml .lattice/findings/closed/*/*.yml; do
    [ -f "${f}" ] || continue
    local closed_at reason tier module rule file line title commit
    closed_at="$(yaml_field "${f}" "closed_at")"
    [ -z "${closed_at}" ] && continue
    local closed_date="${closed_at%%T*}"
    [[ "${closed_date}" < "${since}" ]] && continue
    if [ -n "${until}" ]; then
      [[ "${closed_date}" > "${until}" ]] && continue
    fi
    reason="$(yaml_field "${f}" "close_reason")"
    [ -z "${reason}" ] && reason="fixed"
    tier="$(yaml_field "${f}" "tier")"
    module="$(yaml_field "${f}" "module")"
    rule="$(yaml_field "${f}" "rule")"
    file="$(yaml_field "${f}" "file")"
    line="$(yaml_field "${f}" "line")"
    title="$(yaml_field "${f}" "title")"
    commit="$(yaml_field "${f}" "closed_by_commit")"

    [ -n "${filter_tier}" ] && [ "${tier^^}" != "${filter_tier}" ] && continue
    if [ -n "${filter_module}" ]; then
      [[ "${module,,}" == *"${filter_module,,}"* ]] || continue
    fi

    rows+=("${reason}|${tier}|${module}|${rule}|${file}|${line}|${title}|${commit}|${closed_at}")
  done

  if [ ${#rows[@]} -eq 0 ]; then
    echo "# Changelog (since ${since}${until:+ until ${until}})"
    echo ""
    echo "_No findings closed in the given window._"
    return 0
  fi

  echo "# Changelog"
  echo ""
  if [ -n "${until}" ]; then
    echo "Closed findings between **${since}** and **${until}** (${#rows[@]} total)."
  else
    echo "Closed findings since **${since}** (${#rows[@]} total)."
  fi
  echo ""

  # Order: fixed → false-positive → wont-fix → out-of-scope → duplicate
  local reason_order="fixed false-positive wont-fix out-of-scope duplicate"
  local tier_order="CRITICAL BLOCKER HIGH RISK DRIFT MEDIUM WATCH LOW INTENTIONAL UNVERIFIABLE OK"

  for r in ${reason_order}; do
    local reason_rows=()
    for row in "${rows[@]}"; do
      [ "${row%%|*}" = "${r}" ] && reason_rows+=("${row}")
    done
    [ ${#reason_rows[@]} -eq 0 ] && continue

    local pretty_reason="${r}"
    case "${r}" in
      fixed)          pretty_reason="Fixed" ;;
      false-positive) pretty_reason="False positives" ;;
      wont-fix)       pretty_reason="Won't fix" ;;
      out-of-scope)   pretty_reason="Out of scope" ;;
      duplicate)      pretty_reason="Duplicates" ;;
    esac
    echo "## ${pretty_reason} (${#reason_rows[@]})"
    echo ""

    for t in ${tier_order}; do
      local printed=0
      for row in "${reason_rows[@]}"; do
        IFS='|' read -r _r row_tier row_module row_rule row_file row_line row_title row_commit row_closed_at <<< "${row}"
        [ "${row_tier^^}" = "${t}" ] || continue
        if [ ${printed} -eq 0 ]; then
          echo "### ${t}"
          printed=1
        fi
        local where="${row_file}:${row_line}"
        local commit_ref=""
        [ -n "${row_commit}" ] && commit_ref=" (\`${row_commit}\`)"
        printf -- "- **%s** / \`%s\` — %s%s\n" "${row_module}" "${row_rule}" "${row_title:-${where}}" "${commit_ref}"
      done
      [ ${printed} -eq 1 ] && echo ""
    done
  done
}

# ---------------------------------------------------------------------------
# resolve-pending — replace __PENDING__ placeholders with current HEAD short SHA.
# Used after `lattice close --pending` followed by the fix commit. Scans all
# closed YAMLs and rewrites in place.
# Usage:
#   lattice resolve-pending [--commit <sha>]    # default: HEAD
# Exit: 0 if any changes (or none to do); 1 on git failure.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# test-fixture — emit a valid finding YAML for tests + dogfood scaffolding.
#
# Cuts the 12-line `cat > .lattice/findings/open/...yml <<YML` boilerplate
# that every new test in scripts/test-lifecycle.sh used to need.
#
# Usage:
#   lattice test-fixture <slug> [--tier T] [--dimension D] [--module M]
#                               [--file F] [--line N] [--title TXT]
#                               [--exposure E] [--verify-pattern PAT]
#                               [--out PATH] [--force]
#   Defaults: tier=MEDIUM dim=audit module=mod file=src/x.ts line=1
#             title=<slug> id=<slug>-id
#   Output: .lattice/findings/open/<TIER>-<slug>.yml  (or --out PATH)
# ---------------------------------------------------------------------------
cmd_test_fixture() {
  local slug=""
  local tier="MEDIUM" dim="audit" module="mod"
  local file="src/x.ts" line="1" title=""
  local exposure="" verify_pattern=""
  local out_path="" force=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --tier)            tier="$2"; shift 2 ;;
      --dimension)       dim="$2"; shift 2 ;;
      --module)          module="$2"; shift 2 ;;
      --file)            file="$2"; shift 2 ;;
      --line)            line="$2"; shift 2 ;;
      --title)           title="$2"; shift 2 ;;
      --exposure)        exposure="$2"; shift 2 ;;
      --verify-pattern)  verify_pattern="$2"; shift 2 ;;
      --out)             out_path="$2"; shift 2 ;;
      --force)           force=1; shift ;;
      -*)                die "test-fixture: unknown flag: $1" ;;
      *)                 [ -z "${slug}" ] && slug="$1" || die "test-fixture: extra arg: $1"; shift ;;
    esac
  done
  [ -z "${slug}" ] && die "test-fixture: usage: lattice test-fixture <slug> [--tier T] [--exposure E] [--verify-pattern P] [--out PATH]"
  [ -z "${title}" ] && title="${slug}"

  ensure_project_dirs

  local target="${out_path}"
  if [ -z "${target}" ]; then
    target=".lattice/findings/open/${tier}-${slug}.yml"
  fi
  if [ -f "${target}" ] && [ "${force}" -ne 1 ]; then
    die "test-fixture: ${target} already exists (use --force to overwrite)"
  fi
  mkdir -p "$(dirname "${target}")" 2>/dev/null || true

  local today
  today="$(date -u +%Y-%m-%d 2>/dev/null || echo 2026-05-14)"

  {
    printf 'id: %s-id\n' "${slug}"
    printf 'rule: %s\n' "${slug}"
    printf 'dimension: %s\n' "${dim}"
    printf 'tier: %s\n' "${tier}"
    printf 'module: %s\n' "${module}"
    printf 'file: %s\n' "${file}"
    printf 'line: %s\n' "${line}"
    printf 'title: %s\n' "${title}"
    printf 'fix: fix it\n'
    printf 'sweep_date: %s\n' "${today}"
    printf 'sweep_id: sw1\n'
    printf 'auditor: claude-code/audit\n'
    printf 'status: open\n'
    [ -n "${exposure}" ]       && printf 'exposure: %s\n' "${exposure}"
    [ -n "${verify_pattern}" ] && printf "verify_pattern: '%s'\n" "${verify_pattern//\'/\\\'}"
  } > "${target}"
  echo "${target}"
}

# ---------------------------------------------------------------------------
# mode — read or set the operating mode (classic | substrate | hybrid).
# See docs/v1.0-substrate-spec.md.
# ---------------------------------------------------------------------------
cmd_mode() {
  local target="${1:-}"
  if [ -z "${target}" ]; then
    if [ -f .lattice/config.yml ] && grep -qE '^mode:' .lattice/config.yml 2>/dev/null; then
      grep -E '^mode:' .lattice/config.yml | head -1 | awk '{print $2}'
    else
      echo "classic"
    fi
    return 0
  fi
  case "${target}" in
    classic|substrate|hybrid) ;;
    *) die "mode: must be one of: classic | substrate | hybrid" ;;
  esac
  ensure_project_dirs
  local cfg=".lattice/config.yml"
  local tmp; tmp="$(mktemp)"
  if [ -f "${cfg}" ]; then
    grep -v '^mode:' "${cfg}" > "${tmp}" || true
  fi
  {
    printf "mode: %s\n" "${target}"
    cat "${tmp}" 2>/dev/null || true
  } > "${cfg}.new"
  mv "${cfg}.new" "${cfg}"
  rm -f "${tmp}"
  echo "[${PROG}] mode: ${target} — wrote ${cfg}"
}

# ---------------------------------------------------------------------------
# decide — create or amend an ADR YAML in .lattice/decisions/.
# v0.9+. See docs/v1.0-substrate-spec.md for the schema.
#
# Usage:
#   lattice decide <slug> --title "<title>" --because "<rationale>"
#                         [--status in_progress|active|superseded|reversed]
#                         [--supersedes <prior-id>]
#                         [--reverses <prior-id>]
#                         [--cite <path>[:lines]]   (may repeat)
#                         [--relates-to <finding-slug>]  (may repeat)
# ---------------------------------------------------------------------------
cmd_decide() {
  local slug="" title="" because="" because_file=""
  local status="active"
  local supersedes="" reverses=""
  local cites=() relates=()
  # v0.9.5 (#27): real ADRs need paragraph-level rationale, not one-liners.
  # Now supports:
  #   --because "single-line text"            (existing)
  #   --because -                             (read from stdin / here-doc)
  #   --because-file path/to/rationale.md     (read from a file)
  # All three feed the same `because:` block. Multi-line content is emitted
  # as a YAML block scalar (`because: |`) so the YAML stays parseable.
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --title)        title="$2"; shift 2 ;;
      --because)      because="$2"; shift 2 ;;
      --because-file) because_file="$2"; shift 2 ;;
      --status)       status="$2"; shift 2 ;;
      --supersedes)   supersedes="$2"; shift 2 ;;
      --reverses)     reverses="$2"; shift 2 ;;
      --cite)         cites+=("$2"); shift 2 ;;
      --relates-to)   relates+=("$2"); shift 2 ;;
      -*)             die "decide: unknown flag: $1" ;;
      *)              [ -z "${slug}" ] && slug="$1" || die "decide: extra arg: $1"; shift ;;
    esac
  done
  [ -z "${slug}" ] && die "decide: usage: lattice decide <slug> --title \"...\" --because \"...\""
  [ -z "${title}" ] && die "decide: --title required"

  # Resolve --because-file first (overrides --because if both given).
  if [ -n "${because_file}" ]; then
    [ -f "${because_file}" ] || die "decide: --because-file not found: ${because_file}"
    because="$(cat "${because_file}")"
  elif [ "${because}" = "-" ]; then
    # Read from stdin (here-doc / pipe). Useful for multi-paragraph rationale.
    because="$(cat)"
  fi

  [ -z "${because}" ] && die "decide: --because required (the rationale) — pass text, '-' for stdin, or --because-file <path>"

  ensure_project_dirs
  mkdir -p .lattice/decisions

  # Auto-number: scan existing 0NNN- prefixes, pick next.
  shopt -s nullglob
  local next=1
  for f in .lattice/decisions/*.yml; do
    local n
    n="$(basename "${f}" | awk -F- '{print $1+0}')"
    [ "${n}" -ge "${next}" ] && next=$((n + 1))
  done
  local padded
  padded="$(printf '%04d' "${next}")"
  local dest=".lattice/decisions/${padded}-${slug}.yml"
  [ -f "${dest}" ] && die "decide: ${dest} already exists"

  local now
  now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  local today
  today="$(date -u +%Y-%m-%d)"
  local actor="${LATTICE_AGENT:-${USER:-unknown}}"

  {
    printf 'id: %s-%s\n' "${padded}" "${slug}"
    printf 'slug: %s\n' "${slug}"
    printf 'title: "%s"\n' "${title//\"/\\\"}"
    printf 'status: %s\n' "${status}"
    printf 'created_at: %s\n' "${now}"
    printf 'created_by: %s\n' "${actor}"
    # v0.9.5 (#27): multi-line rationale emitted as YAML block scalar (`|`)
    # so newlines survive. Single-line preserves the original quoted form so
    # diffs against older ADRs stay clean.
    if [[ "${because}" == *$'\n'* ]]; then
      printf 'because: |\n'
      printf '%s\n' "${because}" | sed 's/^/  /'
    else
      printf 'because: "%s"\n' "${because//\"/\\\"}"
    fi
    if [ "${status}" = "active" ]; then
      printf 'still_valid_as_of: %s\n' "${today}"
    fi
    [ -n "${supersedes}" ] && printf 'supersedes: %s\n' "${supersedes}"
    [ -n "${reverses}" ]   && printf 'reverses: %s\n' "${reverses}"
    if [ ${#cites[@]} -gt 0 ]; then
      printf 'cited_files:\n'
      for c in "${cites[@]}"; do
        local cpath clines
        cpath="${c%%:*}"
        clines="${c#*:}"
        [ "${cpath}" = "${clines}" ] && clines=""
        printf '  - path: %s\n' "${cpath}"
        [ -n "${clines}" ] && printf '    lines: %s\n' "${clines}"
      done
    fi
    if [ ${#relates[@]} -gt 0 ]; then
      printf 'relates_to:\n'
      for r in "${relates[@]}"; do
        printf '  - finding: %s\n' "${r}"
      done
    fi
  } > "${dest}"

  # If superseding, mark the prior ADR as superseded.
  if [ -n "${supersedes}" ]; then
    local prior
    prior="$(ls .lattice/decisions/${supersedes}*.yml 2>/dev/null | head -1)"
    if [ -n "${prior}" ] && [ -f "${prior}" ]; then
      local tmp; tmp="$(mktemp)"
      awk -v new="${padded}-${slug}" '
        /^status:/ { print "status: superseded"; next }
        /^superseded_by:/ { next }
        { print }
        END { print "superseded_by: " new }
      ' "${prior}" > "${tmp}" && mv "${tmp}" "${prior}"
      echo "[${PROG}] marked superseded: ${prior}"
    fi
  fi

  # v0.9.11: auto-refresh project CLAUDE.md block on new ADR.
  _lattice_project_sync_auto

  echo "${dest}"
}

# ---------------------------------------------------------------------------
# decisions — list ADRs, optionally filtered by status.
# Usage: lattice decisions list [--status active|in_progress|superseded|reversed]
# ---------------------------------------------------------------------------
cmd_decisions() {
  local action="${1:-list}"
  shift 2>/dev/null || true
  case "${action}" in
    list)
      local filter_status=""
      while [ "$#" -gt 0 ]; do
        case "$1" in
          --status) filter_status="$2"; shift 2 ;;
          -*) die "decisions: unknown flag: $1" ;;
          *) die "decisions: unexpected arg: $1" ;;
        esac
      done
      [ -d .lattice/decisions ] || { echo "[${PROG}] no .lattice/decisions/ in cwd"; return 0; }
      shopt -s nullglob
      local count=0
      for f in .lattice/decisions/*.yml; do
        local id title status
        id="$(yaml_field "${f}" "id")"
        title="$(yaml_field "${f}" "title")"
        status="$(yaml_field "${f}" "status")"
        [ -n "${filter_status}" ] && [ "${status}" != "${filter_status}" ] && continue
        printf "%-9s %-30s %s\n" "${status}" "${id}" "${title}"
        count=$((count + 1))
      done
      echo ""
      echo "[${PROG}] ${count} decision(s)"
      ;;
    show)
      local target="${1:-}"
      [ -z "${target}" ] && die "decisions show: usage: lattice decisions show <id-or-slug>"
      shopt -s nullglob
      for f in .lattice/decisions/*${target}*.yml; do
        echo "[${PROG}] ${f}"
        echo "----------------------------------------------------------------------"
        cat "${f}"
        return 0
      done
      die "decisions: not found: ${target}"
      ;;
    *)
      die "decisions: usage: lattice decisions list [--status S] | show <id>"
      ;;
  esac
}

# ---------------------------------------------------------------------------
# invariants — derive structural facts about the project from code (v0.9.1).
#
# First-pass grep-based derivation. Walks the working tree, detects tech
# stack (Flutter / Node / Supabase), extracts modules, contracts (HTTP
# routes, Edge Functions, DB tables), and emits a YAML to:
#   .lattice/invariants/HEAD.yml  (and a sha-tagged copy)
#
# Subcommands:
#   lattice invariants derive [--write|--print]   (default: --write)
#   lattice invariants show
#   lattice invariants diff                       (HEAD vs previous)
#
# Tree-sitter upgrade comes in v0.9.x as needed. This pass is intentionally
# coarse — covers ~80% of the cases that matter for Claude session-start.
# ---------------------------------------------------------------------------
cmd_invariants() {
  local action="${1:-derive}"
  shift 2>/dev/null || true
  case "${action}" in
    derive) _invariants_derive "$@" ;;
    show)   _invariants_show ;;
    diff)   _invariants_diff ;;
    regen)  _invariants_derive --write ;;
    check)  _invariants_diff ;;
    *)      die "invariants: usage: lattice invariants derive|show|diff" ;;
  esac
}

_invariants_derive() {
  local out_mode="write"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --print) out_mode="print"; shift ;;
      --write) out_mode="write"; shift ;;
      *) die "invariants derive: unknown flag: $1" ;;
    esac
  done

  ensure_project_dirs
  mkdir -p .lattice/invariants

  local commit
  commit="$(git rev-parse --short HEAD 2>/dev/null || echo "uncommitted")"
  local derived_at
  derived_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

  # Detect stack ----------------------------------------------------------
  local has_pubspec=0 has_pkgjson=0 has_supabase=0 has_flutter=0
  [ -f pubspec.yaml ] && { has_pubspec=1; grep -q '^[[:space:]]*flutter:' pubspec.yaml 2>/dev/null && has_flutter=1; }
  [ -f package.json ] && has_pkgjson=1
  [ -d supabase ] && [ -d supabase/migrations -o -d supabase/functions ] && has_supabase=1

  # Find module roots -----------------------------------------------------
  # Heuristic: top-level dirs under lib/ (Flutter) or src/ (Node) or
  # supabase/functions/* (Edge Functions).
  local modules=()
  if [ -d lib ]; then
    while IFS= read -r -d '' d; do
      modules+=("${d#./}")
    done < <(find lib -mindepth 1 -maxdepth 2 -type d -print0 2>/dev/null | head -z -n 50)
  fi
  if [ -d src ]; then
    while IFS= read -r -d '' d; do
      modules+=("${d#./}")
    done < <(find src -mindepth 1 -maxdepth 2 -type d -print0 2>/dev/null | head -z -n 50)
  fi
  if [ -d supabase/functions ]; then
    while IFS= read -r -d '' d; do
      modules+=("${d#./}")
    done < <(find supabase/functions -mindepth 1 -maxdepth 1 -type d -print0 2>/dev/null)
  fi

  # Contracts -------------------------------------------------------------
  # 1. Edge Functions (Supabase)
  local edge_fns=()
  if [ "${has_supabase}" = "1" ] && [ -d supabase/functions ]; then
    while IFS= read -r -d '' fn; do
      local name
      name="$(basename "${fn}")"
      [ "${name}" = "_shared" ] && continue
      edge_fns+=("${name}")
    done < <(find supabase/functions -mindepth 1 -maxdepth 1 -type d -print0 2>/dev/null)
  fi

  # 2. Express / Fastify routes (Node)
  local node_routes=()
  if [ "${has_pkgjson}" = "1" ]; then
    while IFS= read -r line; do
      [ -n "${line}" ] && node_routes+=("${line}")
    done < <(grep -RhEn "(app|router|fastify)\.(get|post|put|delete|patch)\(['\"]" \
              --include='*.js' --include='*.ts' \
              src/ routes/ 2>/dev/null \
              | sed -E 's/.*\.(get|post|put|delete|patch)\(['"'"'"]([^'"'"'"]+)['"'"'"].*/\1 \2/' \
              | sort -u | head -100)
  fi

  # 3. Frontend HTTP calls (Flutter) — emit `method` + `call_site: file:line`.
  # v0.9.4 (#22): rewrote parser. The v0.9.1-v0.9.3 version used `grep -RhEn` (with
  # `-h` suppressing the filename) and a sed that tried to strip `file:line` that
  # was never there, leaving `method:` holding the line number and `target:` holding
  # the entire source line with leading whitespace. New parser uses `grep -REn`
  # (filename + line), extracts via awk into stable `<verb>\t<file>:<line>` tuples,
  # and emits a properly structured YAML entry. Two calls on the same line number
  # across different files no longer collide.
  local fe_calls=()
  if [ "${has_flutter}" = "1" ] && [ -d lib ]; then
    while IFS= read -r line; do
      [ -n "${line}" ] && fe_calls+=("${line}")
    done < <(grep -REn "(_?dio|http|api)\.(get|post|put|delete|patch)\(" \
              --include='*.dart' lib/ 2>/dev/null \
              | awk -F: '
                  {
                    file=$1; lineno=$2;
                    # Re-join the rest in case the source line itself contained colons.
                    rest=$0; sub("^[^:]*:[^:]*:", "", rest);
                    if (match(rest, /\.(get|post|put|delete|patch)\(/)) {
                      verb=substr(rest, RSTART+1, RLENGTH-2);
                      printf("%s\t%s:%s\n", verb, file, lineno);
                    }
                  }
                ' \
              | sort -u | head -100)
  fi

  # 4. DB tables (Supabase migrations)
  local db_tables=()
  if [ "${has_supabase}" = "1" ] && [ -d supabase/migrations ]; then
    while IFS= read -r tbl; do
      [ -n "${tbl}" ] && db_tables+=("${tbl}")
    done < <(grep -REho '\bCREATE TABLE (IF NOT EXISTS )?[a-zA-Z_]+\.?[a-zA-Z_]*' \
              supabase/migrations/ 2>/dev/null \
              | sed -E 's/.*CREATE TABLE (IF NOT EXISTS )?//' \
              | sort -u | head -50)
  fi

  # Emit YAML -------------------------------------------------------------
  local tmp; tmp="$(mktemp)"
  {
    printf 'commit: %s\n' "${commit}"
    printf 'derived_at: %s\n' "${derived_at}"
    printf 'derived_by: lattice/invariants-engine@0.9.1\n'
    printf '\n# Stack detection (heuristic)\n'
    printf 'stack:\n'
    [ "${has_flutter}" = "1" ] && printf '  - flutter\n'
    [ "${has_pkgjson}" = "1" ] && printf '  - node\n'
    [ "${has_supabase}" = "1" ] && printf '  - supabase\n'
    [ "${has_flutter}${has_pkgjson}${has_supabase}" = "000" ] && printf '  - unknown\n'

    if [ ${#modules[@]} -gt 0 ]; then
      printf '\n# Modules (top-level dirs under lib/ / src/ / supabase/functions/)\n'
      printf 'modules:\n'
      for m in "${modules[@]}"; do
        printf '  - path: %s\n' "${m}"
      done
    fi

    if [ ${#edge_fns[@]} -gt 0 ]; then
      printf '\n# Supabase Edge Functions\n'
      printf 'edge_functions:\n'
      for fn in "${edge_fns[@]}"; do
        printf '  - %s\n' "${fn}"
      done
    fi

    if [ ${#node_routes[@]} -gt 0 ]; then
      printf '\n# Node HTTP routes (heuristic from app/router/fastify .verb())\n'
      printf 'routes:\n'
      for r in "${node_routes[@]}"; do
        local v p
        v="${r%% *}"; p="${r#* }"
        printf '  - method: %s\n    path: %s\n' "${v}" "${p}"
      done
    fi

    if [ ${#fe_calls[@]} -gt 0 ]; then
      printf '\n# Frontend HTTP calls (heuristic from dio/http/api .verb())\n'
      printf 'frontend_calls:\n'
      for c in "${fe_calls[@]}"; do
        # Tuple format (v0.9.4): "<VERB>\t<file>:<line>"
        local v site
        v="${c%%	*}"
        site="${c#*	}"
        printf '  - method: %s\n    call_site: %s\n' "${v^^}" "${site}"
      done
    fi

    if [ ${#db_tables[@]} -gt 0 ]; then
      printf '\n# Database tables (from supabase/migrations/*.sql)\n'
      printf 'db_tables:\n'
      for t in "${db_tables[@]}"; do
        printf '  - %s\n' "${t}"
      done
    fi
  } > "${tmp}"

  # v0.9.5 (#25): --print is now ADDITIVE (print AND persist) instead of
  # print-only. Before this fix, `derive --print` printed YAML to stdout but
  # never wrote .lattice/invariants/HEAD.yml — so the very next `lattice
  # context` reported "(none — run: lattice invariants derive)" in the same
  # session. Three subcommands had three different views of "do invariants
  # exist". Least-surprise: writing is the side effect of deriving; --print
  # just adds a stdout echo on top of it.
  if [ "${out_mode}" = "print" ]; then
    cat "${tmp}"
  fi

  # Write to .lattice/invariants/HEAD.yml + sha-tagged copy (always; --print
  # is additive in v0.9.5+).
  cp "${tmp}" ".lattice/invariants/HEAD.yml"
  cp "${tmp}" ".lattice/invariants/${commit}.yml"
  rm -f "${tmp}"
  if [ "${out_mode}" != "print" ]; then
    echo "[${PROG}] invariants derived: .lattice/invariants/HEAD.yml (commit ${commit})"
  fi
}

_invariants_show() {
  if [ -f .lattice/invariants/HEAD.yml ]; then
    cat .lattice/invariants/HEAD.yml
  else
    echo "[${PROG}] no invariants yet — run: lattice invariants derive"
    return 1
  fi
}

_invariants_diff() {
  if [ ! -f .lattice/invariants/HEAD.yml ]; then
    echo "[${PROG}] no baseline — run: lattice invariants derive"
    return 1
  fi
  # v0.9.5 (#25): --print now also persists, so we can't pipe `derive --print`
  # into a temp file without trashing the HEAD.yml baseline we want to diff
  # against. Snapshot the baseline first, then re-derive, then diff snapshot
  # vs the freshly-written HEAD.yml.
  local baseline; baseline="$(mktemp)"
  cp .lattice/invariants/HEAD.yml "${baseline}"
  local baseline_commit
  baseline_commit="$(grep -E '^commit:' "${baseline}" | awk '{print $2}')"

  _invariants_derive >/dev/null 2>&1
  local new_commit
  new_commit="$(grep -E '^commit:' .lattice/invariants/HEAD.yml | awk '{print $2}')"

  if [ "${baseline_commit}" = "${new_commit}" ]; then
    # Same commit → derivation is deterministic for fixed source, so diff
    # should be empty. Report fresh and bail.
    echo "[${PROG}] HEAD invariants are fresh (commit ${baseline_commit}); no diff"
    rm -f "${baseline}"
    return 0
  fi

  echo "[${PROG}] diff: ${baseline_commit} -> ${new_commit}"
  echo ""
  diff -u "${baseline}" .lattice/invariants/HEAD.yml || true
  rm -f "${baseline}"
}

# ---------------------------------------------------------------------------
# context — what Claude sees at session start (v0.9.1).
# Prints active invariants summary + open findings + active ADRs + drift hint.
# Designed for `cat $(lattice context)` or MCP get_context() consumption.
# Always regenerated, never cached.
# ---------------------------------------------------------------------------
cmd_context() {
  local mode
  mode="$(cmd_mode 2>/dev/null || echo classic)"

  echo "# Lattice context — $(date -u +%Y-%m-%dT%H:%M:%SZ)"
  echo "mode: ${mode}"
  if git rev-parse --short HEAD >/dev/null 2>&1; then
    printf 'commit: %s\n' "$(git rev-parse --short HEAD)"
  fi
  # Telemetry status — every session must see this so the bug-reporting channel
  # is never re-discovered as "an unknown mystery". Discovery, not just configuration.
  if _telemetry_enabled; then
    echo "telemetry: ON — failures auto-file at github.com/IsaamMJ/Lattice/issues?q=label%3Atelemetry"
  else
    echo "telemetry: OFF — enable: lattice config telemetry on  (or: export LATTICE_OWNER_MODE=1)"
  fi
  echo ""

  # Active ADRs (substrate + hybrid modes)
  if [ "${mode}" != "classic" ] && [ -d .lattice/decisions ]; then
    echo "## Active decisions"
    shopt -s nullglob
    local any=0
    for f in .lattice/decisions/*.yml; do
      local st
      st="$(yaml_field "${f}" "status")"
      [ "${st}" = "active" ] || [ "${st}" = "in_progress" ] || continue
      any=1
      printf '  - %s — %s\n' "$(yaml_field "${f}" "id")" "$(yaml_field "${f}" "title")"
    done
    [ ${any} -eq 0 ] && echo "  (none)"
    echo ""
  fi

  # Invariants summary (substrate mode)
  # v0.9.4 (#24): rewrote renderer. Previous version emitted bare labels
  # (`stack:`, `modules:`, `edge_functions:`) with empty values because the
  # data is on the lines BELOW each label (YAML list items), not inline.
  # New renderer counts/collapses each section explicitly so every line
  # carries information.
  if [ "${mode}" = "substrate" ]; then
    if [ -f .lattice/invariants/HEAD.yml ]; then
      echo "## Invariants (.lattice/invariants/HEAD.yml)"
      local inv=.lattice/invariants/HEAD.yml
      local inv_commit stack_list mod_count fn_count route_count tbl_count fe_count
      inv_commit="$(grep -E '^commit:' "${inv}" | awk '{print $2}')"
      # stack: list under `stack:` block (`  - flutter`, `  - supabase` …)
      stack_list="$(awk '/^stack:/{f=1;next} /^[a-z]/{f=0} f && /^  - /{sub(/^  - /,""); print}' "${inv}" 2>/dev/null | paste -sd, - | sed 's/,/, /g')"
      mod_count="$(grep -cE '^  - path:' "${inv}" 2>/dev/null || echo 0)"
      fn_count="$(awk '/^edge_functions:/{f=1;next} /^[a-z]/{f=0} f && /^  -/{c++} END{print c+0}' "${inv}" 2>/dev/null)"
      route_count="$(awk '/^routes:/{f=1;next} /^[a-z]/{f=0} f && /^  - /{c++} END{print c+0}' "${inv}" 2>/dev/null)"
      fe_count="$(awk '/^frontend_calls:/{f=1;next} /^[a-z]/{f=0} f && /^  - /{c++} END{print c+0}' "${inv}" 2>/dev/null)"
      tbl_count="$(awk '/^db_tables:/{f=1;next} /^[a-z]/{f=0} f && /^  - /{c++} END{print c+0}' "${inv}" 2>/dev/null)"
      [ -n "${inv_commit}" ] && printf '  commit: %s\n' "${inv_commit}"
      [ -n "${stack_list}" ] && printf '  stack: %s\n' "${stack_list}"
      [ "${mod_count}" -gt 0 ]  && printf '  modules: %s\n' "${mod_count}"
      [ "${fn_count}" -gt 0 ]   && printf '  edge_functions: %s\n' "${fn_count}"
      [ "${route_count}" -gt 0 ] && printf '  routes: %s\n' "${route_count}"
      [ "${fe_count}" -gt 0 ]   && printf '  frontend_calls: %s\n' "${fe_count}"
      [ "${tbl_count}" -gt 0 ]  && printf '  db_tables: %s\n' "${tbl_count}"
    else
      echo "## Invariants"
      echo "  (none — run: lattice invariants derive)"
    fi
    echo ""
  fi

  # Open findings summary
  if [ -d .lattice/findings/open ]; then
    echo "## Open findings (top by tier)"
    local total=0
    declare -A by_tier
    shopt -s nullglob
    for f in .lattice/findings/open/*.yml .lattice/findings/open/*/*.yml; do
      [ -f "${f}" ] || continue
      total=$((total + 1))
      local t
      t="$(yaml_field "${f}" "tier")"
      by_tier["${t}"]=$(( ${by_tier["${t}"]:-0} + 1 ))
    done
    if [ ${total} -eq 0 ]; then
      echo "  (none)"
    else
      for t in CRITICAL BLOCKER HIGH RISK DRIFT MEDIUM WATCH LOW INTENTIONAL UNVERIFIABLE OK; do
        local n=${by_tier["${t}"]:-0}
        [ ${n} -gt 0 ] && printf '  %s: %d\n' "${t}" "${n}"
      done
      printf '  total: %d\n' "${total}"
    fi
    echo ""
  fi

  # MAT friction awareness (v0.9.8). Close the awareness loop: if the session
  # log has unfiled friction candidates, surface the count + filing command at
  # the top of `next actions` so it's the path of least resistance, not an
  # opt-in scavenger hunt. Silent when there's nothing or no log yet.
  local _today _candcount
  _today="$(date -u +%Y%m%d 2>/dev/null || echo unknown)"
  if [ -f ".lattice/sessions/${_today}.jsonl" ]; then
    _candcount="$(cmd_review --day "${_today}" --quiet 2>/dev/null || echo 0)"
    if [ "${_candcount:-0}" -gt 0 ] 2>/dev/null; then
      echo "## Friction candidates"
      printf "  %s candidate(s) from today's session log — review: lattice review\n" "${_candcount}"
      printf '  file all (idempotent):                 lattice review --file --yes\n'
      echo ""
    fi
  fi

  echo "## Next actions"
  echo "  lattice list --tier CRITICAL,HIGH        # priority queue"
  echo "  lattice next                             # single highest-priority finding"
  echo "  lattice invariants diff                  # has the structural shape drifted?"
}

# ---------------------------------------------------------------------------
# report — manual bug / observation channel (v0.9.3). Closes the "telemetry
# blind to silent correctness bugs" gap surfaced by riseCraft session 2026-05-14.
#
# Telemetry only auto-files on FAILED commands. Silent correctness bugs (exit 0
# but wrong output), UX gaps, and architectural observations bypass that pipe.
# `lattice report` opens the channel for those: author-supplied title + body,
# routed through the same Cloudflare Worker that owns auto-telemetry, but with
# a different label set (`manual-report`).
#
# Usage:
#   lattice report <category> --title "..." --body "..." [--severity LOW|MED|HIGH]
#   lattice report <category> --title "..." --body-file <path>      [--severity ...]
#
# Categories: bug | enhancement | ux | docs | perf | security
# Severities: LOW | MED (default) | HIGH
# ---------------------------------------------------------------------------
cmd_report() {
  local category="" title="" body="" body_file="" severity="MED"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --title)     title="$2"; shift 2 ;;
      --body)      body="$2"; shift 2 ;;
      --body-file) body_file="$2"; shift 2 ;;
      --severity)  severity="$2"; shift 2 ;;
      -*)          die "report: unknown flag: $1" ;;
      *)           [ -z "${category}" ] && category="$1" || die "report: extra arg: $1"; shift ;;
    esac
  done
  [ -z "${category}" ] && die "report: usage: lattice report <category> --title \"...\" --body \"...\" [--severity LOW|MED|HIGH]"
  [ -z "${title}" ] && die "report: --title required"
  case "${category}" in
    bug|enhancement|ux|docs|perf|security) ;;
    *) die "report: category must be one of: bug | enhancement | ux | docs | perf | security" ;;
  esac
  # v2.1.2 (#73): accept MEDIUM as alias for MED to match finding-schema.md vocab
  case "${severity}" in
    MEDIUM) severity="MED" ;;
    LOW|MED|HIGH) ;;
    *) die "report: --severity must be LOW | MED | HIGH (also accepts MEDIUM)" ;;
  esac

  if [ -n "${body_file}" ]; then
    [ -f "${body_file}" ] || die "report: --body-file not found: ${body_file}"
    body="$(cat "${body_file}")"
  fi
  [ -z "${body}" ] && die "report: --body or --body-file required"

  # Build the payload. Same wire shape as telemetry plus kind+category+severity+title+body.
  local version os timestamp fingerprint user_hash
  version="$(current_version 2>/dev/null || echo 0.0.0)"
  case "$(uname -s 2>/dev/null)" in
    Linux*)   os="linux" ;;
    Darwin*)  os="darwin" ;;
    CYGWIN*|MINGW*|MSYS*|Windows*) os="windows" ;;
    *)        os="linux" ;;
  esac
  timestamp="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  # Fingerprint manual reports by title hash so duplicate titles dedup on the
  # Worker if it ever adds that (currently no dedup for manual_report).
  fingerprint="$(printf '%s:%s' "report" "${title}" | sha256sum 2>/dev/null | cut -d' ' -f1)"
  user_hash="$(printf '%s:%s' "$(uname -n 2>/dev/null || echo unknown)" "${HOME:-}" | sha256sum 2>/dev/null | cut -d' ' -f1)"

  # JSON-escape title + body. Bash-native to avoid stdin-pipe surprises across
  # python3/node availability on Git Bash Windows. Handles backslash, quote,
  # newline, tab, carriage-return. Other control chars stripped.
  _json_escape() {
    local s="$1"
    s="${s//\\/\\\\}"      # backslash first (must precede other escapes)
    s="${s//\"/\\\"}"      # double quote
    s="${s//$'\n'/\\n}"    # newline
    s="${s//$'\r'/\\r}"    # carriage return
    s="${s//$'\t'/\\t}"    # tab
    printf '"%s"' "${s}"
  }
  local title_json body_json
  title_json="$(_json_escape "${title}")"
  body_json="$(_json_escape "${body}")"

  # v2.1.3 (Part A): include project name so the Worker can tag the GH issue
  # with `project:<basename>` label. Lets `gh issue list --label project:X`
  # surface per-project bug pressure across many projects.
  local project_name; project_name="$(basename "$(pwd)" 2>/dev/null || echo unknown)"
  local project_json; project_json="$(_json_escape "${project_name}")"

  local payload
  payload="{\"version\":\"${version}\",\"command\":\"report\",\"exit_code\":0,\"os\":\"${os}\",\"msg_fingerprint\":\"${fingerprint}\",\"user_hash\":\"${user_hash}\",\"timestamp\":\"${timestamp}\",\"kind\":\"manual_report\",\"category\":\"${category}\",\"severity\":\"${severity}\",\"title\":${title_json},\"body\":${body_json},\"project\":${project_json}}"

  if [ "${LATTICE_TELEMETRY_DEBUG:-0}" = "1" ]; then
    echo "[${PROG}-report] payload (would send):" >&2
    echo "${payload}" >&2
    echo "[${PROG}-report] (debug mode — not sent)" >&2
    return 0
  fi

  echo "[${PROG}] filing manual report: [${category}/${severity}] ${title}"
  # 5s timeout — longer than telemetry's 2s because manual reports are user-initiated
  # and we want to give the Worker time to actually create the issue + return.
  local response http_code
  response="$(curl -sS -X POST "${_LATTICE_TELEMETRY_URL}" \
    -H "content-type: application/json" \
    -d "${payload}" \
    --max-time 5 \
    -w "\n%{http_code}" 2>/dev/null || echo "000")"
  http_code="$(echo "${response}" | tail -1)"

  case "${http_code}" in
    202|200)
      echo "[${PROG}] report accepted by Worker. Issue typically appears within ~5s at:"
      echo "[${PROG}]   github.com/IsaamMJ/Lattice/issues?q=label%3Amanual-report"
      ;;
    400)
      die "report: Worker rejected payload (likely sanitize failed). Check title/body for shell-quoting issues."
      ;;
    503)
      die "report: Worker misconfigured (GitHub token / KV namespace not bound)."
      ;;
    000|"")
      die "report: Worker unreachable. Check network. URL: ${_LATTICE_TELEMETRY_URL}"
      ;;
    *)
      die "report: Worker returned HTTP ${http_code}. Response: $(echo "${response}" | head -1)"
      ;;
  esac
}

# ---------------------------------------------------------------------------
# install-hooks — install the post-commit-resolve-pending hook into .git/hooks/
# (closes #7). Idempotent. Sources the helper from project-local scripts/ if
# present, else from the global ~/.claude/lattice/scripts/.
# ---------------------------------------------------------------------------
cmd_install_hooks() {
  local force=0
  for a in "$@"; do
    [ "${a}" = "--force" ] && force=1
  done

  git rev-parse --git-dir >/dev/null 2>&1 || die "install-hooks: not inside a git repo"
  local git_dir
  git_dir="$(git rev-parse --git-dir)"
  local hooks_dir="${git_dir}/hooks"
  mkdir -p "${hooks_dir}"

  # Helper: install one hook by source basename + dest hook name + match-pattern
  _install_one_hook() {
    local src_name="$1" dest_name="$2" match_pat="$3"
    local src=""
    for candidate in \
        "${SELF_DIR}/${src_name}" \
        "${HOME}/.claude/lattice/scripts/${src_name}"; do
      if [ -f "${candidate}" ]; then src="${candidate}"; break; fi
    done
    if [ -z "${src}" ]; then
      echo "[${PROG}] install-hooks: ${src_name} not found — skipping ${dest_name}"
      return 0
    fi
    local dest="${hooks_dir}/${dest_name}"
    if [ -f "${dest}" ] && [ "${force}" -ne 1 ]; then
      if grep -q "${match_pat}" "${dest}" 2>/dev/null; then
        echo "[${PROG}] install-hooks: ${dest_name} already Lattice-managed — nothing to do"
        return 0
      fi
      echo "[${PROG}] install-hooks: ${dest} exists and is not the Lattice hook (use --force to overwrite) — skipping"
      return 0
    fi
    cp "${src}" "${dest}"
    chmod +x "${dest}" 2>/dev/null || true
    echo "[${PROG}] install-hooks: installed ${dest}"
  }

  # post-commit (existing — resolve-pending)
  _install_one_hook "post-commit-resolve-pending.sh" "post-commit" 'post-commit-resolve-pending\|lattice resolve-pending'

  # v2.2 (#84): prepare-commit-msg — verify-on-commit hint
  _install_one_hook "prepare-commit-msg-lattice.sh" "prepare-commit-msg" 'prepare-commit-msg-lattice\|Lattice prepare-commit-msg'

  echo "[${PROG}] install-hooks: uninstall manually with: rm ${hooks_dir}/post-commit ${hooks_dir}/prepare-commit-msg"
}

# ---------------------------------------------------------------------------
# stats — totals by tier + dimension + top modules (closes the stats half of #15).
# Reads .lattice/findings/open/*.yml and prints a single-screen summary.
# ---------------------------------------------------------------------------
cmd_stats() {
  [ -d ".lattice/findings/open" ] || { echo "[${PROG}] no .lattice/findings/open/ in cwd" >&2; return 0; }

  shopt -s nullglob
  local total=0
  declare -A by_tier by_dim by_module
  for f in .lattice/findings/open/*/*.yml .lattice/findings/open/*.yml; do
    [ -f "${f}" ] || continue
    total=$((total + 1))
    local t d m
    t="$(yaml_field "${f}" "tier")"
    d="$(yaml_field "${f}" "dimension")"
    m="$(yaml_field "${f}" "module")"
    by_tier["${t}"]=$(( ${by_tier["${t}"]:-0} + 1 ))
    by_dim["${d}"]=$(( ${by_dim["${d}"]:-0} + 1 ))
    by_module["${m}"]=$(( ${by_module["${m}"]:-0} + 1 ))
  done

  echo "Open findings: ${total}"
  echo ""
  if [ ${total} -gt 0 ]; then
    echo "By tier:"
    for t in CRITICAL BLOCKER HIGH RISK DRIFT MEDIUM WATCH LOW INTENTIONAL UNVERIFIABLE OK; do
      local n=${by_tier["${t}"]:-0}
      [ ${n} -gt 0 ] && printf "  %-12s %d\n" "${t}" "${n}"
    done
    echo ""
    echo "By dimension:"
    for d in "${!by_dim[@]}"; do
      printf "  %-15s %d\n" "${d}" "${by_dim[${d}]}"
    done | sort -rnk2
    echo ""
    echo "Top modules:"
    for m in "${!by_module[@]}"; do
      printf "  %-40s %d\n" "${m}" "${by_module[${m}]}"
    done | sort -rnk2 | head -10
  fi
}

# ---------------------------------------------------------------------------
cmd_resolve_pending() {
  local target_commit=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --commit) [ -z "${2:-}" ] && die "resolve-pending: --commit requires a value"
                target_commit="$2"; shift 2 ;;
      *) die "resolve-pending: unknown arg: $1" ;;
    esac
  done

  local sha
  if [ -n "${target_commit}" ]; then
    if ! sha="$(git rev-parse --short "${target_commit}" 2>/dev/null)"; then
      die "resolve-pending: cannot resolve --commit '${target_commit}'"
    fi
  else
    if ! sha="$(git rev-parse --short HEAD 2>/dev/null)"; then
      die "resolve-pending: not in a git repo (use --commit <sha>)"
    fi
  fi

  [ -d ".lattice/findings/closed" ] || { echo "[${PROG}] resolve-pending: no closed findings directory"; return 0; }

  shopt -s nullglob
  local resolved=0
  for f in .lattice/findings/closed/*.yml .lattice/findings/closed/*/*.yml; do
    [ -f "${f}" ] || continue
    if grep -q '^closed_by_commit: __PENDING__$' "${f}"; then
      # Use awk for cross-platform safety (macOS sed -i differs from GNU sed -i)
      local tmp; tmp="$(mktemp)"
      awk -v sha="${sha}" '/^closed_by_commit: __PENDING__$/ { print "closed_by_commit: " sha; next } { print }' "${f}" > "${tmp}"
      mv "${tmp}" "${f}"
      echo "[${PROG}] resolved: ${f} -> ${sha}"
      resolved=$((resolved + 1))
    fi
  done

  if [ ${resolved} -eq 0 ]; then
    echo "[${PROG}] resolve-pending: no __PENDING__ markers found (nothing to do)"
  else
    echo "[${PROG}] resolved ${resolved} pending finding(s) to ${sha}"
    echo "[${PROG}] next: git add .lattice/findings/closed/ && git commit --amend --no-edit"
  fi
}

# ---------------------------------------------------------------------------
# sessions — inspect the MAT log (v0.9.6).
#
#   lattice sessions list              # list every day's session file w/ counts
#   lattice sessions show              # pretty-print today's session log
#   lattice sessions show <YYYYMMDD>   # pretty-print a specific day
#   lattice sessions show --raw [day]  # dump raw JSONL (for piping to jq)
#
# The MAT log is the v0.9.6 foundation; v0.9.7 layers friction predicates and
# `lattice review` on top. v0.9.6 only ships read access so users can verify
# the trace data is being captured correctly.
# ---------------------------------------------------------------------------
cmd_sessions() {
  local action="${1:-list}"
  shift 2>/dev/null || true
  case "${action}" in
    list)
      [ -d ".lattice/sessions" ] || { echo "[${PROG}] no .lattice/sessions/ in cwd (no MAT events recorded yet)"; return 0; }
      shopt -s nullglob
      local files=(.lattice/sessions/*.jsonl)
      if [ "${#files[@]}" -eq 0 ]; then
        echo "[${PROG}] no session files (MAT log is empty)"
        return 0
      fi
      printf '%-12s %8s  %s\n' "DAY" "EVENTS" "PATH"
      local f day count
      for f in "${files[@]}"; do
        day="$(basename "${f}" .jsonl)"
        count="$(wc -l < "${f}" 2>/dev/null | tr -d ' ' || echo 0)"
        printf '%-12s %8s  %s\n' "${day}" "${count}" "${f}"
      done
      ;;
    show)
      local raw=0 day=""
      while [ "$#" -gt 0 ]; do
        case "$1" in
          --raw) raw=1; shift ;;
          -*)    die "sessions show: unknown flag: $1" ;;
          *)     [ -z "${day}" ] && day="$1" || die "sessions show: extra arg: $1"; shift ;;
        esac
      done
      [ -z "${day}" ] && day="$(date -u +%Y%m%d)"
      local f=".lattice/sessions/${day}.jsonl"
      if [ ! -f "${f}" ]; then
        echo "[${PROG}] no session log for ${day} (${f})"
        return 1
      fi
      if [ "${raw}" -eq 1 ]; then
        cat "${f}"
        return 0
      fi
      # Pretty-print: ts cmd exit dur invoked_via
      local total=0 fail=0 fullpath=0
      printf '%-20s %-18s %-5s %-8s %-10s\n' "TS" "CMD" "EXIT" "DUR_MS" "INVOKED"
      while IFS= read -r line; do
        [ -z "${line}" ] && continue
        total=$((total + 1))
        # Extract fields with grep + sed; the JSON shape is fixed so this is safe.
        local _ts _cmd _exit _dur _via
        _ts="$(printf '%s' "${line}" | sed -E 's/.*"ts":"([^"]*)".*/\1/')"
        _cmd="$(printf '%s' "${line}" | sed -E 's/.*"cmd":"([^"]*)".*/\1/')"
        _exit="$(printf '%s' "${line}" | sed -E 's/.*"exit":([0-9-]+).*/\1/')"
        _dur="$(printf '%s' "${line}" | sed -E 's/.*"duration_ms":([0-9]+).*/\1/')"
        _via="$(printf '%s' "${line}" | sed -E 's/.*"invoked_via":"([^"]*)".*/\1/')"
        [ "${_exit}" != "0" ] && fail=$((fail + 1))
        [ "${_via}" = "fullpath" ] && fullpath=$((fullpath + 1))
        printf '%-20s %-18s %-5s %-8s %-10s\n' "${_ts}" "${_cmd}" "${_exit}" "${_dur}" "${_via}"
      done < "${f}"
      echo ""
      printf '[%s] %s events, %s failures, %s full-path invocations\n' "${PROG}" "${total}" "${fail}" "${fullpath}"
      if [ "${fullpath}" -gt 0 ]; then
        echo "[${PROG}] hint: full-path invocations indicate PATH workaround — see install.sh shim auto-install"
      fi
      ;;
    *)
      die "sessions: usage: lattice sessions <list|show> [day]"
      ;;
  esac
}

# ---------------------------------------------------------------------------
# review — derive friction candidates from the MAT log (v0.9.7).
#
# Reads `.lattice/sessions/<day>.jsonl` (default today) and runs a set of
# predicates over the events. Each match emits a candidate of the form:
#   {kind, severity, title, body, evidence_count, sample_ts}
#
# Predicates (initial set, kept narrow + high-precision):
#
#   fullpath_workaround
#     ANY event with invoked_via=fullpath. Means the session used
#     `~/.claude/lattice/scripts/lattice` instead of the PATH-resolved
#     `lattice`. Direct evidence the PATH shim is broken on this machine.
#     Severity: MED (real recurring friction, partial v0.8.3 fix).
#
#   unknown_subcommand
#     Any event where exit=2 AND cmd is not a known subcommand name. A
#     discoverability / typo signal. Severity: LOW.
#
#   repeated_failure
#     Same cmd exited non-zero >=2 times within the session day. Likely
#     a real reproducible bug the session worked around. Severity: MED.
#
#   failed_then_succeeded
#     Same cmd transitioned exit!=0 -> exit=0 within the session. The
#     initial failure is a bug candidate even though the second try worked
#     (a session "got past it" without filing). Severity: LOW.
#
#   slow_command
#     Any event with duration_ms > 30000. Foreground stall, scanning issue,
#     or stuck loop. Severity: LOW.
#
# Output modes:
#   lattice review                  # pretty table + summary (default = today)
#   lattice review --day YYYYMMDD   # specific day
#   lattice review --json           # one JSON object per line per candidate
#   lattice review --quiet          # only emit the candidate count (CI gate)
#
# v0.9.8 will add `--file [--yes]` to feed each candidate into
# `lattice report` with idempotent dedup via `.lattice/sessions/.filed.jsonl`.
# ---------------------------------------------------------------------------
_KNOWN_SUBS="close link reopen sync regenerate defer list ls show cat bulk-close handoff next verify ci-check ci-check-dead wire-hooks mcp uninstall setup onboard release-notes normalize diff write-manifest audit-infra profile grow usage update config validate sweeps sweep-id id-gen doctor export changelog resolve-pending test-fixture install-hooks stats mode decide decisions invariants context report sessions review audit-env-contract claude-md-tune claude-md-restore project-init project-sync project-restore statusline version help"

_review_known_cmd() {
  local needle="$1" w
  for w in ${_KNOWN_SUBS}; do
    [ "${w}" = "${needle}" ] && return 0
  done
  return 1
}

cmd_review() {
  local day="" mode="pretty" auto_yes=0
  # v0.9.8: --file feeds candidates into `lattice report` with idempotent
  # dedup via `.lattice/sessions/.filed.jsonl`. --yes skips per-candidate
  # confirmation (CI / autonomous-agent friendly).
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --day)   day="$2"; shift 2 ;;
      --json)  mode="json"; shift ;;
      --quiet) mode="quiet"; shift ;;
      --file)  mode="file"; shift ;;
      --yes|-y) auto_yes=1; shift ;;
      -*)      die "review: unknown flag: $1" ;;
      *)       die "review: extra arg: $1" ;;
    esac
  done
  [ -z "${day}" ] && day="$(date -u +%Y%m%d)"
  local log=".lattice/sessions/${day}.jsonl"
  if [ ! -f "${log}" ]; then
    [ "${mode}" = "quiet" ] && { echo "0"; return 0; }
    [ "${mode}" = "json" ] && return 0
    echo "[${PROG}] review: no session log for ${day} (${log})"
    return 0
  fi

  # Pass 1: collect per-line tuples into parallel arrays. JSON parsing here is
  # whitelisted-shape sed (the writer at _write_mat_entry is the only producer).
  local -a EVT_TS=() EVT_CMD=() EVT_EXIT=() EVT_DUR=() EVT_VIA=()
  local line
  while IFS= read -r line; do
    [ -z "${line}" ] && continue
    EVT_TS+=(   "$(printf '%s' "${line}" | sed -E 's/.*"ts":"([^"]*)".*/\1/')")
    EVT_CMD+=(  "$(printf '%s' "${line}" | sed -E 's/.*"cmd":"([^"]*)".*/\1/')")
    EVT_EXIT+=( "$(printf '%s' "${line}" | sed -E 's/.*"exit":([0-9-]+).*/\1/')")
    EVT_DUR+=(  "$(printf '%s' "${line}" | sed -E 's/.*"duration_ms":([0-9]+).*/\1/')")
    EVT_VIA+=(  "$(printf '%s' "${line}" | sed -E 's/.*"invoked_via":"([^"]*)".*/\1/')")
  done < "${log}"

  local n=${#EVT_TS[@]}

  # Pass 2: run predicates. Each predicate writes 0..1 candidates to a flat
  # array (kind|severity|title|count|sample_ts) joined by tab so we can emit
  # in either pretty or JSON form without re-running.
  local -a CANDIDATES=()
  # Helper: append a tab-joined candidate row. 7th field (stable_key) is the
  # dedup fingerprint input for v0.9.8 --file mode — keeps the row identity
  # stable across days/counts so re-filing doesn't double-create issues.
  _emit_candidate() {
    CANDIDATES+=("$1"$'\t'"$2"$'\t'"$3"$'\t'"$4"$'\t'"$5"$'\t'"$6"$'\t'"${7:-$1}")
  }

  # --- predicate: fullpath_workaround
  local fp_count=0 fp_sample=""
  local i
  for ((i=0; i<n; i++)); do
    if [ "${EVT_VIA[$i]}" = "fullpath" ]; then
      fp_count=$((fp_count + 1))
      [ -z "${fp_sample}" ] && fp_sample="${EVT_TS[$i]}"
    fi
  done
  if [ "${fp_count}" -gt 0 ]; then
    _emit_candidate "fullpath_workaround" "MED" \
      "lattice CLI invoked via full path ${fp_count}x — PATH shim not resolved" \
      "v0.8.3 ships an install-time shim into ~/.local/bin and a PATH guard in shell rc. On ${fp_count} invocation(s) today the dispatcher was reached via its full path instead, which means the shim never made it onto PATH for this shell. Re-run install.sh or inspect 'lattice doctor' output." \
      "${fp_count}" "${fp_sample}" "fullpath_workaround"
  fi

  # --- predicate: unknown_subcommand
  local unk_count=0 unk_sample="" unk_cmd=""
  for ((i=0; i<n; i++)); do
    if [ "${EVT_EXIT[$i]}" = "2" ] && ! _review_known_cmd "${EVT_CMD[$i]}"; then
      unk_count=$((unk_count + 1))
      [ -z "${unk_sample}" ] && unk_sample="${EVT_TS[$i]}"
      [ -z "${unk_cmd}" ] && unk_cmd="${EVT_CMD[$i]}"
    fi
  done
  if [ "${unk_count}" -gt 0 ]; then
    _emit_candidate "unknown_subcommand" "LOW" \
      "session tried unknown subcommand(s) ${unk_count}x — first: '${unk_cmd}'" \
      "Sessions invoked subcommand names that don't exist in this version's dispatcher. Either a discoverability gap (the right command exists under a different name) or stale memory of removed/renamed commands. Worth comparing to 'lattice help' output and considering aliases or did-you-mean hints." \
      "${unk_count}" "${unk_sample}" "unknown_subcommand:${unk_cmd}"
  fi

  # --- predicate: repeated_failure (same cmd, exit!=0, >=2 occurrences)
  local -A fail_by_cmd=()
  local -A fail_sample=()
  for ((i=0; i<n; i++)); do
    if [ "${EVT_EXIT[$i]}" != "0" ]; then
      local c="${EVT_CMD[$i]}"
      fail_by_cmd["${c}"]=$(( ${fail_by_cmd["${c}"]:-0} + 1 ))
      [ -z "${fail_sample["${c}"]:-}" ] && fail_sample["${c}"]="${EVT_TS[$i]}"
    fi
  done
  for c in "${!fail_by_cmd[@]}"; do
    if [ "${fail_by_cmd[${c}]}" -ge 2 ]; then
      _emit_candidate "repeated_failure" "MED" \
        "lattice ${c} failed ${fail_by_cmd[${c}]}x in one day — reproducible bug candidate" \
        "Same subcommand exited non-zero multiple times in the same day. Either a real bug the session worked around (filed candidate) or a misuse pattern (still useful as a UX signal — surface the actual error in usage)." \
        "${fail_by_cmd[${c}]}" "${fail_sample[${c}]}" "repeated_failure:${c}"
    fi
  done

  # --- predicate: failed_then_succeeded (same cmd transitions fail -> ok)
  local -A last_fail_ts=()
  local -A ftss_count=()
  local -A ftss_sample=()
  for ((i=0; i<n; i++)); do
    local c="${EVT_CMD[$i]}"
    if [ "${EVT_EXIT[$i]}" != "0" ]; then
      last_fail_ts["${c}"]="${EVT_TS[$i]}"
    else
      if [ -n "${last_fail_ts["${c}"]:-}" ]; then
        ftss_count["${c}"]=$(( ${ftss_count["${c}"]:-0} + 1 ))
        [ -z "${ftss_sample["${c}"]:-}" ] && ftss_sample["${c}"]="${last_fail_ts["${c}"]}"
        unset 'last_fail_ts['"${c}"']'
      fi
    fi
  done
  for c in "${!ftss_count[@]}"; do
    _emit_candidate "failed_then_succeeded" "LOW" \
      "lattice ${c} failed then succeeded ${ftss_count[${c}]}x — silent workaround" \
      "Session retried the same subcommand and got past the failure. The original failure is a bug candidate even though the workaround unblocked the session — exactly the silent-correctness class the manual report channel was built for." \
      "${ftss_count[${c}]}" "${ftss_sample[${c}]}" "failed_then_succeeded:${c}"
  done

  # --- predicate: slow_command (duration_ms > 30000)
  local slow_count=0 slow_sample="" slow_cmd=""
  for ((i=0; i<n; i++)); do
    if [ "${EVT_DUR[$i]:-0}" -gt 30000 ] 2>/dev/null; then
      slow_count=$((slow_count + 1))
      [ -z "${slow_sample}" ] && slow_sample="${EVT_TS[$i]}"
      [ -z "${slow_cmd}" ] && slow_cmd="${EVT_CMD[$i]}"
    fi
  done
  if [ "${slow_count}" -gt 0 ]; then
    _emit_candidate "slow_command" "LOW" \
      "lattice ${slow_cmd} took >30s ${slow_count}x — perf or stuck-loop candidate" \
      "Duration above 30s on a Lattice CLI invocation. Most subcommands should be sub-second; durations this long usually indicate filesystem scan blow-up, regex backtracking, or a stuck loop. Worth profiling." \
      "${slow_count}" "${slow_sample}" "slow_command:${slow_cmd}"
  fi

  # --- Output --------------------------------------------------------------
  local ncand=${#CANDIDATES[@]}

  if [ "${mode}" = "quiet" ]; then
    echo "${ncand}"
    return 0
  fi

  if [ "${mode}" = "json" ]; then
    local entry
    for entry in "${CANDIDATES[@]}"; do
      local kind sev title body cnt ts key
      kind="${entry%%	*}";  entry="${entry#*	}"
      sev="${entry%%	*}";   entry="${entry#*	}"
      title="${entry%%	*}"; entry="${entry#*	}"
      body="${entry%%	*}";  entry="${entry#*	}"
      cnt="${entry%%	*}";   entry="${entry#*	}"
      ts="${entry%%	*}";    entry="${entry#*	}"
      key="${entry}"
      # Inline escape — same rules as the MAT writer in _write_mat_entry.
      local _k="${kind//\\/\\\\}"; _k="${_k//\"/\\\"}"; _k="${_k//$'\n'/\\n}"
      local _s="${sev//\\/\\\\}";  _s="${_s//\"/\\\"}";  _s="${_s//$'\n'/\\n}"
      local _t="${title//\\/\\\\}"; _t="${_t//\"/\\\"}"; _t="${_t//$'\n'/\\n}"
      local _b="${body//\\/\\\\}";  _b="${_b//\"/\\\"}";  _b="${_b//$'\n'/\\n}"
      local _ts="${ts//\\/\\\\}";   _ts="${_ts//\"/\\\"}"; _ts="${_ts//$'\n'/\\n}"
      local _key="${key//\\/\\\\}"; _key="${_key//\"/\\\"}"; _key="${_key//$'\n'/\\n}"
      printf '{"kind":"%s","severity":"%s","title":"%s","body":"%s","evidence_count":%s,"sample_ts":"%s","stable_key":"%s"}\n' \
        "${_k}" "${_s}" "${_t}" "${_b}" "${cnt}" "${_ts}" "${_key}"
    done
    return 0
  fi

  if [ "${mode}" = "file" ]; then
    if [ "${ncand}" -eq 0 ]; then
      echo "[${PROG}] review --file (${day}): 0 candidates, nothing to file"
      return 0
    fi
    mkdir -p .lattice/sessions 2>/dev/null || true
    local filed_log=".lattice/sessions/.filed.jsonl"
    local filed=0 skipped=0 errored=0
    local entry kind sev title body cnt ts key fp category
    for entry in "${CANDIDATES[@]}"; do
      kind="${entry%%	*}";  entry="${entry#*	}"
      sev="${entry%%	*}";   entry="${entry#*	}"
      title="${entry%%	*}"; entry="${entry#*	}"
      body="${entry%%	*}";  entry="${entry#*	}"
      cnt="${entry%%	*}";   entry="${entry#*	}"
      ts="${entry%%	*}";    entry="${entry#*	}"
      key="${entry}"
      # Idempotent fingerprint over the stable_key (not over title — title
      # contains volatile occurrence counts).
      fp="$(printf '%s' "${key}" | sha256sum 2>/dev/null | cut -d' ' -f1)"
      if [ -z "${fp}" ]; then
        echo "[${PROG}] review --file: sha256sum unavailable; cannot dedup safely. Aborting." >&2
        return 1
      fi
      if [ -f "${filed_log}" ] && grep -q "\"fingerprint\":\"${fp}\"" "${filed_log}" 2>/dev/null; then
        skipped=$((skipped + 1))
        echo "[${PROG}] skip (already filed): [${kind}] ${title}"
        continue
      fi
      # Optional per-candidate prompt unless --yes
      if [ "${auto_yes}" -ne 1 ]; then
        if [ ! -t 0 ]; then
          echo "[${PROG}] review --file: non-TTY stdin; refusing without --yes" >&2
          return 2
        fi
        printf '\nfile [%s] %s? [y/N] ' "${kind}" "${title}" >&2
        local ans; read -r ans </dev/tty || ans=""
        case "${ans}" in
          y|Y|yes|YES) ;;
          *) echo "[${PROG}] skipped (user)"; skipped=$((skipped + 1)); continue ;;
        esac
      fi
      # Map kind -> lattice report category
      case "${kind}" in
        fullpath_workaround)   category="bug"  ;;
        unknown_subcommand)    category="ux"   ;;
        repeated_failure)      category="bug"  ;;
        failed_then_succeeded) category="bug"  ;;
        slow_command)          category="perf" ;;
        *)                     category="bug"  ;;
      esac
      # Body gets the predicate sample timestamp + evidence footer so the
      # filed issue is traceable back to the MAT log on this machine.
      local annotated_body
      annotated_body="${body}

---
*Auto-detected by \`lattice review\` predicate \`${kind}\` on ${day}.*
- evidence_count: ${cnt}
- sample_ts: ${ts}
- fingerprint: ${fp}"
      # Invoke lattice report. In normal mode this POSTs to the Worker and
      # auto-files a GitHub issue. In LATTICE_TELEMETRY_DEBUG=1 mode it just
      # prints the payload (tests rely on that for hermetic runs).
      if bash "${BASH_SOURCE[0]:-$0}" report "${category}" \
          --title "${title}" \
          --body "${annotated_body}" \
          --severity "${sev}" >/dev/null 2>&1; then
        filed=$((filed + 1))
        # Append filed-fingerprint record so re-runs dedup.
        local filed_at
        filed_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
        printf '{"fingerprint":"%s","kind":"%s","filed_at":"%s","day":"%s"}\n' \
          "${fp}" "${kind}" "${filed_at}" "${day}" \
          >> "${filed_log}" 2>/dev/null || true
        echo "[${PROG}] FILED: [${kind}] ${title}"
      else
        errored=$((errored + 1))
        echo "[${PROG}] FAILED to file: [${kind}] ${title}" >&2
      fi
    done
    echo ""
    echo "[${PROG}] review --file (${day}): ${filed} filed, ${skipped} skipped, ${errored} errored"
    return 0
  fi

  # pretty mode
  if [ "${ncand}" -eq 0 ]; then
    echo "[${PROG}] review (${day}): ${n} event(s), 0 friction candidates"
    return 0
  fi
  echo "[${PROG}] review (${day}): ${n} event(s), ${ncand} friction candidate(s)"
  echo ""
  local idx=0 entry
  for entry in "${CANDIDATES[@]}"; do
    idx=$((idx + 1))
    local kind sev title cnt
    kind="${entry%%	*}";  entry="${entry#*	}"
    sev="${entry%%	*}";   entry="${entry#*	}"
    title="${entry%%	*}"; entry="${entry#*	}"
    entry="${entry#*	}"  # body — skipped in pretty
    cnt="${entry%%	*}"
    printf '  %d) [%s] %-6s (%sx) %s\n' "${idx}" "${kind}" "${sev}" "${cnt}" "${title}"
  done
  echo ""
  echo "  next: lattice review --json | jq    # structured form for tooling"
  echo "        (v0.9.8 will add --file to auto-create issues from candidates)"
}

# ---------------------------------------------------------------------------
# Global CLAUDE.md integration helpers (v0.9.10).
#
# Single source of truth for:
#   - the Lattice-managed block content (`_lattice_md_block`)
#   - the sentinel-based install/replace logic (`_lattice_md_apply`)
#   - backup management (`_lattice_md_backup`)
#
# Shared between install.sh (calls dispatcher with `lattice claude-md-tune
# --apply --bootstrap`) and the `claude-md-tune` / `claude-md-restore`
# subcommands so block content never lives in two places.
#
# Sentinels — never edit text inside these markers by hand; the tune loop
# will overwrite them. Edit OUTSIDE the markers for personal customizations.
# ---------------------------------------------------------------------------
_LATTICE_MD_SENTINEL_START="<!-- LATTICE-MANAGED-BLOCK-START -->"
_LATTICE_MD_SENTINEL_END="<!-- LATTICE-MANAGED-BLOCK-END -->"
_LATTICE_GLOBAL_MD="${HOME}/.claude/CLAUDE.md"
_LATTICE_MD_BACKUP_DIR="${HOME}/.claude/lattice/claude-md-backups"

# v0.9.11 — project-scoped block uses DIFFERENT sentinels so the global tune
# can never accidentally edit a project file (and vice versa). Each block is
# managed independently by its own writer.
_LATTICE_PROJECT_MD_SENTINEL_START="<!-- LATTICE-PROJECT-BLOCK-START -->"
_LATTICE_PROJECT_MD_SENTINEL_END="<!-- LATTICE-PROJECT-BLOCK-END -->"
_LATTICE_PROJECT_MD_BACKUP_DIR=".lattice/claude-md-backups"

# Echoes the canonical Lattice-managed block (no surrounding sentinels — the
# caller wraps). Pure heuristic, deterministic. v0.9.11+ may rewrite parts of
# this based on usage data, but the structure stays stable.
_lattice_md_block() {
  local ver
  ver="$(current_version 2>/dev/null || echo unknown)"
  cat <<MDBLOCK
${_LATTICE_MD_SENTINEL_START}
<!-- managed by lattice install.sh / \`lattice claude-md-tune\` — do not edit by hand -->
<!-- generated: $(date -u +%Y-%m-%dT%H:%M:%SZ)  lattice-version: ${ver} -->

# Lattice (audit + finding lifecycle substrate)

Lattice is installed on this machine. Every Claude Code session should use it as the audit + finding-lifecycle layer for any project that has \`.lattice/\` checked in.

## Session-start protocol

1. Run \`lattice context\` at the very start of any session that operates on a project with \`.lattice/\`. It returns mode, active ADRs, invariants summary, open findings by tier, telemetry status, and pending friction candidates from prior sessions.
2. If \`.lattice/\` does not exist and the user is asking for an audit, run \`lattice doctor\` first (auto-bootstraps the directory).
3. If \`lattice context\` reports pending friction candidates, surface them to the user before diving into the task.

## Working with findings

- List: \`lattice list --tier CRITICAL,HIGH\` (or \`lattice next\` for the single highest-priority).
- Close: \`lattice close <id> --reason <fixed|false-positive|wont-fix|out-of-scope|duplicate> --commit HEAD --rationale "..."\`
- Defer: \`lattice defer <id> --until YYYY-MM-DD --reason "..."\`
- Reopen: \`lattice reopen <id> --reason "..."\`
- Verify a "fixed" claim: \`lattice verify <id> --rerun-grep\`
- ADR: \`lattice decide <slug> --title "..." --because-file <path>\`

## Running audits

- \`/audit <project-root> [doc-path]\` — single audit (doc-vs-code drift).
- \`/audit-sweep <project-root> [audit|scale|security|env-contract|flow|coverage]\` — full sweep across modules. **Default-on dimensions:** audit + scale + security + env-contract. Flow / coverage are opt-in.
- \`/security-audit\`, \`/scale-audit\`, \`/flow-audit\` — single-dimension passes.
- \`/lattice-fix <id>\` — auto-fix one low-risk PATCH_DOC finding via a Haiku subagent.

## Reporting friction

Hit a workflow problem or silent-correctness bug? File it:
\`\`\`
lattice report <bug|enhancement|ux|docs|perf|security> --title "..." --body "..." --severity LOW|MED|HIGH
\`\`\`
Reports auto-create GitHub issues at \`github.com/IsaamMJ/Lattice/issues?q=label%3Amanual-report\`.

## End-of-session protocol

- Run \`lattice review\` to see friction candidates auto-derived from this session's MAT log.
- Run \`lattice review --file --yes\` to auto-file them as GitHub issues (idempotent — already-filed candidates skip cleanly).

## Self-tuning

This block is auto-managed. If it goes stale, run \`lattice claude-md-tune --apply\` to refresh it from current Lattice state + observed usage. Backups are kept in \`~/.claude/lattice/claude-md-backups/\`; revert via \`lattice claude-md-restore --list\` and \`lattice claude-md-restore <timestamp>\`.

${_LATTICE_MD_SENTINEL_END}
MDBLOCK
}

# _lattice_md_backup <target_file>
# Always copies target to backup dir with UTC timestamp. Echoes backup path.
# No-op (returns 0) if target doesn't exist.
_lattice_md_backup() {
  local target="$1"
  [ -f "${target}" ] || return 0
  mkdir -p "${_LATTICE_MD_BACKUP_DIR}" 2>/dev/null || return 1
  local ts backup_path
  ts="$(date -u +%Y%m%dT%H%M%SZ)"
  backup_path="${_LATTICE_MD_BACKUP_DIR}/CLAUDE.md.${ts}"
  cp "${target}" "${backup_path}" 2>/dev/null || return 1
  echo "${backup_path}"
}

# _lattice_md_apply <target_file>
# Idempotently inserts the Lattice block at the TOP of target_file. If the
# block already exists (detected by sentinels), replaces ITS CONTENTS without
# touching anything outside. If target doesn't exist, creates it with just the
# block + a trailing newline so future user edits append cleanly.
_lattice_md_apply() {
  local target="$1"
  mkdir -p "$(dirname "${target}")" 2>/dev/null || return 1

  # Always backup first (if file exists)
  local backup
  backup="$(_lattice_md_backup "${target}")"
  if [ -n "${backup}" ]; then
    echo "[${PROG}] backed up to ${backup}" >&2
  fi

  local new_block
  new_block="$(_lattice_md_block)"

  if [ ! -f "${target}" ]; then
    # New file — block at top + trailing newline for user content
    {
      printf '%s\n\n' "${new_block}"
    } > "${target}"
    echo "[${PROG}] created ${target} (Lattice block + empty user section)" >&2
    return 0
  fi

  # Existing file — detect sentinels
  if grep -qF "${_LATTICE_MD_SENTINEL_START}" "${target}"; then
    # Replace content between sentinels in place using awk for atomicity
    local tmp
    tmp="$(mktemp)" || return 1
    awk -v start="${_LATTICE_MD_SENTINEL_START}" \
        -v end="${_LATTICE_MD_SENTINEL_END}" \
        -v block="${new_block}" '
      BEGIN { in_block=0; replaced=0 }
      {
        if (index($0, start) > 0 && !in_block) {
          in_block=1
          if (!replaced) {
            print block
            replaced=1
          }
          next
        }
        if (in_block) {
          if (index($0, end) > 0) {
            in_block=0
          }
          next
        }
        print
      }
    ' "${target}" > "${tmp}"
    mv "${tmp}" "${target}"
    echo "[${PROG}] replaced existing Lattice block in ${target}" >&2
  else
    # No sentinels — prepend block, then existing content
    local tmp
    tmp="$(mktemp)" || return 1
    {
      printf '%s\n\n' "${new_block}"
      cat "${target}"
    } > "${tmp}"
    mv "${tmp}" "${target}"
    echo "[${PROG}] prepended Lattice block to existing ${target}" >&2
  fi
  return 0
}

# ---------------------------------------------------------------------------
# claude-md-tune (v0.9.10) — Phase 2 of global integration.
#
# Modes:
#   --propose          dry-run; print what the apply would do (default)
#   --apply            actually write the refreshed block to ~/.claude/CLAUDE.md
#   --bootstrap        equivalent to --apply, but suppresses the "no change"
#                      banner; called by install.sh on first install
#   --review-prompt    emit a structured self-review prompt for the running
#                      Claude session to consume (this is the auto-tune
#                      mechanism: same session reads its own onboarding doc
#                      and proposes revisions, no external service needed)
# ---------------------------------------------------------------------------
cmd_claude_md_tune() {
  local mode="propose"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --propose)        mode="propose"; shift ;;
      --apply)          mode="apply"; shift ;;
      --bootstrap)      mode="bootstrap"; shift ;;
      --review-prompt)  mode="review-prompt"; shift ;;
      --check)          mode="check"; shift ;;
      --auto)           mode="auto"; shift ;;
      --help|-h)
        cat <<'TUNE_HELP'
lattice claude-md-tune — manage the Lattice block in ~/.claude/CLAUDE.md

  --propose          (default) preview what would be written
  --apply            write the deterministic block, backing up the existing file
  --bootstrap        same as --apply but used during initial install
  --review-prompt    emit a structured prompt for the running Claude session
                     to review the current block
  --check            check if a trigger fired (3 releases since last tune OR
                     5+ unknown_subcommand events). Exit 1 if trigger fired.
  --auto             when LATTICE_AUTO_TUNE=1 and a trigger fired, apply.
                     Logs the diff to ~/.claude/lattice/claude-md-tune-history/.

Auto-tune is opt-in via LATTICE_AUTO_TUNE=1 for the first 30 days of
dogfooding. Without it, --auto reports the trigger but does not apply.
TUNE_HELP
        return 0 ;;
      -*)               die "claude-md-tune: unknown flag: $1" ;;
      *)                die "claude-md-tune: extra arg: $1" ;;
    esac
  done

  case "${mode}" in
    propose)
      echo "[${PROG}] claude-md-tune: would update ${_LATTICE_GLOBAL_MD}"
      echo "[${PROG}] block content preview ($(date -u +%Y-%m-%dT%H:%M:%SZ)):"
      echo ""
      _lattice_md_block
      echo ""
      echo "[${PROG}] apply this with: lattice claude-md-tune --apply"
      ;;
    apply|bootstrap)
      # v1.1.0 (#6): log the diff before applying, so history is auditable.
      local hist_dir="${HOME}/.claude/lattice/claude-md-tune-history"
      mkdir -p "${hist_dir}" 2>/dev/null || true
      local hist_ts="$(date -u +%Y%m%dT%H%M%SZ)"
      local hist_file="${hist_dir}/${hist_ts}.diff"
      local old_block="(no previous block)"
      if [ -f "${_LATTICE_GLOBAL_MD}" ] && grep -qF "${_LATTICE_MD_SENTINEL_START}" "${_LATTICE_GLOBAL_MD}" 2>/dev/null; then
        old_block="$(awk -v s="${_LATTICE_MD_SENTINEL_START}" -v e="${_LATTICE_MD_SENTINEL_END}" \
          'index($0,s)>0{p=1} p{print} index($0,e)>0{p=0; exit}' "${_LATTICE_GLOBAL_MD}")"
      fi
      local new_block
      new_block="$(_lattice_md_block)"
      {
        echo "# claude-md-tune diff — ${hist_ts}"
        echo "# mode: ${mode}"
        echo "# version: $(current_version)"
        echo "---"
        echo "## old"
        printf '%s\n' "${old_block}"
        echo "---"
        echo "## new"
        printf '%s\n' "${new_block}"
      } > "${hist_file}" 2>/dev/null || true

      _lattice_md_apply "${_LATTICE_GLOBAL_MD}" || die "claude-md-tune: write failed"
      # Record the version at which we tuned, so --check can detect "N releases
      # since last tune" without parsing the diff history.
      printf '%s\n' "$(current_version)" > "${hist_dir}/last-tune-version" 2>/dev/null || true
      printf '%s\n' "${hist_ts}" > "${hist_dir}/last-tune-timestamp" 2>/dev/null || true
      if [ "${mode}" = "apply" ]; then
        echo "[${PROG}] claude-md-tune: applied — restore via lattice claude-md-restore --list"
        echo "[${PROG}] diff logged: ${hist_file}"
      fi
      ;;
    check|auto)
      # v1.1.0 (#6): trigger detection.
      # Trigger A — release-driven: 3+ Lattice releases since last tune.
      # Trigger B — friction-driven: 5+ unknown_subcommand events since last tune.
      local hist_dir="${HOME}/.claude/lattice/claude-md-tune-history"
      local last_ver=""
      [ -f "${hist_dir}/last-tune-version" ] && last_ver="$(cat "${hist_dir}/last-tune-version")"
      local cur_ver
      cur_ver="$(current_version)"

      # Count releases between last_ver and cur_ver. Naive parse:
      # X.Y.Z -> integer (X*10000 + Y*100 + Z); diff >= 3 patch bumps triggers.
      _ver_int() {
        local v="$1" maj min pat
        v="${v#v}"; v="${v%%-*}"
        maj="${v%%.*}"; v="${v#*.}"
        min="${v%%.*}"; pat="${v#*.}"
        [ -z "${maj}" ] && maj=0; [ -z "${min}" ] && min=0; [ -z "${pat}" ] && pat=0
        echo $((maj * 10000 + min * 100 + pat))
      }
      local cur_int last_int delta_releases=99
      cur_int="$(_ver_int "${cur_ver}")"
      if [ -n "${last_ver}" ]; then
        last_int="$(_ver_int "${last_ver}")"
        delta_releases=$((cur_int - last_int))
      fi
      local trigger_release=0
      [ "${delta_releases}" -ge 3 ] && trigger_release=1

      # Count unknown_subcommand events in the global usage log since last tune
      local global_log="${HOME}/.claude/lattice/usage/global.jsonl"
      local unknown_count=0
      if [ -f "${global_log}" ] && command -v node >/dev/null 2>&1; then
        local since_ts="0"
        [ -f "${hist_dir}/last-tune-timestamp" ] && since_ts="$(cat "${hist_dir}/last-tune-timestamp")"
        unknown_count="$(node -e '
const fs = require("fs");
const [, log, sinceTs] = process.argv;
const since = sinceTs && sinceTs !== "0" ? Date.parse(
  sinceTs.replace(/T(\d{2})(\d{2})(\d{2})Z/, "T$1:$2:$3Z")
) : 0;
let n = 0;
try {
  for (const line of fs.readFileSync(log, "utf8").split("\n")) {
    if (!line) continue;
    let ev; try { ev = JSON.parse(line); } catch { continue; }
    if (ev.command !== "unknown_subcommand") continue;
    const ts = ev.ts ? Date.parse(ev.ts) : NaN;
    if (Number.isFinite(ts) && (since === 0 || ts >= since)) n++;
  }
} catch {}
process.stdout.write(String(n));
' "${global_log}" "${since_ts}" 2>/dev/null)"
        [ -z "${unknown_count}" ] && unknown_count=0
      fi
      local trigger_friction=0
      [ "${unknown_count}" -ge 5 ] && trigger_friction=1

      echo "[${PROG}] claude-md-tune --check:"
      echo "  current version:           ${cur_ver}"
      echo "  last tune version:         ${last_ver:-(never)}"
      echo "  releases since last tune:  ${delta_releases}  (triggers at 3+)"
      echo "  unknown_subcommand events: ${unknown_count}  (triggers at 5+)"

      if [ "${trigger_release}" -eq 0 ] && [ "${trigger_friction}" -eq 0 ]; then
        echo "  -> no trigger fired"
        return 0
      fi
      echo -n "  -> trigger fired:"
      [ "${trigger_release}" -eq 1 ] && echo -n " release"
      [ "${trigger_friction}" -eq 1 ] && echo -n " friction"
      echo ""

      if [ "${mode}" = "check" ]; then
        echo "  apply with:  lattice claude-md-tune --apply"
        echo "  or auto:     LATTICE_AUTO_TUNE=1 lattice claude-md-tune --auto"
        return 1
      fi
      # auto mode — only apply if LATTICE_AUTO_TUNE=1
      if [ "${LATTICE_AUTO_TUNE:-0}" != "1" ]; then
        echo "  LATTICE_AUTO_TUNE != 1 — reporting trigger but not applying."
        echo "  To enable auto-tune for the next 30 days of dogfooding:"
        echo "    export LATTICE_AUTO_TUNE=1"
        return 1
      fi
      # Recurse into apply mode (handles diff logging + last-tune-version stamp)
      cmd_claude_md_tune --apply
      ;;
    review-prompt)
      # Emit a structured prompt the running Claude session can act on:
      # read current block, read usage data, propose revisions, apply.
      local current usage_top friction_count
      if [ -f "${_LATTICE_GLOBAL_MD}" ] && grep -qF "${_LATTICE_MD_SENTINEL_START}" "${_LATTICE_GLOBAL_MD}"; then
        current="$(awk -v s="${_LATTICE_MD_SENTINEL_START}" -v e="${_LATTICE_MD_SENTINEL_END}" \
          'index($0,s)>0{p=1} p{print} index($0,e)>0{p=0; exit}' "${_LATTICE_GLOBAL_MD}")"
      else
        current="(no Lattice block found in ${_LATTICE_GLOBAL_MD})"
      fi
      usage_top="$(cmd_usage --global --json 2>/dev/null | head -20 || echo "(no usage data)")"
      friction_count="$(cmd_review --quiet 2>/dev/null || echo 0)"

      cat <<PROMPT
[lattice claude-md-tune --review-prompt]

You are the Claude session running on this machine. The global CLAUDE.md
contains a Lattice-managed onboarding block (shown below). Your task: read
it cold as if you were a new session at session start, then decide if it
should be revised.

## Current Lattice block
${current}

## Top Lattice commands by global usage
${usage_top}

## Friction candidates pending today
${friction_count} candidate(s) — run \`lattice review\` for details.

## Your task
1. If the block accurately reflects the most-used commands and current
   workflow, output: NO_CHANGE
2. If revisions would help (re-order commands by usage, surface friction
   patterns, drop stale entries, add new commands from recent releases),
   propose a revised block by running:
     lattice claude-md-tune --apply
   (the deterministic generator already incorporates current Lattice state)
3. Either way, log your decision to .lattice/claude-md-tune-history/.

Output your decision as one of: NO_CHANGE | REVISE | INSUFFICIENT_DATA
PROMPT
      ;;
  esac
}

# ---------------------------------------------------------------------------
# claude-md-restore (v0.9.10) — list / revert CLAUDE.md backups.
#
#   lattice claude-md-restore --list           # show available backups
#   lattice claude-md-restore <timestamp>      # revert to that backup
#   lattice claude-md-restore --latest         # revert to most recent backup
# ---------------------------------------------------------------------------
cmd_claude_md_restore() {
  if [ "$#" -eq 0 ]; then
    die "claude-md-restore: usage: lattice claude-md-restore [--list | --latest | <YYYYMMDDTHHMMSSZ>]"
  fi
  if [ ! -d "${_LATTICE_MD_BACKUP_DIR}" ]; then
    echo "[${PROG}] no backups (no ${_LATTICE_MD_BACKUP_DIR}/ directory)"
    return 0
  fi
  shopt -s nullglob
  local backups=("${_LATTICE_MD_BACKUP_DIR}"/CLAUDE.md.*)
  if [ "${#backups[@]}" -eq 0 ]; then
    echo "[${PROG}] no backups in ${_LATTICE_MD_BACKUP_DIR}/"
    return 0
  fi

  local action="$1"
  case "${action}" in
    --list)
      printf '%-22s  %s\n' "TIMESTAMP" "PATH"
      local b ts
      for b in "${backups[@]}"; do
        ts="$(basename "${b}" | sed 's/^CLAUDE\.md\.//')"
        printf '%-22s  %s\n' "${ts}" "${b}"
      done
      echo ""
      echo "[${PROG}] revert via: lattice claude-md-restore <timestamp>"
      echo "[${PROG}] latest:    lattice claude-md-restore --latest"
      ;;
    --latest)
      # Backups are sorted by name = timestamp; tail -1 = newest
      local latest="${backups[-1]}"
      _lattice_md_backup "${_LATTICE_GLOBAL_MD}" >/dev/null 2>&1
      cp "${latest}" "${_LATTICE_GLOBAL_MD}" || die "claude-md-restore: copy failed"
      echo "[${PROG}] restored ${_LATTICE_GLOBAL_MD} from ${latest}"
      ;;
    *)
      local target="${_LATTICE_MD_BACKUP_DIR}/CLAUDE.md.${action}"
      [ -f "${target}" ] || die "claude-md-restore: no backup at ${target}"
      _lattice_md_backup "${_LATTICE_GLOBAL_MD}" >/dev/null 2>&1
      cp "${target}" "${_LATTICE_GLOBAL_MD}" || die "claude-md-restore: copy failed"
      echo "[${PROG}] restored ${_LATTICE_GLOBAL_MD} from ${target}"
      ;;
  esac
}

# ---------------------------------------------------------------------------
# statusline (v0.9.14) — DEPRECATED no-op stub.
#
# Statusline is now served by scripts/lattice-statusline.mjs (Node.js).
# This bash entry point exists ONLY to fail-closed if any old settings.json
# config still points at `lattice statusline`. See CHANGELOG v0.9.14 for the
# orphan-bash.exe incident that motivated the rewrite.
# ---------------------------------------------------------------------------
cmd_statusline() {
  # v0.9.13 (Windows orphan-bash incident, 2026-05-16): the bash statusline
  # caused 12+ orphan bash.exe processes, 29% CPU, 77% RAM, 3 forced restarts
  # on the developer machine. Even with lock + cache + skip-list + non-blocking
  # stdin, bash startup is 1-3s on Windows + Git Bash; with Claude Code ticking
  # every ~2s, the math fundamentally does not work.
  #
  # Replaced by a Node.js statusline at scripts/lattice-statusline.mjs
  # (~85ms cold start, pure fs reads, zero subprocesses in hot path).
  #
  # This bash entry point is kept as a fast-exit shim so any wired-up
  # invocations from old settings.json blocks fail closed (no work, no orphans).
  return 0
}

# ---------------------------------------------------------------------------
# Project CLAUDE.md integration (v0.9.11).
#
# Same sentinel-managed pattern as v0.9.10 global, but scoped to <project>/
# CLAUDE.md and carrying STATE (not instructions). The global block tells the
# session WHAT Lattice is; the project block tells the session what's IN this
# project's Lattice right now: dimensions active, findings by tier, top-3 by
# priority, active ADRs, telemetry status.
#
# Auto-refreshed on lifecycle events (`lattice close`, `lattice decide`,
# `lattice invariants derive`). Opt-out via LATTICE_NO_PROJECT_SYNC=1.
#
# Strict boundaries (locked for v0.9.11 — DO NOT extend without measurement):
#   - counts + top-3 findings only (no full lists)
#   - state snapshot, NOT instructions (instructions live in global block)
#   - no cross-session memory writes (deferred to v0.9.12 if dogfood justifies)
#   - no AI-driven content rewrites (deterministic generator only)
# ---------------------------------------------------------------------------

# Echoes the project state block (no surrounding sentinels — caller wraps).
# Pure read of .lattice/ filesystem state. No network, no AI.
_lattice_project_md_block() {
  local cwd_name="${PWD##*/}"
  local generated_at
  generated_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

  # --- Mode + telemetry status -------------------------------------------
  local mode tel_status
  mode="$(cmd_mode 2>/dev/null || echo classic)"
  if _telemetry_enabled; then
    tel_status="ON (failures auto-file at IsaamMJ/Lattice)"
  else
    tel_status="OFF"
  fi

  # --- Active dimensions (read from existing findings, infer from
  # .lattice/findings/open/*.yml dimension fields) ------------------------
  local dimensions=""
  if [ -d .lattice/findings/open ]; then
    dimensions="$(shopt -s nullglob; for f in .lattice/findings/open/*.yml .lattice/findings/open/*/*.yml; do
      [ -f "${f}" ] || continue
      # yaml_field uses printf '%s' (no newline) so we must add one explicitly
      # to keep sort -u from collapsing all values into one run-on token.
      echo "$(yaml_field "${f}" "dimension")"
    done | sort -u | awk 'NF{ out=out (out?", ":"") $0 } END{ print out }')"
  fi
  [ -z "${dimensions}" ] && dimensions="(none yet)"

  # --- Findings by tier --------------------------------------------------
  local total=0
  declare -A by_tier=()
  shopt -s nullglob
  for f in .lattice/findings/open/*.yml .lattice/findings/open/*/*.yml; do
    [ -f "${f}" ] || continue
    total=$((total + 1))
    local t
    t="$(yaml_field "${f}" "tier")"
    by_tier["${t}"]=$(( ${by_tier["${t}"]:-0} + 1 ))
  done
  local tier_summary=""
  local tier
  for tier in CRITICAL BLOCKER HIGH RISK DRIFT MEDIUM WATCH LOW; do
    local n=${by_tier["${tier}"]:-0}
    if [ "${n}" -gt 0 ]; then
      [ -n "${tier_summary}" ] && tier_summary="${tier_summary}, "
      tier_summary="${tier_summary}${tier}: ${n}"
    fi
  done
  [ -z "${tier_summary}" ] && tier_summary="(none open)"

  # --- Top 3 by tier rank + sweep_date (oldest first within tier) --------
  local top3=""
  if [ "${total}" -gt 0 ]; then
    # Build "<tier-rank>|<sweep_date>|<slug>" rows then sort + take 3
    local rank
    while IFS= read -r row; do
      [ -z "${row}" ] && continue
      [ -n "${top3}" ] && top3="${top3}"$'\n'
      top3="${top3}- ${row}"
    done < <(
      shopt -s nullglob
      for f in .lattice/findings/open/*.yml .lattice/findings/open/*/*.yml; do
        [ -f "${f}" ] || continue
        local t sd slug
        t="$(yaml_field "${f}" "tier")"
        sd="$(yaml_field "${f}" "sweep_date")"
        slug="$(basename "${f}" .yml)"
        case "${t}" in
          CRITICAL) rank=1 ;; BLOCKER) rank=2 ;; HIGH) rank=3 ;;
          RISK)     rank=4 ;; DRIFT)   rank=5 ;; MEDIUM)  rank=6 ;;
          WATCH)    rank=7 ;; LOW)     rank=8 ;; *)       rank=9 ;;
        esac
        printf '%d|%s|%s\n' "${rank}" "${sd:-0000-00-00}" "${slug}"
      done \
      | sort \
      | head -3 \
      | awk -F'|' '{printf "%s %s (%s)\n", toupper(substr("CRITICALBLOCKERHIGHRISK DRIFTMEDIUMWATCHLOW",1,0)), $3, $2}' \
      | sed -E 's/^\s+//'
    )
  fi
  # Simpler top-3 builder (overwrite — the awk above was wrong; just emit slug + sweep_date)
  top3=""
  if [ "${total}" -gt 0 ]; then
    while IFS= read -r row; do
      [ -z "${row}" ] && continue
      [ -n "${top3}" ] && top3="${top3}"$'\n'
      top3="${top3}- ${row}"
    done < <(
      shopt -s nullglob
      for f in .lattice/findings/open/*.yml .lattice/findings/open/*/*.yml; do
        [ -f "${f}" ] || continue
        local t sd slug rank
        t="$(yaml_field "${f}" "tier")"
        sd="$(yaml_field "${f}" "sweep_date")"
        slug="$(basename "${f}" .yml)"
        case "${t}" in
          CRITICAL) rank=1 ;; BLOCKER) rank=2 ;; HIGH) rank=3 ;;
          RISK)     rank=4 ;; DRIFT)   rank=5 ;; MEDIUM)  rank=6 ;;
          WATCH)    rank=7 ;; LOW)     rank=8 ;; *)       rank=9 ;;
        esac
        printf '%d|%s|%s|%s\n' "${rank}" "${sd:-0000-00-00}" "${slug}" "${t}"
      done \
      | sort \
      | head -3 \
      | awk -F'|' '{printf "%s — %s (%s)\n", $4, $3, $2}'
    )
  fi
  [ -z "${top3}" ] && top3="- (no open findings)"

  # --- Active ADRs -------------------------------------------------------
  local adr_count=0
  local adr_list=""
  if [ -d .lattice/decisions ]; then
    while IFS= read -r line; do
      [ -z "${line}" ] && continue
      adr_count=$((adr_count + 1))
      [ "${adr_count}" -le 3 ] && adr_list="${adr_list}- ${line}"$'\n'
    done < <(
      shopt -s nullglob
      for d in .lattice/decisions/*.yml; do
        [ -f "${d}" ] || continue
        local st id_v title_v
        st="$(yaml_field "${d}" "status")"
        case "${st}" in
          active|in_progress) ;;
          *) continue ;;
        esac
        id_v="$(yaml_field "${d}" "id")"
        title_v="$(yaml_field "${d}" "title")"
        printf '%s — %s\n' "${id_v}" "${title_v}"
      done
    )
  fi

  # --- Render block (between sentinels — caller wraps) -------------------
  cat <<MDBLOCK
${_LATTICE_PROJECT_MD_SENTINEL_START}
<!-- managed by \`lattice project-sync\` — auto-refreshed on close/decide/derive -->
<!-- generated: ${generated_at}   project: ${cwd_name}   mode: ${mode} -->

## Lattice state (auto-synced)

- **Mode:** ${mode}
- **Telemetry:** ${tel_status}
- **Active dimensions:** ${dimensions}
- **Findings open (${total} total):** ${tier_summary}
- **Active ADRs:** ${adr_count}

### Top findings (by tier + age)
${top3}
$([ -n "${adr_list}" ] && printf '\n### Active decisions\n%s' "${adr_list}")
*Refresh: \`lattice project-sync\`. Suppress auto-sync: \`export LATTICE_NO_PROJECT_SYNC=1\`. Undo: \`lattice project-restore --list\`.*

${_LATTICE_PROJECT_MD_SENTINEL_END}
MDBLOCK
}

# Backup target file to .lattice/claude-md-backups/ with UTC timestamp.
_lattice_project_md_backup() {
  local target="$1"
  [ -f "${target}" ] || return 0
  mkdir -p "${_LATTICE_PROJECT_MD_BACKUP_DIR}" 2>/dev/null || return 1
  local ts backup_path
  ts="$(date -u +%Y%m%dT%H%M%SZ)"
  backup_path="${_LATTICE_PROJECT_MD_BACKUP_DIR}/CLAUDE.md.${ts}"
  cp "${target}" "${backup_path}" 2>/dev/null || return 1
  echo "${backup_path}"
}

# Idempotently insert/replace the project block in <project>/CLAUDE.md.
_lattice_project_md_apply() {
  local target="${1:-CLAUDE.md}"
  local quiet="${2:-0}"
  # Backup first (only if file exists)
  local backup
  backup="$(_lattice_project_md_backup "${target}")"
  if [ -n "${backup}" ] && [ "${quiet}" != "1" ]; then
    echo "[${PROG}] backed up to ${backup}" >&2
  fi

  local new_block
  new_block="$(_lattice_project_md_block)"

  if [ ! -f "${target}" ]; then
    {
      printf '%s\n' "${new_block}"
    } > "${target}"
    [ "${quiet}" != "1" ] && echo "[${PROG}] created ${target} with Lattice project block" >&2
    return 0
  fi

  if grep -qF "${_LATTICE_PROJECT_MD_SENTINEL_START}" "${target}"; then
    local tmp
    tmp="$(mktemp)" || return 1
    awk -v start="${_LATTICE_PROJECT_MD_SENTINEL_START}" \
        -v end="${_LATTICE_PROJECT_MD_SENTINEL_END}" \
        -v block="${new_block}" '
      BEGIN { in_block=0; replaced=0 }
      {
        if (index($0, start) > 0 && !in_block) {
          in_block=1
          if (!replaced) { print block; replaced=1 }
          next
        }
        if (in_block) {
          if (index($0, end) > 0) { in_block=0 }
          next
        }
        print
      }
    ' "${target}" > "${tmp}"
    mv "${tmp}" "${target}"
    [ "${quiet}" != "1" ] && echo "[${PROG}] refreshed Lattice project block in ${target}" >&2
  else
    # No sentinels — APPEND block at bottom (project CLAUDE.md usually has
    # project-specific rules at top; auto-state block belongs after).
    local tmp
    tmp="$(mktemp)" || return 1
    {
      cat "${target}"
      printf '\n%s\n' "${new_block}"
    } > "${tmp}"
    mv "${tmp}" "${target}"
    [ "${quiet}" != "1" ] && echo "[${PROG}] appended Lattice project block to ${target}" >&2
  fi
  return 0
}

# Internal: called by lifecycle commands (close, decide, derive) for auto-sync.
# Silent unless something fails. Respects LATTICE_NO_PROJECT_SYNC=1 opt-out.
_lattice_project_sync_auto() {
  case "${LATTICE_NO_PROJECT_SYNC:-0}" in
    1|on|true|yes) return 0 ;;
  esac
  # Only sync if there's already a project CLAUDE.md (don't surprise-create on
  # first close). Initial creation must be opt-in via `lattice project-init`.
  [ -f CLAUDE.md ] || return 0
  # Only sync if .lattice/ exists (sanity)
  [ -d .lattice ] || return 0
  _lattice_project_md_apply "CLAUDE.md" "1" >/dev/null 2>&1 || true
}

cmd_project_init() {
  local force=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --force) force=1; shift ;;
      -*)      die "project-init: unknown flag: $1" ;;
      *)       die "project-init: extra arg: $1" ;;
    esac
  done
  [ -d .lattice ] || die "project-init: no .lattice/ in cwd. Run 'lattice doctor' first to bootstrap."
  if [ -f CLAUDE.md ] && grep -qF "${_LATTICE_PROJECT_MD_SENTINEL_START}" CLAUDE.md && [ "${force}" -ne 1 ]; then
    echo "[${PROG}] project-init: CLAUDE.md already has Lattice project block. Use --force to refresh, or run 'lattice project-sync'."
    return 0
  fi
  _lattice_project_md_apply "CLAUDE.md" "0"
  echo "[${PROG}] project-init: done. Subsequent close/decide/derive will auto-refresh the block."
  echo "[${PROG}] opt out of auto-sync: export LATTICE_NO_PROJECT_SYNC=1"
}

cmd_project_sync() {
  while [ "$#" -gt 0 ]; do
    case "$1" in
      -*) die "project-sync: unknown flag: $1" ;;
      *)  die "project-sync: extra arg: $1" ;;
    esac
  done
  [ -d .lattice ] || die "project-sync: no .lattice/ in cwd."
  [ -f CLAUDE.md ] || die "project-sync: no CLAUDE.md in cwd. Run 'lattice project-init' first to create one."
  if ! grep -qF "${_LATTICE_PROJECT_MD_SENTINEL_START}" CLAUDE.md; then
    die "project-sync: CLAUDE.md exists but has no Lattice project block. Run 'lattice project-init' first."
  fi
  _lattice_project_md_apply "CLAUDE.md" "0"
}

cmd_project_restore() {
  if [ "$#" -eq 0 ]; then
    die "project-restore: usage: lattice project-restore [--list | --latest | <YYYYMMDDTHHMMSSZ>]"
  fi
  if [ ! -d "${_LATTICE_PROJECT_MD_BACKUP_DIR}" ]; then
    echo "[${PROG}] no project backups (no ${_LATTICE_PROJECT_MD_BACKUP_DIR}/ directory)"
    return 0
  fi
  shopt -s nullglob
  local backups=("${_LATTICE_PROJECT_MD_BACKUP_DIR}"/CLAUDE.md.*)
  if [ "${#backups[@]}" -eq 0 ]; then
    echo "[${PROG}] no project backups in ${_LATTICE_PROJECT_MD_BACKUP_DIR}/"
    return 0
  fi
  local action="$1"
  case "${action}" in
    --list)
      printf '%-22s  %s\n' "TIMESTAMP" "PATH"
      local b ts
      for b in "${backups[@]}"; do
        ts="$(basename "${b}" | sed 's/^CLAUDE\.md\.//')"
        printf '%-22s  %s\n' "${ts}" "${b}"
      done
      ;;
    --latest)
      local latest="${backups[-1]}"
      _lattice_project_md_backup "CLAUDE.md" >/dev/null 2>&1
      cp "${latest}" "CLAUDE.md" || die "project-restore: copy failed"
      echo "[${PROG}] restored CLAUDE.md from ${latest}"
      ;;
    *)
      local target="${_LATTICE_PROJECT_MD_BACKUP_DIR}/CLAUDE.md.${action}"
      [ -f "${target}" ] || die "project-restore: no backup at ${target}"
      _lattice_project_md_backup "CLAUDE.md" >/dev/null 2>&1
      cp "${target}" "CLAUDE.md" || die "project-restore: copy failed"
      echo "[${PROG}] restored CLAUDE.md from ${target}"
      ;;
  esac
}

# ---------------------------------------------------------------------------
# audit-env-contract — env-contract dimension scanner (v0.9.9, closes #31).
#
# Detects env-var fallback patterns across Node/TS, Python, and Dart. Classifies
# each finding by fallback-value plausibility (HIGH/MED/LOW) so the audit stays
# signal-rich instead of being tuned out as noise. Optional cross-check against
# a checked-in `docs/env.contract.md` file emits DRIFT-env-not-in-contract for
# any env var referenced in code but missing from the contract.
#
# Designed to be invoked BY the `/audit-sweep` skill, NOT typed by humans —
# this is a sweep dimension, not a standalone tool. Survival depends on living
# inside a habit-loop (audit-sweep already gets 1000+ invocations/month).
#
# Usage:
#   lattice audit-env-contract [--path .] [--write]
#     (no --write: prints findings to stdout; --write emits YAML to
#      .lattice/findings/open/<slug>.yml for the lifecycle to pick up)
#
# Patterns detected (five families):
#   1. process.env.X || 'literal'              # JS/TS, the canonical case
#   2. process.env.X ?? 'literal'              # JS/TS strict-mode TS
#   3. const { X = 'literal' } = process.env   # JS/TS destructured defaults
#   4. getEnv('X', 'literal') / env('X', ...)  # helper-wrapped patterns
#   5. os.environ.get('X', 'literal')          # Python
#   6. String.fromEnvironment('X', defaultValue: 'literal')  # Dart
#
# Classification heuristic (tunable via _env_plausibility_tier):
#   LOW    sane dev defaults — '3000', 'localhost', '', '0', 'false', 'info', ...
#   MEDIUM placeholder shapes — 'TODO', 'changeme', '<...>', 'REPLACE_ME', ...
#   HIGH   anything else — looks domain-specific, probably catastrophic if real
#
# Heuristic errs on alarm: better 3 HIGH false-positives than 1 missed disaster.
# Allowlist for LOW grows as real usage tells us what's fine.
# ---------------------------------------------------------------------------
_env_plausibility_tier() {
  # Echoes LOW/MEDIUM/HIGH based on fallback-literal shape.
  local v="$1"
  # Strip surrounding quotes
  v="${v#\'}"; v="${v%\'}"
  v="${v#\"}"; v="${v%\"}"
  # Empty / unset / common dev defaults => LOW
  case "${v}" in
    ""|" "|"unset"|"none"|"null"|"undefined") echo "LOW"; return ;;
    "localhost"|"127.0.0.1"|"0.0.0.0") echo "LOW"; return ;;
    "true"|"false"|"yes"|"no"|"on"|"off") echo "LOW"; return ;;
    "0"|"1") echo "LOW"; return ;;
    "development"|"dev"|"local"|"test"|"production") echo "LOW"; return ;;
    "info"|"debug"|"warn"|"warning"|"error"|"trace"|"verbose"|"silent") echo "LOW"; return ;;
    "GET"|"POST"|"PUT"|"DELETE"|"PATCH") echo "LOW"; return ;;
  esac
  # Pure digit string (ports, counts, timeouts) => LOW
  if [[ "${v}" =~ ^[0-9]+$ ]]; then echo "LOW"; return; fi
  # Common placeholder shapes => MEDIUM
  case "${v}" in
    TODO|todo|Todo|FIXME|fixme|changeme|CHANGEME|placeholder|PLACEHOLDER) echo "MEDIUM"; return ;;
    REPLACE|REPLACE_ME|replace-me|your-key|YOUR_KEY|your-secret|YOUR_SECRET) echo "MEDIUM"; return ;;
  esac
  if [[ "${v}" == \<*\> ]]; then echo "MEDIUM"; return; fi  # <your-key> shape
  if [[ "${v}" == *placeholder* ]] || [[ "${v}" == *PLACEHOLDER* ]]; then echo "MEDIUM"; return; fi
  # Default: looks real => HIGH
  echo "HIGH"
}

_env_emit_finding() {
  # args: tier, env_key, fallback_value, file, line, write_mode, slug_seq
  local tier="$1" key="$2" fallback="$3" file="$4" line="$5" write="$6" seq="$7"
  # v2.1.2 (#68): defensive sanitization. Regex capture from minified bundles
  # (ora spinners.json was the original trigger) can leak binary content into
  # ${key}, causing filename-too-long when composed into the slug. Strip to
  # valid env-var chars and cap at 60.
  key="$(printf '%s' "${key}" | tr -cd 'A-Z0-9_' | head -c 60)"
  if [ -z "${key}" ]; then
    # Refuse to emit a finding without a real key
    return 0
  fi
  local slug="${tier}-env-fallback-${key}"
  # If multiple findings share the same key+tier (e.g. two callsites), suffix.
  [ "${seq}" -gt 0 ] && slug="${slug}-${seq}"
  local short_fb="${fallback//\'/}"; short_fb="${short_fb//\"/}"
  local short_fb_display="${short_fb}"
  [ "${#short_fb}" -gt 30 ] && short_fb_display="${short_fb:0:27}..."
  if [ "${write}" != "1" ]; then
    printf '%-7s %-30s %-15s %s:%s\n' "${tier}" "${key}" "[${short_fb_display}]" "${file}" "${line}"
    return 0
  fi
  ensure_project_dirs
  mkdir -p .lattice/findings/open
  local dest=".lattice/findings/open/${slug}.yml"
  local now today
  now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  today="$(date -u +%Y-%m-%d)"
  local sweep_id="${LATTICE_SWEEP_ID:-$(date -u +%Y%m%d)$(printf '%06x' "$$" | tail -c6)}"
  # Escape body content for safe YAML quoting
  local esc_fb="${fallback//\\/\\\\}"
  esc_fb="${esc_fb//\"/\\\"}"
  cat > "${dest}" <<YML
id: ${slug}-id
rule: env-fallback
dimension: env-contract
tier: ${tier}
module: $(dirname "${file}")
file: ${file}
line: ${line}
title: "env var ${key} silently falls back to ${short_fb_display}"
fix: "make ${key} required at startup or use a validation lib (zod/joi/pydantic); fallback hides missing config until it bites in prod"
env_key: "${key}"
fallback_value: "${esc_fb}"
verify_pattern: "process\\\\.env\\\\.${key}\\\\s*(\\\\|\\\\||\\\\?\\\\?)"
verify_file: "${file}"
sweep_date: ${today}
sweep_id: ${sweep_id}
auditor: lattice/audit-env-contract@0.9.9
status: open
exposure: code-time
detected_at: ${now}
YML
  echo "[${PROG}] emitted: ${dest}" >&2
}

cmd_audit_env_contract() {
  local target_path="."
  local write=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --path)  target_path="$2"; shift 2 ;;
      --write) write=1; shift ;;
      -*)      die "audit-env-contract: unknown flag: $1" ;;
      *)       die "audit-env-contract: extra arg: $1" ;;
    esac
  done
  [ -d "${target_path}" ] || die "audit-env-contract: path not found: ${target_path}"

  if [ "${write}" -ne 1 ]; then
    printf '%-7s %-30s %-15s %s\n' "TIER" "ENV_KEY" "FALLBACK" "LOCATION"
  fi

  # Track key+tier counts so multiple callsites get suffix slugs without
  # colliding on filename when --write is set.
  declare -A seq_by_slug=()
  local found=0

  _process_match() {
    local file="$1" line="$2" key="$3" fallback="$4"
    [ -z "${key}" ] && return 0
    [ -z "${fallback}" ] && return 0
    local tier
    tier="$(_env_plausibility_tier "${fallback}")"
    local sk="${tier}-${key}"
    local seq="${seq_by_slug[${sk}]:-0}"
    _env_emit_finding "${tier}" "${key}" "${fallback}" "${file}" "${line}" "${write}" "${seq}"
    seq_by_slug["${sk}"]=$((seq + 1))
    found=$((found + 1))
  }

  # --- Pattern 1+2: process.env.X || 'lit' / process.env.X ?? 'lit' --------
  while IFS=: read -r file line rest; do
    [ -z "${file}" ] && continue
    # rest could look like: `const x = process.env.FOO || 'bar';`
    # Extract key (after process.env.) and fallback (after || or ??)
    local key fallback
    key="$(printf '%s' "${rest}" | sed -nE "s/.*process\\.env\\.([A-Z][A-Z0-9_]*).*/\\1/p")"
    fallback="$(printf '%s' "${rest}" | sed -nE "s/.*process\\.env\\.[A-Z][A-Z0-9_]*[[:space:]]*(\\|\\||\\?\\?)[[:space:]]*((['\"][^'\"]*['\"])).*/\\2/p")"
    [ -n "${key}" ] && [ -n "${fallback}" ] && _process_match "${file}" "${line}" "${key}" "${fallback}"
  done < <(grep -REn "process\.env\.[A-Z][A-Z0-9_]*[[:space:]]*(\|\||\?\?)[[:space:]]*['\"]" \
            --include='*.js' --include='*.ts' --include='*.tsx' --include='*.jsx' \
            --include='*.mjs' --include='*.cjs' \
            --exclude-dir=node_modules --exclude-dir=.git --exclude-dir=dist \
            --exclude-dir=build --exclude-dir=.next --exclude-dir=coverage \
            --exclude-dir=vendor --exclude-dir=.lattice \
            "${target_path}" 2>/dev/null)

  # --- Pattern 3: const { X = 'lit' } = process.env -----------------------
  # Anchor matches INSIDE `{...}` braces so we don't accidentally grab the
  # `env` token from `process.env` as the key (greedy-regex foot-gun caught
  # in v0.9.9 smoke-test on `const { API_TOKEN = 'TODO' } = process.env`).
  while IFS=: read -r file line rest; do
    [ -z "${file}" ] && continue
    local key fallback inside
    # Extract the contents of the {...} block first
    inside="$(printf '%s' "${rest}" | sed -nE "s/.*\{([^}]*)\}[[:space:]]*=[[:space:]]*process\\.env.*/\\1/p")"
    [ -z "${inside}" ] && continue
    # Anchor at the start of `inside` (the {...} body) so leading greedy `.*`
    # doesn't grab the trailing letters of an earlier word as the key.
    # Caught on `const { API_TOKEN = 'TODO' } = process.env` where the loose
    # regex was returning `EN` (last 2 chars of `process.env`).
    key="$(printf '%s' "${inside}" | sed -nE "s/^[[:space:]]*([A-Z][A-Z0-9_]+)[[:space:]]*=[[:space:]]*['\"][^'\"]*['\"].*/\\1/p")"
    fallback="$(printf '%s' "${inside}" | sed -nE "s/^[[:space:]]*[A-Z][A-Z0-9_]+[[:space:]]*=[[:space:]]*(['\"][^'\"]*['\"]).*/\\1/p")"
    [ -n "${key}" ] && [ -n "${fallback}" ] && _process_match "${file}" "${line}" "${key}" "${fallback}"
  done < <(grep -REn "\{[^}]*[A-Z][A-Z0-9_]+[[:space:]]*=[[:space:]]*['\"][^'\"]*['\"][^}]*\}[[:space:]]*=[[:space:]]*process\.env" \
            --include='*.js' --include='*.ts' --include='*.tsx' --include='*.jsx' \
            --exclude-dir=node_modules --exclude-dir=.git --exclude-dir=dist \
            --exclude-dir=build --exclude-dir=.next --exclude-dir=coverage \
            --exclude-dir=vendor --exclude-dir=.lattice \
            "${target_path}" 2>/dev/null)

  # --- Pattern 5: os.environ.get('X', 'lit') ------------------------------
  while IFS=: read -r file line rest; do
    [ -z "${file}" ] && continue
    local key fallback
    key="$(printf '%s' "${rest}" | sed -nE "s/.*os\\.environ\\.get\\([[:space:]]*['\"]([A-Z][A-Z0-9_]*)['\"][[:space:]]*,[[:space:]]*['\"][^'\"]*['\"].*/\\1/p")"
    fallback="$(printf '%s' "${rest}" | sed -nE "s/.*os\\.environ\\.get\\([[:space:]]*['\"][A-Z][A-Z0-9_]*['\"][[:space:]]*,[[:space:]]*(['\"][^'\"]*['\"]).*/\\1/p")"
    [ -n "${key}" ] && [ -n "${fallback}" ] && _process_match "${file}" "${line}" "${key}" "${fallback}"
  done < <(grep -REn "os\.environ\.get\([[:space:]]*['\"][A-Z][A-Z0-9_]*['\"][[:space:]]*,[[:space:]]*['\"]" \
            --include='*.py' \
            --exclude-dir=node_modules --exclude-dir=.git --exclude-dir=dist \
            --exclude-dir=build --exclude-dir=__pycache__ --exclude-dir=.venv \
            --exclude-dir=venv --exclude-dir=vendor --exclude-dir=.lattice \
            "${target_path}" 2>/dev/null)

  # --- Pattern 6: String.fromEnvironment('X', defaultValue: 'lit') -------
  while IFS=: read -r file line rest; do
    [ -z "${file}" ] && continue
    local key fallback
    key="$(printf '%s' "${rest}" | sed -nE "s/.*String\\.fromEnvironment\\([[:space:]]*['\"]([A-Z][A-Z0-9_]*)['\"].*/\\1/p")"
    fallback="$(printf '%s' "${rest}" | sed -nE "s/.*defaultValue:[[:space:]]*(['\"][^'\"]*['\"]).*/\\1/p")"
    [ -n "${key}" ] && [ -n "${fallback}" ] && _process_match "${file}" "${line}" "${key}" "${fallback}"
  done < <(grep -REn "String\.fromEnvironment\([[:space:]]*['\"][A-Z][A-Z0-9_]*['\"].*defaultValue" \
            --include='*.dart' \
            --exclude-dir=.dart_tool --exclude-dir=build --exclude-dir=.git \
            --exclude-dir=vendor --exclude-dir=.lattice \
            "${target_path}" 2>/dev/null)

  # --- Contract-file cross-check (optional, only if docs/env.contract.md
  #     exists). Emits DRIFT-env-not-in-contract findings for any env var
  #     referenced in code but missing from the contract. Cheap, very-high
  #     signal when the contract file exists. Skipped silently when absent.
  if [ -f "${target_path}/docs/env.contract.md" ]; then
    local contract_keys
    contract_keys="$(grep -oE '\b[A-Z][A-Z0-9_]+\b' "${target_path}/docs/env.contract.md" 2>/dev/null | sort -u)"
    local code_keys
    code_keys="$(grep -REho \
                 --exclude-dir=node_modules --exclude-dir=.git --exclude-dir=dist \
                 --exclude-dir=build --exclude-dir=.next --exclude-dir=coverage \
                 --exclude-dir=vendor --exclude-dir=.lattice --exclude-dir=__pycache__ \
                 --exclude-dir=.venv --exclude-dir=venv --exclude-dir=.dart_tool \
                 '\bprocess\.env\.[A-Z][A-Z0-9_]+|os\.environ\.get\(['\''"][A-Z][A-Z0-9_]+|String\.fromEnvironment\(['\''"][A-Z][A-Z0-9_]+' \
                 --include='*.js' --include='*.ts' --include='*.tsx' --include='*.jsx' --include='*.py' --include='*.dart' \
                 "${target_path}" 2>/dev/null \
                 | sed -E 's/.*[\.\(]['\''"]?([A-Z][A-Z0-9_]+).*/\1/' \
                 | sort -u)"
    if [ -n "${code_keys}" ]; then
      local k
      while IFS= read -r k; do
        # v2.1.2 (#68): same sanitization as _env_emit_finding
        k="$(printf '%s' "${k}" | tr -cd 'A-Z0-9_' | head -c 60)"
        [ -z "${k}" ] && continue
        if ! printf '%s\n' "${contract_keys}" | grep -qFx "${k}"; then
          # Emit DRIFT finding
          if [ "${write}" -eq 1 ]; then
            ensure_project_dirs
            mkdir -p .lattice/findings/open
            local drift_slug="DRIFT-env-not-in-contract-${k}"
            local drift_dest=".lattice/findings/open/${drift_slug}.yml"
            local today; today="$(date -u +%Y-%m-%d)"
            local sweep_id="${LATTICE_SWEEP_ID:-$(date -u +%Y%m%d)$(printf '%06x' "$$" | tail -c6)}"
            cat > "${drift_dest}" <<YML
id: ${drift_slug}-id
rule: env-not-in-contract
dimension: env-contract
tier: DRIFT
module: env
file: docs/env.contract.md
line: 1
title: "env var ${k} referenced in code but missing from docs/env.contract.md"
fix: "add ${k} to docs/env.contract.md with its source-of-truth + required/optional + default policy, OR remove the code reference"
env_key: "${k}"
sweep_date: ${today}
sweep_id: ${sweep_id}
auditor: lattice/audit-env-contract@0.9.9
status: open
exposure: contract-drift
YML
            echo "[${PROG}] emitted: ${drift_dest} (DRIFT — env-not-in-contract)" >&2
          else
            printf '%-7s %-30s %-15s %s\n' "DRIFT" "${k}" "[not-in-contract]" "docs/env.contract.md"
          fi
          found=$((found + 1))
        fi
      done <<< "${code_keys}"
    fi
  fi

  if [ "${write}" -eq 1 ]; then
    echo "[${PROG}] audit-env-contract: ${found} finding(s) written to .lattice/findings/open/"
  else
    [ "${found}" -eq 0 ] && echo "[${PROG}] audit-env-contract: 0 findings (no env-var fallback patterns matched)"
  fi
  return 0
}

# ---------------------------------------------------------------------------
# wire-hooks — idempotently merge Lattice hooks + statusLine into
# ~/.claude/settings.json. v0.9.18 (#39). Replaces the
# "install.sh prints snippet, user pastes" friction. Dry-run by default;
# --apply writes after y/N confirm (--yes auto-confirms); always backs up;
# refuses to apply if settings.json is malformed.
#
# Usage:
#   lattice wire-hooks [--apply] [--yes] [--session-start] [--statusline]
#   lattice wire-hooks --restore <timestamp>
#
# Defaults: dry-run, wires SessionStart + statusLine.
# ---------------------------------------------------------------------------
cmd_wire_hooks() {
  local apply=0 auto_yes=0 want_session=1 want_status=1 want_stop=1 restore=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --apply)         apply=1; shift ;;
      --yes|-y)        auto_yes=1; shift ;;
      --session-start) want_status=0; want_stop=0; shift ;;
      --statusline)    want_session=0; want_stop=0; shift ;;
      --stop)          want_session=0; want_status=0; shift ;;  # v1.3.0 (#40)
      --no-stop)       want_stop=0; shift ;;
      --restore)       [ -z "${2:-}" ] && die "wire-hooks: --restore requires a timestamp"
                       restore="$2"; shift 2 ;;
      --help|-h)
        cat <<'WHHELP'
lattice wire-hooks — wire Lattice into ~/.claude/settings.json

  --apply             write after confirmation (default: dry-run preview)
  --yes               auto-confirm (use with --apply)
  --session-start     wire only the SessionStart hook
  --statusline        wire only the statusLine
  --stop              wire only the Stop hook (friction catch-net, #40)
  --no-stop           skip the Stop hook when wiring everything else
  --restore <ts>      restore from backup (timestamp from a previous run)

Always backs up to ~/.claude/settings.json.lattice-backup-<UTC-timestamp>
before any mutation. Refuses to apply if existing JSON is malformed.
Idempotent: detects existing Lattice wiring and exits clean.
WHHELP
        return 0 ;;
      -*) die "wire-hooks: unknown flag: $1" ;;
      *)  die "wire-hooks: extra arg: $1" ;;
    esac
  done

  local settings="${HOME}/.claude/settings.json"
  command -v node >/dev/null 2>&1 || die "wire-hooks: node required (settings.json is JSON; bash JSON munging unsafe)"

  # Resolve the absolute path to this script's directory — used for the hook
  # command paths so settings.json points at the installed location.
  local script_dir
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
  local session_path="${script_dir}/lattice-session-start.mjs"
  local statusline_path="${script_dir}/lattice-statusline.mjs"
  local stop_path="${script_dir}/lattice-stop.mjs"

  # Restore path: short-circuit before any other work.
  if [ -n "${restore}" ]; then
    local backup="${settings}.lattice-backup-${restore}"
    [ -f "${backup}" ] || die "wire-hooks: backup not found: ${backup}"
    if [ "${auto_yes}" -ne 1 ]; then
      printf "[${PROG}] restore %s -> %s? [y/N] " "${backup}" "${settings}"
      read -r ans
      case "${ans}" in y|Y|yes|YES) ;; *) echo "[${PROG}] aborted"; return 0 ;; esac
    fi
    cp -f "${backup}" "${settings}" || die "wire-hooks: restore copy failed"
    echo "[${PROG}] restored ${settings} from ${backup}"
    return 0
  fi

  mkdir -p "$(dirname "${settings}")" 2>/dev/null || true
  [ -f "${settings}" ] || echo "{}" > "${settings}"

  # Hand off to Node for JSON parse/merge/serialize. The script outputs:
  #   first line: STATUS=<noop|wired|malformed>
  #   subsequent lines: the diff or rendered settings.json
  local out
  out="$(node - "$settings" "$session_path" "$statusline_path" "$stop_path" "$want_session" "$want_status" "$want_stop" "$apply" <<'NODEJS'
const fs = require('fs');
const [,, settingsPath, sessionPath, statuslinePath, stopPath, wantSessionStr, wantStatusStr, wantStopStr, applyStr] = process.argv;
const wantSession = wantSessionStr === '1';
const wantStatus = wantStatusStr === '1';
const wantStop = wantStopStr === '1';
const apply = applyStr === '1';

let raw;
try { raw = fs.readFileSync(settingsPath, 'utf8'); }
catch (e) { console.log('STATUS=malformed'); console.log('cannot read: ' + e.message); process.exit(2); }
let cfg;
try { cfg = raw.trim() === '' ? {} : JSON.parse(raw); }
catch (e) { console.log('STATUS=malformed'); console.log('JSON parse error: ' + e.message); process.exit(2); }

const sentinel = (p) => p.endsWith('lattice-session-start.mjs') || p.endsWith('lattice-statusline.mjs') || p.endsWith('lattice-stop.mjs');
const sessionCmd = `node ${sessionPath}`;
const statuslineCmd = `node ${statuslinePath}`;
const stopCmd = `node ${stopPath}`;

let changed = false;
const before = JSON.stringify(cfg, null, 2);

if (wantSession) {
  cfg.hooks ??= {};
  cfg.hooks.SessionStart ??= [];
  // Strip any existing Lattice SessionStart entries first (idempotent re-wire).
  cfg.hooks.SessionStart = cfg.hooks.SessionStart.filter(group => {
    if (!group || !Array.isArray(group.hooks)) return true;
    return !group.hooks.some(h => h && typeof h.command === 'string' && sentinel(h.command));
  });
  cfg.hooks.SessionStart.push({
    hooks: [{ type: 'command', command: sessionCmd }],
  });
}

if (wantStatus) {
  const existing = cfg.statusLine;
  // Replace only if missing OR if it points at a lattice-statusline.mjs already
  // (idempotent). Don't clobber a user's unrelated statusline.
  if (!existing || (existing.command && sentinel(existing.command))) {
    cfg.statusLine = { type: 'command', command: statuslineCmd };
  } else {
    console.log('STATUS=conflict');
    console.log('existing statusLine is not Lattice; refusing to overwrite. Current command:');
    console.log('  ' + (existing.command || JSON.stringify(existing)));
    console.log('Remove it manually, or re-run with --session-start to skip statusLine.');
    process.exit(3);
  }
}

// v1.3.0 (#40): Stop hook for friction catch-net
if (wantStop) {
  cfg.hooks ??= {};
  cfg.hooks.Stop ??= [];
  cfg.hooks.Stop = cfg.hooks.Stop.filter(group => {
    if (!group || !Array.isArray(group.hooks)) return true;
    return !group.hooks.some(h => h && typeof h.command === 'string' && sentinel(h.command));
  });
  cfg.hooks.Stop.push({
    hooks: [{ type: 'command', command: stopCmd }],
  });
}

const after = JSON.stringify(cfg, null, 2);
changed = before !== after;

if (!changed) {
  console.log('STATUS=noop');
  console.log('Lattice already wired in ' + settingsPath);
  process.exit(0);
}

console.log('STATUS=wired');
console.log('--- diff (preview)');
console.log('would write:');
console.log(after);

if (apply) {
  const ts = new Date().toISOString().replace(/[:.]/g, '-');
  const backup = settingsPath + '.lattice-backup-' + ts;
  fs.copyFileSync(settingsPath, backup);
  fs.writeFileSync(settingsPath, after + '\n', 'utf8');
  console.log('--- applied');
  console.log('backup: ' + backup);
  console.log('written: ' + settingsPath);
}
NODEJS
)" || {
    rc=$?
    echo "${out}"
    case "${rc}" in
      2) die "wire-hooks: settings.json is malformed — fix or delete it, then re-run" ;;
      3) die "wire-hooks: existing statusLine conflict (see message above)" ;;
      *) die "wire-hooks: node helper exited ${rc}" ;;
    esac
  }

  # v1.4.2 (#58): same defensive init as _mcp_setup — set -u + pipefail
  local status="" body=""
  status="$(printf '%s\n' "${out:-}" | head -1 | sed -E 's/^STATUS=//' || true)"
  body="$(printf '%s\n' "${out:-}" | tail -n +2 || true)"

  case "${status}" in
    noop)
      echo "[${PROG}] wire-hooks: already wired — no changes needed"
      return 0
      ;;
    wired)
      echo "${body}"
      if [ "${apply}" -ne 1 ]; then
        echo ""
        echo "[${PROG}] wire-hooks: DRY RUN — re-run with --apply to write"
        return 0
      fi
      if [ "${auto_yes}" -ne 1 ]; then
        printf "[${PROG}] write changes to %s? [y/N] " "${settings}"
        read -r ans
        case "${ans}" in y|Y|yes|YES) ;; *) echo "[${PROG}] aborted"; return 0 ;; esac
      fi
      # Re-run with apply=1 (the dry-run above didn't actually write because
      # node sees apply=0 if confirmation was needed). Force apply now:
      node - "$settings" "$session_path" "$statusline_path" "$stop_path" "$want_session" "$want_status" "$want_stop" "1" <<'NODEJS_APPLY' >/dev/null
const fs = require('fs');
const [,, settingsPath, sessionPath, statuslinePath, stopPath, wantSessionStr, wantStatusStr, wantStopStr] = process.argv;
const wantSession = wantSessionStr === '1';
const wantStatus = wantStatusStr === '1';
const wantStop = wantStopStr === '1';
const raw = fs.readFileSync(settingsPath, 'utf8');
const cfg = raw.trim() === '' ? {} : JSON.parse(raw);
const sentinel = (p) => p.endsWith('lattice-session-start.mjs') || p.endsWith('lattice-statusline.mjs') || p.endsWith('lattice-stop.mjs');
if (wantSession) {
  cfg.hooks ??= {};
  cfg.hooks.SessionStart ??= [];
  cfg.hooks.SessionStart = cfg.hooks.SessionStart.filter(g => !(g && Array.isArray(g.hooks) && g.hooks.some(h => h && typeof h.command === 'string' && sentinel(h.command))));
  cfg.hooks.SessionStart.push({ hooks: [{ type: 'command', command: `node ${sessionPath}` }] });
}
if (wantStop) {
  cfg.hooks ??= {};
  cfg.hooks.Stop ??= [];
  cfg.hooks.Stop = cfg.hooks.Stop.filter(g => !(g && Array.isArray(g.hooks) && g.hooks.some(h => h && typeof h.command === 'string' && sentinel(h.command))));
  cfg.hooks.Stop.push({ hooks: [{ type: 'command', command: `node ${stopPath}` }] });
}
if (wantStatus) {
  const ex = cfg.statusLine;
  if (!ex || (ex.command && sentinel(ex.command))) {
    cfg.statusLine = { type: 'command', command: `node ${statuslinePath}` };
  }
}
const ts = new Date().toISOString().replace(/[:.]/g, '-');
fs.copyFileSync(settingsPath, settingsPath + '.lattice-backup-' + ts);
fs.writeFileSync(settingsPath, JSON.stringify(cfg, null, 2) + '\n', 'utf8');
process.stdout.write(ts);
NODEJS_APPLY
      echo "[${PROG}] wire-hooks: applied — backup at ${settings}.lattice-backup-<ts>"
      echo "[${PROG}] restart Claude Code to pick up the hooks"
      return 0
      ;;
    *)
      echo "${out}"
      die "wire-hooks: unexpected helper status: ${status}"
      ;;
  esac
}

# ---------------------------------------------------------------------------
# release-notes — auto-generate a CHANGELOG.md entry from git commits + closed
# findings since the last tag. v1.1.1 (#11). Output is markdown ready to paste
# at the top of CHANGELOG.md under the new ## [version] heading.
#
# Usage:
#   lattice release-notes                            # auto-detect last tag
#   lattice release-notes --since v1.0.4
#   lattice release-notes --since 2026-05-18
#   lattice release-notes --version 1.1.1            # override version
#   lattice release-notes --raw-commits              # skip categorization
#
# Categorizes commits by conventional prefix (fix:, feat:, refactor:, etc).
# Commits with "release:" or "Merge" prefix are dropped (release commits are
# this command's output; merges are noise).
# ---------------------------------------------------------------------------
cmd_release_notes() {
  local since="" override_version="" raw=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --since)   [ -z "${2:-}" ] && die "release-notes: --since requires a tag or YYYY-MM-DD"
                 since="$2"; shift 2 ;;
      --version) [ -z "${2:-}" ] && die "release-notes: --version requires a value"
                 override_version="$2"; shift 2 ;;
      --raw-commits) raw=1; shift ;;
      --help|-h)
        cat <<'RN_HELP'
lattice release-notes — auto-generate a CHANGELOG.md entry

  --since <tag-or-date>   commits/findings after this point
                          (default: most recent git tag)
  --version <v>           override the version header (default: plugin.json)
  --raw-commits           skip categorization; list commits as-is

Output is markdown, paste at top of CHANGELOG.md under ## [version] heading.
Categorizes commits by conventional prefix (fix:, feat:, etc).
Drops `release:` and merge commits.
RN_HELP
        return 0 ;;
      -*) die "release-notes: unknown flag: $1" ;;
      *)  die "release-notes: extra arg: $1" ;;
    esac
  done

  command -v git >/dev/null 2>&1 || die "release-notes: git required"
  git rev-parse --git-dir >/dev/null 2>&1 || die "release-notes: not in a git repo"

  # Auto-detect last tag if --since omitted
  if [ -z "${since}" ]; then
    since="$(git describe --tags --abbrev=0 2>/dev/null || true)"
    [ -z "${since}" ] && die "release-notes: no git tags found and --since not supplied"
  fi

  # Version header
  local version="${override_version}"
  if [ -z "${version}" ]; then
    version="$(current_version 2>/dev/null || echo unknown)"
  fi
  local today
  today="$(date -u +%Y-%m-%d)"

  # Build range expression — git understands both tag and date
  local range
  if git rev-parse "${since}" >/dev/null 2>&1; then
    range="${since}..HEAD"
  else
    # Treat as date
    range=""
  fi

  # Fetch commits
  local commits
  if [ -n "${range}" ]; then
    commits="$(git log "${range}" --pretty=format:'%h|%s' 2>/dev/null || true)"
  else
    commits="$(git log --since="${since}" --pretty=format:'%h|%s' 2>/dev/null || true)"
  fi

  # Header
  echo "## [${version}] — ${today}"
  echo ""

  if [ -z "${commits}" ]; then
    echo "_No commits since ${since}._"
    echo ""
  else
    if [ "${raw}" -eq 1 ]; then
      echo "### Commits"
      echo ""
      printf '%s\n' "${commits}" | while IFS='|' read -r sha subj; do
        [ -z "${sha}" ] && continue
        echo "- ${sha} — ${subj}"
      done
      echo ""
    else
      # Categorize by conventional prefix
      local feats="" fixes="" refactors="" docs="" tests="" perfs="" others=""
      while IFS='|' read -r sha subj; do
        [ -z "${sha}" ] && continue
        # Drop release commits + merges
        case "${subj}" in
          release:*|Release:*|Merge\ *|"Merge pull request"*) continue ;;
        esac
        case "${subj}" in
          feat:*|feature:*)  feats="${feats}- ${subj#*: } (${sha})"$'\n' ;;
          fix:*)             fixes="${fixes}- ${subj#fix: } (${sha})"$'\n' ;;
          refactor:*)        refactors="${refactors}- ${subj#refactor: } (${sha})"$'\n' ;;
          docs:*|doc:*)      docs="${docs}- ${subj#*: } (${sha})"$'\n' ;;
          test:*|tests:*)    tests="${tests}- ${subj#*: } (${sha})"$'\n' ;;
          perf:*)            perfs="${perfs}- ${subj#perf: } (${sha})"$'\n' ;;
          *)                 others="${others}- ${subj} (${sha})"$'\n' ;;
        esac
      done <<EOF_COMMITS
${commits}
EOF_COMMITS

      [ -n "${feats}" ]     && { echo "### Added"; echo ""; printf '%s' "${feats}"; echo ""; }
      [ -n "${fixes}" ]     && { echo "### Fixed"; echo ""; printf '%s' "${fixes}"; echo ""; }
      [ -n "${refactors}" ] && { echo "### Changed"; echo ""; printf '%s' "${refactors}"; echo ""; }
      [ -n "${perfs}" ]     && { echo "### Performance"; echo ""; printf '%s' "${perfs}"; echo ""; }
      [ -n "${docs}" ]      && { echo "### Documentation"; echo ""; printf '%s' "${docs}"; echo ""; }
      [ -n "${tests}" ]     && { echo "### Tests"; echo ""; printf '%s' "${tests}"; echo ""; }
      [ -n "${others}" ]    && { echo "### Other"; echo ""; printf '%s' "${others}"; echo ""; }
    fi
  fi

  # Closed findings (delegate to cmd_changelog if .lattice/ exists)
  if [ -d .lattice/findings/closed ]; then
    local since_date="${since}"
    # If since is a tag, resolve to the tag's commit date
    if git rev-parse "${since}" >/dev/null 2>&1; then
      since_date="$(git log -1 --format=%cd --date=short "${since}" 2>/dev/null || echo "${since}")"
    fi
    # cmd_changelog --since outputs its own markdown headers, so embed under H3
    local cl_out
    cl_out="$(cmd_changelog --since "${since_date}" 2>/dev/null | grep -v '^_Total:' || true)"
    # Suppress noisy "no findings closed" pass-through from cmd_changelog
    if printf '%s' "${cl_out}" | grep -qE '^_No findings|^\(no findings'; then
      :
    elif [ -n "${cl_out}" ]; then
      echo "### Closed Lattice findings (since ${since_date})"
      echo ""
      printf '%s\n' "${cl_out}"
      echo ""
    fi
  fi

  # Footer hint
  echo "### Verified"
  echo "- (fill in: live tests, validate.sh, smoke tests)"
  echo ""
  echo "---"
  echo "_Generated by \`lattice release-notes\` from \`${since}\`..HEAD on ${today}._"
}

# ---------------------------------------------------------------------------
# profile — operator profile (#55, #56). Global per-user constraints +
# preferences that reweight finding tiers and bias suggested fixes. Lives
# at ~/.lattice/profile.yml. Project-level override at .lattice/profile.yml.
#
# Usage:
#   lattice profile init                    # create ~/.lattice/profile.yml with safe defaults
#   lattice profile show                    # print merged effective profile
#   lattice profile set <key>=<value> [...]  # update one or more fields
#
# Fields read by `lattice list --effective-tier` and `lattice show`:
#   operator.scale = solo | small-team | org | enterprise
#   workflow_constraints.will_check_dashboards = bool
#   workflow_constraints.will_query_databases = bool
#   workflow_constraints.will_read_log_files = bool
#   workflow_constraints.push_channels_only = bool
#   preferences.prefer_delete_over_wire = bool
# ---------------------------------------------------------------------------
_PROFILE_GLOBAL="${HOME}/.lattice/profile.yml"

_profile_default() {
  cat <<'PROFYAML'
# Lattice operator profile (~/.lattice/profile.yml). Read by `lattice list
# --effective-tier`, `lattice show`, and `lattice grow` for tier reweighting
# + suggested-fix bias. Project-level overrides go in .lattice/profile.yml.
operator:
  scale: solo               # solo | small-team | org | enterprise
  on_call: false
workflow_constraints:
  will_check_dashboards: false
  will_query_databases: false
  will_read_log_files: false
  push_channels_only: true
preferences:
  prefer_delete_over_wire: true
  confirm_before_large_changes: true   # >300 LOC = confirm
PROFYAML
}

cmd_profile() {
  local sub="${1:-show}"; shift || true
  case "${sub}" in
    init)
      if [ -f "${_PROFILE_GLOBAL}" ]; then
        echo "[${PROG}] profile already exists at ${_PROFILE_GLOBAL} (preserved)"
        return 0
      fi
      mkdir -p "$(dirname "${_PROFILE_GLOBAL}")" 2>/dev/null
      _profile_default > "${_PROFILE_GLOBAL}"
      echo "[${PROG}] created ${_PROFILE_GLOBAL}"
      echo "[${PROG}] edit it to declare your workflow constraints; tier reweighting will honor them"
      ;;
    show)
      if [ -f "${_PROFILE_GLOBAL}" ]; then
        echo "# --- global: ${_PROFILE_GLOBAL} ---"
        cat "${_PROFILE_GLOBAL}"
      else
        echo "[${PROG}] no profile yet. run: lattice profile init"
      fi
      if [ -f .lattice/profile.yml ]; then
        echo ""
        echo "# --- project override: $(pwd)/.lattice/profile.yml ---"
        cat .lattice/profile.yml
      fi
      ;;
    set)
      [ "$#" -ge 1 ] || die "profile set: usage: lattice profile set key=value [key=value...]"
      [ -f "${_PROFILE_GLOBAL}" ] || cmd_profile init >/dev/null
      for kv in "$@"; do
        local k="${kv%%=*}" v="${kv#*=}"
        # Simple key-line replacement; preserves structure
        if grep -qE "^[[:space:]]*${k}:" "${_PROFILE_GLOBAL}"; then
          sed -i.bak -E "s|^([[:space:]]*${k}:).*|\1 ${v}|" "${_PROFILE_GLOBAL}"
          rm -f "${_PROFILE_GLOBAL}.bak"
          echo "[${PROG}] set ${k}=${v}"
        else
          echo "[${PROG}] WARN: key '${k}' not found in profile — append manually" >&2
        fi
      done
      ;;
    --help|-h)
      cat <<'PROFHELP'
lattice profile — operator profile for tier reweighting + fix bias

  init                              create ~/.lattice/profile.yml with defaults
  show                              print merged effective profile
  set key=value [key=value...]      update one or more keys

Profile fields drive `lattice list --effective-tier`:
  scale=solo + audit/dead-code               -> demote 1 step
  will_check_dashboards=false + fix=dashboard -> demote 2 steps
  prefer_delete_over_wire=true               -> bias suggested_fix toward delete
PROFHELP
      ;;
    *) die "profile: unknown action: ${sub} (try: init | show | set)" ;;
  esac
}

# Read a profile field (dot-path like "operator.scale"). Used by tier
# reweighting + lattice grow. Returns empty string if not set.
_profile_get() {
  local path="$1"
  local last="${path##*.}"
  local file
  for file in .lattice/profile.yml "${_PROFILE_GLOBAL}"; do
    [ -f "${file}" ] || continue
    local v
    v="$(grep -E "^[[:space:]]*${last}:" "${file}" 2>/dev/null | head -1 | sed -E "s|^[[:space:]]*${last}:[[:space:]]*||; s|[[:space:]]*#.*$||; s|^[\"']||; s|[\"']$||")"
    [ -n "${v}" ] && { printf '%s' "${v}"; return 0; }
  done
}

# Reweight tier based on profile. Args: tier, dimension, rule, fix_text.
# Returns the (possibly demoted) tier. Demotion ladder:
#   CRITICAL -> BLOCKER -> HIGH -> RISK -> MEDIUM -> WATCH -> LOW
_profile_reweight_tier() {
  local tier="$1" dimension="$2" rule="$3" fix_text="$4"
  local demote=0
  local scale; scale="$(_profile_get operator.scale)"
  local will_dash; will_dash="$(_profile_get workflow_constraints.will_check_dashboards)"
  local will_db; will_db="$(_profile_get workflow_constraints.will_query_databases)"
  local push_only; push_only="$(_profile_get workflow_constraints.push_channels_only)"

  # Rule 1: solo + dead-code -> demote 1
  if [ "${scale}" = "solo" ] && [[ "${rule}" == *dead-code* || "${rule}" == *unused* ]]; then
    demote=$((demote + 1))
  fi
  # Rule 2: will_check_dashboards=false + fix mentions dashboard -> demote 2
  if [ "${will_dash}" = "false" ] && [[ "${fix_text,,}" == *dashboard* ]]; then
    demote=$((demote + 2))
  fi
  # Rule 3: will_query_databases=false + fix mentions "query the database" -> demote 1
  if [ "${will_db}" = "false" ] && [[ "${fix_text,,}" == *"query the database"* || "${fix_text,,}" == *"check the database"* ]]; then
    demote=$((demote + 1))
  fi
  # Rule 4: push_channels_only=true + fix mentions "open the admin" -> demote 1
  if [ "${push_only}" = "true" ] && [[ "${fix_text,,}" == *"open the admin"* || "${fix_text,,}" == *"check the admin panel"* ]]; then
    demote=$((demote + 1))
  fi

  if [ "${demote}" -eq 0 ]; then
    printf '%s' "${tier}"
    return 0
  fi
  # Apply demotion ladder
  local ladder=("CRITICAL" "BLOCKER" "HIGH" "RISK" "MEDIUM" "WATCH" "LOW")
  local idx=-1 i
  for i in "${!ladder[@]}"; do
    [ "${ladder[$i]}" = "${tier}" ] && idx=${i}
  done
  if [ ${idx} -lt 0 ]; then
    printf '%s' "${tier}"
    return 0
  fi
  local new=$((idx + demote))
  [ ${new} -ge ${#ladder[@]} ] && new=$((${#ladder[@]} - 1))
  printf '%s' "${ladder[${new}]}"
}

# ---------------------------------------------------------------------------
# grow — hypothesis lifecycle (v1.4.0, #57). Mirror of the findings lifecycle
# but for forward-looking changes (growth experiments, refactor proposals,
# product hypotheses). Same YAML-per-file pattern, separate directory tree.
#
# .lattice/hypotheses/
#   open/        proposed, not yet executing
#   running/     in-flight (PR open, A/B running, etc)
#   closed/      resolved (won/lost/inconclusive)
#   rolled-back/ executed but reverted due to negative signal
#
# Usage:
#   lattice grow init
#   lattice grow propose <slug> --title "..." --change "..." --metric "..." [--cadence weekly]
#   lattice grow list [--state running|open|closed]
#   lattice grow show <slug>
#   lattice grow run <slug> --commit <sha>   # mark as running, link to commit/PR
#   lattice grow status <slug>
#   lattice grow rollback <slug> --reason "..."
#   lattice grow close <slug> --result <won|lost|inconclusive> [--rationale "..."]
# ---------------------------------------------------------------------------
cmd_grow() {
  local sub="${1:-help}"; shift || true
  case "${sub}" in
    init)        _grow_init "$@" ;;
    propose)     _grow_propose "$@" ;;
    list|ls)     _grow_list "$@" ;;
    show)        _grow_show "$@" ;;
    run)         _grow_run "$@" ;;
    status)      _grow_status "$@" ;;
    rollback)    _grow_rollback "$@" ;;
    close)       _grow_close "$@" ;;
    measure)        _grow_measure "$@" ;;
    check)          _grow_check "$@" ;;
    auto-rollback)  _grow_auto_rollback "$@" ;;
    attach-measurement) _grow_attach_measurement "$@" ;;
    schedule)       _grow_schedule "$@" ;;
    help|--help|-h)
      cat <<'GROWHELP'
lattice grow — hypothesis lifecycle (parallel to findings; for forward-looking
changes: growth experiments, refactor proposals, product hypotheses).

  init                                              create .lattice/hypotheses/{open,running,closed,rolled-back}/
  propose <slug> --title "..." --change "..." --metric "..." [--cadence weekly]
  list [--state open|running|closed|rolled-back]
  show <slug>
  run <slug> --commit <sha>                         mark as running
  status <slug>                                     show current state
  rollback <slug> --reason "..."                    revert (manual)
  close <slug> --result won|lost|inconclusive [--rationale "..."]

CLOSED-LOOP (v2.0):
  measure <slug>                                    fetch metric value vs baseline + threshold; print verdict
  check [--state running]                           measure every running hypothesis; summarize
  auto-rollback <slug> [--execute] [--yes]          if measure verdict is `failed` AND window has elapsed,
                                                    git-revert the run_commit and transition to rolled-back.
                                                    Default DRY-RUN. --execute writes; --yes skips confirm.
                                                    Always backs up branch tip ref before reverting.

Measurement source schemes (set via --measurement-source on propose):
  http://... or https://...      GET request expecting JSON; value at .value or .data.value
  file:/path/to/file             read a single number from that file
  cmd:script.sh [args]           exec script, parse last stdout line as number

Hypotheses live as YAMLs under .lattice/hypotheses/. Lifecycle mirrors
findings: open -> running -> closed (or rolled-back). Each transition stamps
timestamps + transition reasons.

NOT in v2.0: cadence scheduling (cron/queue), low-traffic confidence-
interval stats, hypothesis auto-generation from product data — those need
separate ships (v2.1+).
GROWHELP
      ;;
    *) die "grow: unknown action: ${sub} (try: init | propose | list | show | run | status | rollback | close)" ;;
  esac
}

_grow_init() {
  mkdir -p .lattice/hypotheses/open .lattice/hypotheses/running .lattice/hypotheses/closed .lattice/hypotheses/rolled-back 2>/dev/null
  echo "[${PROG}] grow: created .lattice/hypotheses/{open,running,closed,rolled-back}/"
  echo "[${PROG}] next: lattice grow propose <slug> --title \"...\" --change \"...\" --metric \"...\""
}

_grow_propose() {
  [ "$#" -ge 1 ] || die "grow propose: usage: lattice grow propose <slug> --title ... --change ... --metric ..."
  local slug="$1"; shift
  local title="" change="" metric="" cadence="weekly" effort="MEDIUM" risk="LOW"
  # v1.4.2 (#59): structured measurement fields for v2.0 auto-rollback
  local metric_name="" measurement_source="" baseline_value="" baseline_source=""
  local expected_delta="" success_threshold="" window_days=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --title)              title="$2"; shift 2 ;;
      --change)             change="$2"; shift 2 ;;
      --metric)             metric="$2"; shift 2 ;;
      --metric-name)        metric_name="$2"; shift 2 ;;
      --measurement-source) measurement_source="$2"; shift 2 ;;
      --baseline-value)     baseline_value="$2"; shift 2 ;;
      --baseline-source)    baseline_source="$2"; shift 2 ;;
      --expected-delta)     expected_delta="$2"; shift 2 ;;
      --success-threshold)  success_threshold="$2"; shift 2 ;;
      --window-days)        window_days="$2"; shift 2 ;;
      --cadence)            cadence="$2"; shift 2 ;;
      --effort)             effort="$2"; shift 2 ;;
      --risk)               risk="$2"; shift 2 ;;
      *) die "grow propose: unknown flag: $1" ;;
    esac
  done
  [ -n "${title}" ] || die "grow propose: --title required"
  [ -n "${change}" ] || die "grow propose: --change required (one-line description of the change)"
  [ -n "${metric}" ] || die "grow propose: --metric required (free-text description; pair with --metric-name + --measurement-source for v2.0 auto-rollback)"

  mkdir -p .lattice/hypotheses/open 2>/dev/null
  local now; now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  local dest=".lattice/hypotheses/open/${slug}.yml"
  [ -f "${dest}" ] && die "grow propose: ${dest} already exists"

  local id
  id="$(printf '%s' "growth:${slug}:${change}:${metric}" | sha1sum 2>/dev/null | cut -c1-12 || \
        printf '%s' "growth:${slug}:${change}:${metric}" | shasum -a 1 | cut -c1-12)"

  {
    printf 'id: %s\n' "${id}"
    printf 'slug: %s\n' "${slug}"
    printf 'state: open\n'
    printf 'title: "%s"\n' "${title//\"/\\\"}"
    printf 'change: "%s"\n' "${change//\"/\\\"}"
    printf 'metric: "%s"\n' "${metric//\"/\\\"}"
    # v1.4.2 (#59): structured measurement block — v2.0 auto-rollback reads these
    if [ -n "${metric_name}${measurement_source}${baseline_value}${expected_delta}${success_threshold}${window_days}" ]; then
      printf 'measurement:\n'
      [ -n "${metric_name}" ]         && printf '  name: "%s"\n'              "${metric_name//\"/\\\"}"
      [ -n "${measurement_source}" ]  && printf '  source: "%s"\n'            "${measurement_source//\"/\\\"}"
      [ -n "${baseline_value}" ]      && printf '  baseline_value: %s\n'      "${baseline_value}"
      [ -n "${baseline_source}" ]     && printf '  baseline_source: "%s"\n'   "${baseline_source//\"/\\\"}"
      [ -n "${expected_delta}" ]      && printf '  expected_delta: %s\n'      "${expected_delta}"
      [ -n "${success_threshold}" ]   && printf '  success_threshold: %s\n'   "${success_threshold}"
      [ -n "${window_days}" ]         && printf '  window_days: %s\n'         "${window_days}"
    fi
    printf 'cadence: %s\n' "${cadence}"
    printf 'effort: %s\n' "${effort}"
    printf 'risk: %s\n' "${risk}"
    printf 'proposed_at: %s\n' "${now}"
    printf 'proposed_by: lattice-cli\n'
    printf '# Lifecycle stamps (filled by run/rollback/close):\n'
    printf '# run_at: <ISO>\n'
    printf '# run_commit: <sha>\n'
    printf '# closed_at: <ISO>\n'
    printf '# observed_value: <number>      # v1.4.2 — actual outcome at close\n'
    printf '# result: <won|lost|inconclusive>\n'
    printf '# rationale: "..."\n'
  } > "${dest}"
  echo "[${PROG}] grow: proposed ${dest}"
  echo "[${PROG}] start running with: lattice grow run ${slug} --commit <sha>"
  # v2.2: warn loudly if measurement.source uses the cmd: scheme — RCE surface
  if [[ "${measurement_source}" == cmd:* ]]; then
    echo "[${PROG}] WARNING: measurement.source uses 'cmd:' — arbitrary shell. Default-deny." >&2
    echo "[${PROG}]   to permit, set security.allow_cmd_sources: true in .lattice/config.yml" >&2
    echo "[${PROG}]   (or export LATTICE_ALLOW_CMD_SOURCES=1 for one-shot runs)" >&2
  fi
  if [ -z "${metric_name}${measurement_source}${baseline_value}" ]; then
    echo "[${PROG}] note: structured measurement fields (--metric-name, --measurement-source, --baseline-value, --expected-delta, --success-threshold, --window-days) omitted. v2.0 auto-rollback requires these — see #59." >&2
  fi
}

# Resolve a hypothesis path by slug. Walks open/running/closed/rolled-back.
_grow_resolve() {
  local slug="$1"
  local state
  for state in open running closed rolled-back; do
    local p=".lattice/hypotheses/${state}/${slug}.yml"
    [ -f "${p}" ] && { printf '%s' "${p}"; return 0; }
  done
  return 1
}

_grow_list() {
  local filter_state=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --state) filter_state="$2"; shift 2 ;;
      *) die "grow list: unknown arg: $1" ;;
    esac
  done
  [ -d .lattice/hypotheses ] || { echo "[${PROG}] no .lattice/hypotheses/ — run: lattice grow init" >&2; return 0; }
  local count=0 state
  printf '%-12s %-30s %s\n' "STATE" "SLUG" "TITLE"
  for state in open running closed rolled-back; do
    [ -n "${filter_state}" ] && [ "${state}" != "${filter_state}" ] && continue
    [ -d ".lattice/hypotheses/${state}" ] || continue
    shopt -s nullglob
    for f in .lattice/hypotheses/${state}/*.yml; do
      [ -f "${f}" ] || continue
      local s t
      s="$(basename "${f}" .yml)"
      t="$(yaml_field "${f}" "title")"
      printf '%-12s %-30s %s\n' "${state}" "${s}" "${t}"
      count=$((count + 1))
    done
  done
  echo ""
  echo "[${PROG}] ${count} hypothes$([ ${count} -eq 1 ] && echo is || echo es)"
}

_grow_show() {
  [ "$#" -ge 1 ] || die "grow show: usage: lattice grow show <slug>"
  local p; p="$(_grow_resolve "$1")" || die "grow show: hypothesis not found: $1"
  echo "# ${p}"
  cat "${p}"
}

_grow_run() {
  [ "$#" -ge 1 ] || die "grow run: usage: lattice grow run <slug> --commit <sha>"
  local slug="$1"; shift
  local commit=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --commit) commit="$2"; shift 2 ;;
      *) die "grow run: unknown flag: $1" ;;
    esac
  done
  [ -n "${commit}" ] || die "grow run: --commit <sha> required"
  local src=".lattice/hypotheses/open/${slug}.yml"
  [ -f "${src}" ] || die "grow run: not in open/: ${src}"
  mkdir -p .lattice/hypotheses/running 2>/dev/null
  local dst=".lattice/hypotheses/running/${slug}.yml"
  local now; now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  # Append lifecycle stamps + transition
  awk -v now="${now}" -v sha="${commit}" '
    /^state:/ { print "state: running"; next }
    { print }
    END {
      print "run_at: " now
      print "run_commit: " sha
    }
  ' "${src}" > "${dst}.tmp" && mv "${dst}.tmp" "${dst}"
  rm "${src}"
  echo "[${PROG}] grow: ${slug} -> running (commit ${commit})"
}

_grow_status() {
  [ "$#" -ge 1 ] || die "grow status: usage: lattice grow status <slug>"
  local p; p="$(_grow_resolve "$1")" || die "grow status: hypothesis not found: $1"
  local state run_at run_commit closed_at result
  state="$(basename "$(dirname "${p}")")"
  run_at="$(yaml_field "${p}" "run_at")"
  run_commit="$(yaml_field "${p}" "run_commit")"
  closed_at="$(yaml_field "${p}" "closed_at")"
  result="$(yaml_field "${p}" "result")"
  echo "slug:        $1"
  echo "state:       ${state}"
  [ -n "${run_at}" ]     && echo "run_at:      ${run_at}"
  [ -n "${run_commit}" ] && echo "run_commit:  ${run_commit}"
  [ -n "${closed_at}" ]  && echo "closed_at:   ${closed_at}"
  [ -n "${result}" ]     && echo "result:      ${result}"
}

_grow_rollback() {
  [ "$#" -ge 1 ] || die "grow rollback: usage: lattice grow rollback <slug> --reason \"...\""
  local slug="$1"; shift
  local reason=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --reason) reason="$2"; shift 2 ;;
      *) die "grow rollback: unknown flag: $1" ;;
    esac
  done
  [ -n "${reason}" ] || die "grow rollback: --reason required"
  local src=".lattice/hypotheses/running/${slug}.yml"
  [ -f "${src}" ] || die "grow rollback: hypothesis not running: ${src}"
  mkdir -p .lattice/hypotheses/rolled-back 2>/dev/null
  local dst=".lattice/hypotheses/rolled-back/${slug}.yml"
  local now; now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  awk -v now="${now}" -v reason="${reason}" '
    /^state:/ { print "state: rolled-back"; next }
    { print }
    END {
      print "rolled_back_at: " now
      print "rollback_reason: \"" reason "\""
    }
  ' "${src}" > "${dst}.tmp" && mv "${dst}.tmp" "${dst}"
  rm "${src}"
  echo "[${PROG}] grow: ${slug} -> rolled-back"
}

# v2.0: read a YAML's measurement.* subfields. Sub-keys live at column 2.
_grow_measurement_field() {
  local file="$1" key="$2"
  awk -v k="${key}" '
    /^measurement:/ { inblock=1; next }
    inblock && /^[a-zA-Z_]/ { inblock=0 }
    inblock && $1 == k":" {
      $1=""
      sub(/^[[:space:]]+/, "")
      gsub(/^["'\'']|["'\'']$/, "")
      print
      exit
    }
  ' "${file}" 2>/dev/null
}

# v2.1 (#60): extract headers block from measurement.headers as
# newline-separated "Header: value" lines. Returns empty if no headers block.
_grow_measurement_headers() {
  local file="$1"
  awk '
    /^measurement:/ { inmeas=1; next }
    inmeas && /^[a-zA-Z_]/ { inmeas=0 }
    inmeas && /^  headers:/ { inhdr=1; next }
    inhdr && /^    [A-Za-z]/ {
      # "    Key: value" or "    Key: \"value\""
      sub(/^    /, "")
      sub(/^"/, ""); sub(/"$/, "")
      print
      next
    }
    inhdr && /^  [a-zA-Z_]/ { inhdr=0 }
    inhdr && /^[a-zA-Z_]/   { inhdr=0; inmeas=0 }
  ' "${file}" 2>/dev/null
}

# v2.1 (#60 #3): extract a list of `sources:` entries under measurement.
# Each entry becomes a line "source_url|baseline_value|weight|name".
# Falls back to single source from measurement.source when no list.
_grow_measurement_sources() {
  local file="$1"
  # First try the multi-source list shape
  local list_output
  list_output="$(awk '
    /^measurement:/ { inmeas=1; next }
    inmeas && /^[a-zA-Z_]/ { inmeas=0 }
    inmeas && /^  sources:/ { inlist=1; next }
    inlist && /^    - / {
      if (src != "") {
        print src "|" baseline "|" weight "|" name
      }
      src=""; baseline=""; weight="1"; name=""
      # Parse the "- name: foo" or "- source: foo" inline part
      line=$0
      sub(/^    - /, "", line)
      if (match(line, /^name:[[:space:]]*"?[^"]*"?/)) { name=substr(line, RSTART+5); gsub(/^[[:space:]]+|[[:space:]]+$|"/, "", name) }
      else if (match(line, /^source:[[:space:]]*"?[^"]*"?/)) { src=substr(line, RSTART+7); gsub(/^[[:space:]]+|[[:space:]]+$|"/, "", src) }
      next
    }
    inlist && /^      / {
      line=$0
      sub(/^      /, "", line)
      if (match(line, /^source:/)) { src=substr(line, 8); gsub(/^[[:space:]]+|[[:space:]]+$|"/, "", src) }
      else if (match(line, /^baseline_value:/)) { baseline=substr(line, 16); gsub(/^[[:space:]]+|[[:space:]]+$|"/, "", baseline) }
      else if (match(line, /^weight:/)) { weight=substr(line, 8); gsub(/^[[:space:]]+|[[:space:]]+$|"/, "", weight) }
      else if (match(line, /^name:/)) { name=substr(line, 6); gsub(/^[[:space:]]+|[[:space:]]+$|"/, "", name) }
      next
    }
    inlist && /^  [a-zA-Z_]/ {
      if (src != "") print src "|" baseline "|" weight "|" name
      inlist=0
    }
    END {
      if (inlist && src != "") print src "|" baseline "|" weight "|" name
    }
  ' "${file}" 2>/dev/null)"
  if [ -n "${list_output}" ]; then
    printf '%s\n' "${list_output}"
    return 0
  fi
  # Fall back to single source
  local single
  single="$(_grow_measurement_field "${file}" "source")"
  if [ -n "${single}" ]; then
    local baseline; baseline="$(_grow_measurement_field "${file}" "baseline_value")"
    printf '%s|%s|1|\n' "${single}" "${baseline}"
  fi
}

# v2.2: gate for the cmd: source scheme. Returns 0 (allowed) only when
# explicitly opted in via .lattice/config.yml `security.allow_cmd_sources: true`
# OR the env override LATTICE_ALLOW_CMD_SOURCES=1. Default: refuse.
_grow_cmd_source_allowed() {
  [ "${LATTICE_ALLOW_CMD_SOURCES:-0}" = "1" ] && return 0
  [ -f .lattice/config.yml ] || return 1
  # Look for `allow_cmd_sources: true` inside a top-level `security:` block.
  awk '
    /^security:/ { ins=1; next }
    ins && /^[a-zA-Z_]/ { ins=0 }
    ins && /^[[:space:]]+allow_cmd_sources:[[:space:]]*true[[:space:]]*$/ { found=1; exit }
    END { exit (found ? 0 : 1) }
  ' .lattice/config.yml
}

# v2.0: fetch a metric value from a `measurement.source` URI. Returns the
# numeric value on stdout; non-zero exit + stderr on failure.
# v2.1 (#60): accepts optional 2nd arg = newline-separated `Header: value`
# lines; values may reference ${ENV_VAR} and are interpolated at fetch time.
_grow_fetch_metric() {
  local source="$1"
  local headers="${2:-}"
  case "${source}" in
    http://*|https://*)
      command -v node >/dev/null 2>&1 || { echo "[fetch] node required for http source" >&2; return 1; }
      command -v curl >/dev/null 2>&1 || { echo "[fetch] curl required for http source" >&2; return 1; }
      # v2.1: interpolate ${VAR} in headers + assemble -H flags for curl
      local -a curl_args=(-fsSL --max-time 10)
      if [ -n "${headers}" ]; then
        local h k v interp
        while IFS= read -r h; do
          [ -z "${h}" ] && continue
          # Split "Key: value" — value may contain ${VAR}
          k="${h%%:*}"; v="${h#*:}"
          # Strip one leading space after colon
          v="${v# }"
          # ${VAR} interpolation via envsubst-like loop
          interp="${v}"
          while [[ "${interp}" =~ \$\{([A-Za-z_][A-Za-z0-9_]*)\} ]]; do
            local var_name="${BASH_REMATCH[1]}"
            local var_value="${!var_name:-}"
            interp="${interp//\$\{${var_name}\}/${var_value}}"
          done
          curl_args+=(-H "${k}: ${interp}")
        done <<< "${headers}"
      fi
      local body
      body="$(curl "${curl_args[@]}" "${source}" 2>/dev/null)" || { echo "[fetch] curl failed for ${source}" >&2; return 1; }
      # Parse JSON, look for .value or .data.value or .metric
      printf '%s' "${body}" | node -e '
let s = ""; process.stdin.on("data", d => s += d).on("end", () => {
  try {
    const o = JSON.parse(s);
    const v = o.value ?? o?.data?.value ?? o.metric ?? o?.data?.metric;
    if (v == null || isNaN(Number(v))) { process.stderr.write("[fetch] no numeric .value / .data.value / .metric in response\n"); process.exit(2); }
    process.stdout.write(String(Number(v)));
  } catch (e) { process.stderr.write("[fetch] JSON parse: " + e.message + "\n"); process.exit(2); }
});'
      ;;
    file:/*|file://*)
      local path="${source#file:}"
      path="${path#//}"
      [ -f "${path}" ] || { echo "[fetch] file not found: ${path}" >&2; return 1; }
      local v
      v="$(tr -d '[:space:]' < "${path}")"
      [[ "${v}" =~ ^-?[0-9]+(\.[0-9]+)?$ ]] || { echo "[fetch] file content not numeric: ${path}" >&2; return 1; }
      printf '%s' "${v}"
      ;;
    cmd:*)
      local script="${source#cmd:}"
      # v2.2 (#cmd-rce): cmd: scheme is DEFAULT-DENY. Maintainer must opt in via
      # .lattice/config.yml `security.allow_cmd_sources: true` OR env override
      # LATTICE_ALLOW_CMD_SOURCES=1. This prevents a hypothesis YAML containing
      # `source: cmd:rm -rf ~` from executing on `lattice grow measure`.
      if ! _grow_cmd_source_allowed; then
        echo "[fetch] cmd: scheme refused — set security.allow_cmd_sources: true in .lattice/config.yml (or export LATTICE_ALLOW_CMD_SOURCES=1) to enable" >&2
        echo "[fetch] refused source: ${source}" >&2
        return 1
      fi
      local out
      out="$(bash -c "${script}" 2>/dev/null)" || { echo "[fetch] cmd failed: ${script}" >&2; return 1; }
      # Last non-empty line, parsed as number
      local v
      v="$(printf '%s\n' "${out}" | grep -E '^-?[0-9]+(\.[0-9]+)?$' | tail -1)"
      [ -n "${v}" ] || { echo "[fetch] cmd produced no numeric line: ${script}" >&2; return 1; }
      printf '%s' "${v}"
      ;;
    *) echo "[fetch] unsupported source scheme: ${source} (use http://, https://, file:/, or cmd:)" >&2; return 1 ;;
  esac
}

# Compare numbers as floats via node (bash arithmetic is integer-only).
# Returns: -1 if a<b, 0 if a==b, 1 if a>b.
_grow_fcmp() {
  node -e "const a=parseFloat(process.argv[1]),b=parseFloat(process.argv[2]); if(a<b)process.stdout.write('-1');else if(a>b)process.stdout.write('1');else process.stdout.write('0');" "$1" "$2"
}

# v2.0/v2.1: evaluate a single hypothesis. v2.1 adds: multi-source combine
# (#60 #3), auth headers (#60 #1), --json output mode (#61).
_grow_measure() {
  [ "$#" -ge 1 ] || die "grow measure: usage: lattice grow measure <slug> [--json]"
  local slug="$1"; shift || true
  local output="text"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --json) output="json"; shift ;;
      *) die "grow measure: unknown flag: $1" ;;
    esac
  done
  local p; p="$(_grow_resolve "${slug}")" || die "grow measure: hypothesis not found: ${slug}"
  local state; state="$(basename "$(dirname "${p}")")"
  if [ "${state}" != "running" ]; then
    if [ "${output}" = "json" ]; then
      printf '{"slug":"%s","state":"%s","verdict":"skipped"}\n' "${slug}" "${state}"
    else
      echo "[${PROG}] measure: ${slug} is in state '${state}', not 'running' — skipping"
    fi
    return 0
  fi

  local threshold window_days run_at combine
  threshold="$(_grow_measurement_field "${p}" "success_threshold")"
  window_days="$(_grow_measurement_field "${p}" "window_days")"
  combine="$(_grow_measurement_field "${p}" "combine")"
  [ -z "${combine}" ] && combine="sum"
  run_at="$(yaml_field "${p}" "run_at")"
  local headers; headers="$(_grow_measurement_headers "${p}")"

  # Read sources (1 or N). Each line: url|baseline|weight|name
  local sources_lines; sources_lines="$(_grow_measurement_sources "${p}")"
  if [ -z "${sources_lines}" ]; then
    if [ "${output}" = "json" ]; then
      printf '{"slug":"%s","verdict":"insufficient-data","reason":"no measurement.source(s)"}\n' "${slug}"
    else
      echo "[${PROG}] measure: ${slug} has no measurement.source — propose with --measurement-source. Verdict: insufficient-data"
    fi
    return 0
  fi

  # Fetch each source; track combined value.
  local total=0 count=0 fetch_failed=0
  local -a per_source=()  # rows like "name|source|value"
  local line
  while IFS= read -r line; do
    [ -z "${line}" ] && continue
    local s_url="${line%%|*}"; local rest="${line#*|}"
    local s_base="${rest%%|*}"; rest="${rest#*|}"
    local s_weight="${rest%%|*}"; rest="${rest#*|}"
    local s_name="${rest}"
    [ -z "${s_weight}" ] && s_weight=1
    local s_val
    if s_val="$(_grow_fetch_metric "${s_url}" "${headers}")"; then
      # weighted contribution
      local weighted; weighted="$(node -e "console.log(parseFloat(process.argv[1])*parseFloat(process.argv[2]))" "${s_val}" "${s_weight}")"
      case "${combine}" in
        sum|weighted-avg|weighted_avg)
          total="$(node -e "console.log(parseFloat(process.argv[1])+parseFloat(process.argv[2]))" "${total}" "${weighted}")"
          ;;
        max)
          if [ "${count}" -eq 0 ] || [ "$(_grow_fcmp "${s_val}" "${total}")" -gt 0 ]; then total="${s_val}"; fi
          ;;
        min)
          if [ "${count}" -eq 0 ] || [ "$(_grow_fcmp "${s_val}" "${total}")" -lt 0 ]; then total="${s_val}"; fi
          ;;
        *) total="$(node -e "console.log(parseFloat(process.argv[1])+parseFloat(process.argv[2]))" "${total}" "${weighted}")" ;;
      esac
      per_source+=("${s_name:-_}|${s_url}|${s_val}")
      count=$((count + 1))
    else
      fetch_failed=$((fetch_failed + 1))
      per_source+=("${s_name:-_}|${s_url}|FETCH-FAILED")
    fi
  done <<< "${sources_lines}"

  if [ "${count}" -eq 0 ]; then
    if [ "${output}" = "json" ]; then
      printf '{"slug":"%s","verdict":"fetch-failed","sources_failed":%d}\n' "${slug}" "${fetch_failed}"
    else
      echo "[${PROG}] measure: ${slug} -> fetch-failed (all ${fetch_failed} sources)"
    fi
    return 1
  fi

  # For weighted-avg, divide total by count (or sum of weights — count is fine for v2.1)
  local current="${total}"
  case "${combine}" in
    weighted-avg|weighted_avg) current="$(node -e "console.log(parseFloat(process.argv[1])/parseInt(process.argv[2]))" "${total}" "${count}")" ;;
  esac

  # Window elapsed?
  local window_elapsed=0 elapsed_days=0
  if [ -n "${run_at}" ] && [ -n "${window_days}" ]; then
    local now_s run_s elapsed_s window_s
    now_s="$(date -u +%s)"
    run_s="$(date -u -d "${run_at}" +%s 2>/dev/null || echo 0)"
    elapsed_s=$((now_s - run_s))
    window_s=$((window_days * 86400))
    [ "${elapsed_s}" -ge "${window_s}" ] && window_elapsed=1
    elapsed_days=$((elapsed_s / 86400))
  fi

  # Verdict
  local verdict="still-running"
  if [ -n "${threshold}" ]; then
    local cmp; cmp="$(_grow_fcmp "${current}" "${threshold}")"
    if [ "${cmp}" -ge 0 ]; then
      verdict="succeeded"
    elif [ "${window_elapsed}" -eq 1 ]; then
      verdict="failed"
    fi
  elif [ "${window_elapsed}" -eq 1 ]; then
    verdict="inconclusive"
  fi

  if [ "${output}" = "json" ]; then
    # JSON output for #61 scheduler. Compact one-line.
    local title; title="$(yaml_field "${p}" "title")"
    printf '{"slug":"%s","title":"%s","verdict":"%s","current_value":%s,"success_threshold":%s,"elapsed_days":%d,"window_days":%s,"combine":"%s","sources_count":%d,"sources_failed":%d}\n' \
      "${slug}" "${title//\"/\\\"}" "${verdict}" "${current:-null}" "${threshold:-null}" "${elapsed_days}" "${window_days:-null}" "${combine}" "${count}" "${fetch_failed}"
    return 0
  fi

  echo "[${PROG}] measure: ${slug}"
  echo "  combine:           ${combine}"
  echo "  sources:           ${count} ok, ${fetch_failed} failed"
  for row in "${per_source[@]}"; do
    local n="${row%%|*}" rest2="${row#*|}"
    local u="${rest2%%|*}" v="${rest2#*|}"
    echo "    - ${n}: ${u} -> ${v}"
  done
  echo "  combined_value:    ${current}"
  echo "  success_threshold: ${threshold:-(unset)}"
  echo "  window_days:       ${window_days:-(unset)}"
  echo "  run_at:            ${run_at:-(unset)}"
  [ "${elapsed_days}" -gt 0 ] && echo "  elapsed_days:      ${elapsed_days} / ${window_days:-?}"
  echo "  verdict:           ${verdict}"

  case "${verdict}" in
    succeeded) echo "  suggest:           lattice grow close ${slug} --result won --observed-value ${current}" ;;
    failed)    echo "  suggest:           lattice grow auto-rollback ${slug}  # or close --result lost" ;;
    inconclusive) echo "  suggest:           lattice grow close ${slug} --result inconclusive --observed-value ${current}" ;;
    still-running) echo "  suggest:           wait" ;;
  esac
}

# v2.0/v2.1: walk all running hypotheses and measure each.
# v2.1 (#61): --json output mode produces one JSON object per line + a
# final summary line — designed for the GitHub Actions workflow to pipe
# into the Telegram formatter.
_grow_check() {
  local filter_state="running" output="text"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --state) filter_state="$2"; shift 2 ;;
      --json)  output="json"; shift ;;
      *) die "grow check: unknown arg: $1" ;;
    esac
  done
  if [ ! -d ".lattice/hypotheses/${filter_state}" ]; then
    if [ "${output}" = "json" ]; then
      printf '{"summary":{"measured":0,"won":0,"lost":0,"waiting":0,"failed_fetch":0},"hypotheses":[]}\n'
    else
      echo "[${PROG}] check: no .lattice/hypotheses/${filter_state}/"
    fi
    return 0
  fi
  shopt -s nullglob
  local n=0 won=0 lost=0 waiting=0 failed=0
  if [ "${output}" = "json" ]; then
    # Collect per-hypothesis JSON, build a single envelope at end
    local -a rows=()
    for f in .lattice/hypotheses/${filter_state}/*.yml; do
      [ -f "${f}" ] || continue
      local slug; slug="$(basename "${f}" .yml)"
      local row
      # v2.1.4 (#76): use `|| true` not `|| echo "{}"`. _grow_measure --json
      # prints a valid JSON object even when it returns 1 (fetch-failed). The
      # previous `|| echo "{}"` appended a stray `{}` AFTER the real object,
      # breaking the envelope's array. `|| true` swallows the exit code so
      # `set -e` doesn't kill the loop, without adding garbage to stdout.
      row="$(_grow_measure "${slug}" --json 2>/dev/null || true)"
      # Strip trailing newline from printf — array entries are comma-joined.
      row="${row%$'\n'}"
      [ -z "${row}" ] && row="{}"
      rows+=("${row}")
      n=$((n + 1))
      # Bucket
      case "${row}" in
        *'"verdict":"succeeded"'*)     won=$((won + 1)) ;;
        *'"verdict":"failed"'*)        lost=$((lost + 1)) ;;
        *'"verdict":"still-running"'*) waiting=$((waiting + 1)) ;;
        *'"verdict":"fetch-failed"'*)  failed=$((failed + 1)) ;;
      esac
    done
    # Emit envelope (avoid jq dep — manual JSON)
    printf '{"summary":{"measured":%d,"won":%d,"lost":%d,"waiting":%d,"failed_fetch":%d},"hypotheses":[' "${n}" "${won}" "${lost}" "${waiting}" "${failed}"
    local first=1
    for r in "${rows[@]}"; do
      [ "${first}" -eq 1 ] || printf ','
      printf '%s' "${r}"
      first=0
    done
    printf ']}\n'
    return 0
  fi
  for f in .lattice/hypotheses/${filter_state}/*.yml; do
    [ -f "${f}" ] || continue
    local slug; slug="$(basename "${f}" .yml)"
    echo "---"
    _grow_measure "${slug}" || true
    n=$((n + 1))
  done
  echo "---"
  echo "[${PROG}] grow check: measured ${n} ${filter_state} hypothes$([ ${n} -eq 1 ] && echo is || echo es)"
}

# v2.0: auto-rollback. DESTRUCTIVE (creates a git revert commit). Default
# DRY-RUN. --execute writes. Always backs up branch tip ref before reverting.
_grow_auto_rollback() {
  [ "$#" -ge 1 ] || die "grow auto-rollback: usage: lattice grow auto-rollback <slug> [--execute] [--yes]"
  local slug="$1"; shift
  local execute=0 auto_yes=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --execute) execute=1; shift ;;
      --yes|-y)  auto_yes=1; shift ;;
      *) die "grow auto-rollback: unknown flag: $1" ;;
    esac
  done

  local p=".lattice/hypotheses/running/${slug}.yml"
  [ -f "${p}" ] || die "grow auto-rollback: ${slug} is not in running/"

  local run_commit
  run_commit="$(yaml_field "${p}" "run_commit")"
  [ -n "${run_commit}" ] || die "grow auto-rollback: ${slug} has no run_commit — cannot revert"

  # Re-evaluate verdict to be safe
  local source baseline threshold window_days run_at
  source="$(_grow_measurement_field "${p}" "source")"
  baseline="$(_grow_measurement_field "${p}" "baseline_value")"
  threshold="$(_grow_measurement_field "${p}" "success_threshold")"
  window_days="$(_grow_measurement_field "${p}" "window_days")"
  run_at="$(yaml_field "${p}" "run_at")"

  local current="(not-fetched)"
  local verdict="manual"
  if [ -n "${source}" ]; then
    if current="$(_grow_fetch_metric "${source}" 2>/dev/null)"; then
      local window_elapsed=0
      if [ -n "${run_at}" ] && [ -n "${window_days}" ]; then
        local now_s run_s
        now_s="$(date -u +%s)"
        run_s="$(date -u -d "${run_at}" +%s 2>/dev/null || echo 0)"
        [ $((now_s - run_s)) -ge $((window_days * 86400)) ] && window_elapsed=1
      fi
      if [ -n "${threshold}" ]; then
        local cmp; cmp="$(_grow_fcmp "${current}" "${threshold}")"
        if [ "${cmp}" -lt 0 ] && [ "${window_elapsed}" -eq 1 ]; then
          verdict="failed"
        elif [ "${cmp}" -ge 0 ]; then
          verdict="succeeded"
        else
          verdict="still-running"
        fi
      fi
    else
      current="(fetch-failed)"
    fi
  fi

  command -v git >/dev/null 2>&1 || die "grow auto-rollback: git required"
  git rev-parse --git-dir >/dev/null 2>&1 || die "grow auto-rollback: not in a git repo"

  # Resolve full SHA + check it's reachable from HEAD
  local full_sha
  full_sha="$(git rev-parse "${run_commit}" 2>/dev/null)" || die "grow auto-rollback: commit not found: ${run_commit}"
  git merge-base --is-ancestor "${full_sha}" HEAD 2>/dev/null || die "grow auto-rollback: ${run_commit} is not an ancestor of HEAD — cannot revert via git revert"

  local current_branch; current_branch="$(git rev-parse --abbrev-ref HEAD)"
  local current_head; current_head="$(git rev-parse HEAD)"

  echo "[${PROG}] auto-rollback plan for ${slug}:"
  echo "  run_commit:    ${run_commit} (full: ${full_sha})"
  echo "  current_branch: ${current_branch}"
  echo "  current_HEAD:  ${current_head}"
  echo "  measure:       verdict=${verdict}, current=${current}, threshold=${threshold:-(unset)}"
  echo ""

  if [ "${verdict}" != "failed" ] && [ "${verdict}" != "manual" ]; then
    echo "[${PROG}] auto-rollback REFUSES: verdict is '${verdict}', not 'failed'. Use \`lattice grow rollback\` (manual) to override."
    return 2
  fi

  echo "  proposed actions (DRY RUN):"
  echo "    1. git update-ref refs/lattice/pre-rollback/${slug} ${current_head}     # backup ref"
  echo "    2. git revert --no-edit ${full_sha}                                      # create revert commit"
  echo "    3. mv .lattice/hypotheses/running/${slug}.yml -> rolled-back/             # transition state"
  echo "    4. stamp rolled_back_at + rollback_reason in YAML"
  echo ""

  if [ "${execute}" -ne 1 ]; then
    echo "[${PROG}] DRY RUN — re-run with --execute to perform the rollback"
    return 0
  fi
  if [ "${auto_yes}" -ne 1 ]; then
    printf "[${PROG}] this will create a NEW revert commit on %s. Continue? [y/N] " "${current_branch}"
    read -r ans
    case "${ans}" in y|Y|yes|YES) ;; *) echo "[${PROG}] aborted"; return 0 ;; esac
  fi

  # 1. Backup ref (recoverable: git update-ref -d refs/lattice/pre-rollback/<slug> + git reset --hard <ref>)
  git update-ref "refs/lattice/pre-rollback/${slug}" "${current_head}" || die "auto-rollback: backup ref write failed"
  echo "[${PROG}] backed up HEAD as refs/lattice/pre-rollback/${slug} (${current_head})"

  # 2. git revert. --no-edit uses default message; trap conflict.
  if ! git revert --no-edit "${full_sha}"; then
    echo "[${PROG}] !!! git revert produced conflicts — aborting revert" >&2
    git revert --abort 2>/dev/null || true
    echo "[${PROG}] !!! state unchanged. Resolve manually:" >&2
    echo "[${PROG}] !!!   git revert ${full_sha}     # then resolve conflicts" >&2
    return 3
  fi
  local revert_sha; revert_sha="$(git rev-parse HEAD)"
  echo "[${PROG}] git revert ok — new commit ${revert_sha}"

  # 3 + 4. Transition YAML
  mkdir -p .lattice/hypotheses/rolled-back 2>/dev/null
  local dst=".lattice/hypotheses/rolled-back/${slug}.yml"
  local now; now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  local reason="auto-rollback: measure verdict=${verdict}, current=${current}, threshold=${threshold:-?}"
  awk -v now="${now}" -v reason="${reason}" -v rsha="${revert_sha}" -v cur="${current}" '
    /^state:/ { print "state: rolled-back"; next }
    { print }
    END {
      print "rolled_back_at: " now
      print "rollback_reason: \"" reason "\""
      print "revert_commit: " rsha
      print "observed_value: " cur
    }
  ' "${p}" > "${dst}.tmp" && mv "${dst}.tmp" "${dst}"
  rm "${p}"

  echo "[${PROG}] grow: ${slug} -> rolled-back (revert: ${revert_sha}, backup: refs/lattice/pre-rollback/${slug})"
  echo "[${PROG}] to undo this rollback:"
  echo "  git reset --hard refs/lattice/pre-rollback/${slug}"
  echo "  mv ${dst} .lattice/hypotheses/running/${slug}.yml"
}

# v2.1 (#60 #2): retrofit measurement block into an existing hypothesis YAML
# (in any state). Without this, users who proposed before v1.4.2 had to
# hand-edit YAML to add measurement fields.
_grow_attach_measurement() {
  [ "$#" -ge 1 ] || die "grow attach-measurement: usage: lattice grow attach-measurement <slug> --metric-name X --measurement-source Y --baseline-value Z [...]"
  local slug="$1"; shift
  local metric_name="" measurement_source="" baseline_value="" baseline_source=""
  local expected_delta="" success_threshold="" window_days=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --metric-name)        metric_name="$2"; shift 2 ;;
      --measurement-source) measurement_source="$2"; shift 2 ;;
      --baseline-value)     baseline_value="$2"; shift 2 ;;
      --baseline-source)    baseline_source="$2"; shift 2 ;;
      --expected-delta)     expected_delta="$2"; shift 2 ;;
      --success-threshold)  success_threshold="$2"; shift 2 ;;
      --window-days)        window_days="$2"; shift 2 ;;
      *) die "grow attach-measurement: unknown flag: $1" ;;
    esac
  done
  local p; p="$(_grow_resolve "${slug}")" || die "grow attach-measurement: hypothesis not found: ${slug}"
  if grep -q '^measurement:' "${p}" 2>/dev/null; then
    die "grow attach-measurement: ${p} already has a measurement block — edit YAML manually or remove it first"
  fi
  [ -n "${measurement_source}" ] || die "grow attach-measurement: --measurement-source required"

  # Insert measurement block AFTER the metric: line (or after cadence: line if no metric:)
  local tmp; tmp="$(mktemp 2>/dev/null || echo "${p}.tmp")"
  awk -v mn="${metric_name}" -v ms="${measurement_source}" -v bv="${baseline_value}" \
      -v bs="${baseline_source}" -v ed="${expected_delta}" -v st="${success_threshold}" \
      -v wd="${window_days}" '
    { print }
    /^metric:/ && !inserted {
      print "measurement:"
      if (mn != "") print "  name: \"" mn "\""
      if (ms != "") print "  source: \"" ms "\""
      if (bv != "") print "  baseline_value: " bv
      if (bs != "") print "  baseline_source: \"" bs "\""
      if (ed != "") print "  expected_delta: " ed
      if (st != "") print "  success_threshold: " st
      if (wd != "") print "  window_days: " wd
      inserted=1
    }
  ' "${p}" > "${tmp}" && mv "${tmp}" "${p}"
  echo "[${PROG}] grow attach-measurement: added measurement block to ${p}"
  echo "[${PROG}] verify: lattice grow show ${slug}"
}

# v2.1 (#61): schedule install/status/uninstall/trigger. Generates GitHub
# Actions workflow that runs `lattice grow check --json` weekly and pipes the
# result to lattice-grow-telegram.mjs (which formats + POSTs to Telegram).
_grow_schedule() {
  local action="${1:-status}"; shift || true
  case "${action}" in
    install)   _grow_schedule_install "$@" ;;
    status)    _grow_schedule_status "$@" ;;
    uninstall) _grow_schedule_uninstall "$@" ;;
    trigger)   _grow_schedule_trigger "$@" ;;
    --help|-h|help)
      cat <<'SCHHELP'
lattice grow schedule — autonomous check loop (v2.1 #61)

  install [--transport github-actions|local-cron] [--time HH:MM] [--day mon|...]
          [--auto-action]                     wire up cron + Telegram updates
                                              --auto-action: also open @claude
                                              GH issues for succeeded/failed
                                              verdicts (v2.2 #66)
  status                                      show current schedule + config
  uninstall                                   remove the workflow file
  trigger                                     manually fire a check now

GitHub Actions transport requires these repo secrets:
  TELEGRAM_BOT_TOKEN
  TELEGRAM_CHAT_ID
Set them at: github.com/<owner>/<repo>/settings/secrets/actions
SCHHELP
      ;;
    *) die "grow schedule: unknown action: ${action} (try: install | status | uninstall | trigger)" ;;
  esac
}

_grow_schedule_install() {
  local transport="github-actions" time="09:00" day="mon" tz_mode="local" auto_action=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --transport)   transport="$2"; shift 2 ;;
      --time)        time="$2"; shift 2 ;;
      --day)         day="$2"; shift 2 ;;
      --utc)         tz_mode="utc"; shift ;;
      --auto-action) auto_action=1; shift ;;
      *) die "grow schedule install: unknown flag: $1" ;;
    esac
  done

  case "${transport}" in
    github-actions) ;;
    local-cron) echo "[${PROG}] grow schedule: local-cron transport — emitting crontab line for user to paste"
                local h="${time%%:*}" m="${time##*:}"
                local dow; case "${day}" in mon)dow=1;;tue)dow=2;;wed)dow=3;;thu)dow=4;;fri)dow=5;;sat)dow=6;;sun)dow=0;;*)dow=1;;esac
                echo "  ${m} ${h} * * ${dow} cd $(pwd) && lattice grow check --json | node ${SELF_DIR}/lattice-grow-telegram.mjs"
                return 0 ;;
    *) die "grow schedule install: --transport must be github-actions or local-cron" ;;
  esac

  command -v git >/dev/null 2>&1 || die "grow schedule install: git required"
  git rev-parse --git-dir >/dev/null 2>&1 || die "grow schedule install: not in a git repo"

  # v2.1.1 (#62): interpret --time as user-local by default (Option A from
  # the issue). Detect local timezone offset via `date +%z`, shift to UTC for
  # the cron expression. --utc opts out (treat HH:MM as already-UTC).
  local hh="${time%%:*}" mm="${time##*:}"
  hh="${hh#0}"; mm="${mm#0}"
  [ -z "${hh}" ] && hh=9
  [ -z "${mm}" ] && mm=0
  local dow; case "${day,,}" in mon)dow=1;;tue)dow=2;;wed)dow=3;;thu)dow=4;;fri)dow=5;;sat)dow=6;;sun)dow=0;;*)dow=1;;esac

  local local_tz="" local_offset_min=0 utc_hh="${hh}" utc_mm="${mm}" utc_dow="${dow}"
  if [ "${tz_mode}" = "local" ]; then
    # Get offset like "+0530" or "-0700"
    local off; off="$(date +%z 2>/dev/null)"
    local_tz="$(date +%Z 2>/dev/null)"
    if [[ "${off}" =~ ^([+-])([0-9]{2})([0-9]{2})$ ]]; then
      local sign="${BASH_REMATCH[1]}" oh="${BASH_REMATCH[2]}" om="${BASH_REMATCH[3]}"
      oh="${oh#0}"; om="${om#0}"
      [ -z "${oh}" ] && oh=0; [ -z "${om}" ] && om=0
      local_offset_min=$((oh * 60 + om))
      [ "${sign}" = "-" ] && local_offset_min=$((0 - local_offset_min))
      # UTC = local - offset
      local total_local_min=$((hh * 60 + mm))
      local total_utc_min=$((total_local_min - local_offset_min))
      # Day rollover
      if [ "${total_utc_min}" -lt 0 ]; then
        total_utc_min=$((total_utc_min + 1440))
        utc_dow=$(( (dow + 6) % 7 ))  # -1 day
      elif [ "${total_utc_min}" -ge 1440 ]; then
        total_utc_min=$((total_utc_min - 1440))
        utc_dow=$(( (dow + 1) % 7 ))  # +1 day
      fi
      utc_hh=$((total_utc_min / 60))
      utc_mm=$((total_utc_min % 60))
    else
      echo "[${PROG}] grow schedule: WARN: could not detect local timezone offset — treating --time as UTC" >&2
    fi
  fi
  local cron_expr="${utc_mm} ${utc_hh} * * ${utc_dow}"

  mkdir -p .github/workflows 2>/dev/null
  local wf=".github/workflows/lattice-grow-check.yml"
  if [ -f "${wf}" ]; then
    echo "[${PROG}] grow schedule: ${wf} already exists — refusing to overwrite"
    echo "[${PROG}] remove with: lattice grow schedule uninstall"
    return 1
  fi

  # v2.2 (#66): when --auto-action is set, the workflow needs issues:write so
  # the @claude-dispatch step can file issues. Otherwise the default token's
  # contents:read is sufficient (just posts to Telegram).
  local perms_block=""
  if [ "${auto_action}" -eq 1 ]; then
    perms_block=$'\n    permissions:\n      issues: write\n      contents: read'
  fi

  cat > "${wf}" <<WORKFLOW
# Generated by \`lattice grow schedule install\`.
# Remove with: lattice grow schedule uninstall
# Manual trigger: GitHub Actions UI "Run workflow", or \`lattice grow schedule trigger\`
name: lattice grow check
on:
  schedule:
    # v2.1.1 (#62): UTC equivalent of ${hh}:${mm} ${local_tz:-UTC}
    - cron: '${cron_expr}'
  workflow_dispatch:

jobs:
  check:
    runs-on: ubuntu-latest${perms_block}
    # v2.1.1 (#64): pin Node 22 to dodge the 2026-06-02 Node 20 deprecation.
    # Actions/checkout@v4 itself is fine; explicit setup-node ensures any
    # subsequent JavaScript actions use Node 22.
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - uses: actions/setup-node@v4
        with:
          node-version: '22'

      - name: Install Lattice
        run: |
          curl -fsSL https://raw.githubusercontent.com/IsaamMJ/Lattice/main/scripts/install.sh | LATTICE_INSTALL_NO_PROMPT=1 bash

      - name: Run grow check
        id: check
        run: |
          export PATH="\$HOME/.local/bin:\$PATH"
          lattice grow check --json > /tmp/grow-check.json
          cat /tmp/grow-check.json

      - name: Post to Telegram
        # v2.1.3 (#75): GH Actions rejects \`secrets\` in if: expressions
        # ('Unrecognized named-value'). Always run; formatter exits cleanly
        # when tokens are absent (per v2.1.0 design).
        env:
          TELEGRAM_BOT_TOKEN: \${{ secrets.TELEGRAM_BOT_TOKEN }}
          TELEGRAM_CHAT_ID: \${{ secrets.TELEGRAM_CHAT_ID }}
          REPO_NAME: \${{ github.repository }}
        run: |
          export PATH="\$HOME/.local/bin:\$PATH"
          FORMATTER="\$HOME/.claude/lattice/scripts/lattice-grow-telegram.mjs"
          if [ -z "\${TELEGRAM_BOT_TOKEN:-}" ] || [ -z "\${TELEGRAM_CHAT_ID:-}" ]; then
            echo "::notice::TELEGRAM_BOT_TOKEN or TELEGRAM_CHAT_ID secret not set — skipping notification"
            exit 0
          fi
          if [ -f "\$FORMATTER" ]; then
            node "\$FORMATTER" < /tmp/grow-check.json
          else
            echo "::warning::lattice-grow-telegram.mjs not found — skipping Telegram notification"
          fi
WORKFLOW

  # v2.2 (#66): autonomous-action step — opens a @claude-mentioning issue for
  # every succeeded/failed hypothesis verdict. @claude GitHub App sees the
  # mention, opens a branch, runs the close/rollback command, opens a PR for
  # `failed` (human approves) or commits direct for `succeeded` (low risk).
  if [ "${auto_action}" -eq 1 ]; then
    cat >> "${wf}" <<'AUTOWORKFLOW'

      - name: Dispatch @claude autonomous action
        # v2.2 #66: for every hypothesis with verdict succeeded or failed,
        # open a GH issue mentioning @claude with the exact close/rollback
        # command. The @claude GitHub App (installed separately at org level)
        # then runs the command and opens a PR.
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
          REPO: ${{ github.repository }}
        run: |
          if [ ! -s /tmp/grow-check.json ]; then
            echo "::notice::no grow-check.json — skipping autonomous action"
            exit 0
          fi
          node - <<'NODE'
          const fs = require("fs");
          const { execSync } = require("child_process");
          let payload;
          try { payload = JSON.parse(fs.readFileSync("/tmp/grow-check.json","utf8")); }
          catch (e) { console.error("[auto-action] grow-check.json parse:", e.message); process.exit(0); }
          const rows = Array.isArray(payload?.results) ? payload.results : [];
          let dispatched = 0;
          for (const r of rows) {
            const slug = r.slug || r.id || "(unknown)";
            const verdict = r.verdict || "?";
            if (verdict !== "succeeded" && verdict !== "failed") continue;
            const observed = r.combined_value ?? r.observed_value ?? "";
            let title, body;
            if (verdict === "succeeded") {
              title = `@claude grow close ${slug} (won)`;
              body  = `Hypothesis ${slug} succeeded with observed=${observed}.\n\n` +
                      `@claude please run:\n\n` +
                      `\`\`\`\nlattice grow close ${slug} --result won --observed-value ${observed} --rationale "auto-closed: grow check verdict=succeeded"\n\`\`\`\n\n` +
                      `Commit + push to main directly — this is a low-risk YAML rename.`;
            } else {
              title = `@claude grow auto-rollback ${slug} (failed)`;
              body  = `Hypothesis ${slug} failed with observed=${observed}.\n\n` +
                      `@claude please open a PR (NOT direct push) running:\n\n` +
                      `\`\`\`\nlattice grow auto-rollback ${slug} --execute --yes\n\`\`\`\n\n` +
                      `This will git-revert the run commit. Human approval required on the PR.`;
            }
            try {
              execSync(`gh issue create -R "${process.env.REPO}" -t ${JSON.stringify(title)} -b ${JSON.stringify(body)} -l lattice-auto-action`, { stdio: "inherit" });
              dispatched++;
            } catch (e) {
              console.error(`[auto-action] gh issue create failed for ${slug}:`, e.message);
            }
          }
          console.log(`[auto-action] dispatched ${dispatched} @claude issue(s)`);
          NODE
AUTOWORKFLOW
  fi

  echo "[${PROG}] grow schedule: wrote ${wf}"
  # v2.1.1 (#62): print both local AND UTC interpretations so user can verify.
  local utc_day; case "${utc_dow}" in 0)utc_day=SUN;;1)utc_day=MON;;2)utc_day=TUE;;3)utc_day=WED;;4)utc_day=THU;;5)utc_day=FRI;;6)utc_day=SAT;;esac
  if [ "${tz_mode}" = "local" ] && [ -n "${local_tz}" ]; then
    echo "[${PROG}] cron expression: ${cron_expr} (UTC) — fires ${utc_day} at $(printf '%02d:%02d' "${utc_hh}" "${utc_mm}") UTC"
    echo "[${PROG}]                  = ${day^^} ${time} ${local_tz} (local). Override with --utc to treat --time as UTC."
  else
    echo "[${PROG}] cron expression: ${cron_expr} (UTC) — fires ${utc_day} at ${time} UTC"
  fi
  echo ""
  echo "[${PROG}] required GitHub repo secrets (optional — without them, the workflow runs but doesn't post to Telegram):"
  echo "  TELEGRAM_BOT_TOKEN"
  echo "  TELEGRAM_CHAT_ID"
  echo ""
  echo "[${PROG}] set them at: github.com/<owner>/<repo>/settings/secrets/actions"
  echo "[${PROG}] commit + push ${wf} to enable. Manual test: \`lattice grow schedule trigger\`"
}

_grow_schedule_status() {
  local wf=".github/workflows/lattice-grow-check.yml"
  if [ ! -f "${wf}" ]; then
    echo "[${PROG}] grow schedule: not installed in this project (${wf} absent)"
    return 0
  fi
  echo "[${PROG}] grow schedule:"
  echo "  workflow:   ${wf}"
  local cron_line; cron_line="$(grep -E "^[[:space:]]+- cron:" "${wf}" | head -1 | sed -E "s/^[[:space:]]+- cron:[[:space:]]+'(.*)'$/\1/")"
  echo "  cron:       ${cron_line}"
  # v2.1.1 (#65): render last-run JSON as human-readable, not bash array literal
  if command -v gh >/dev/null 2>&1 && gh auth status >/dev/null 2>&1; then
    if command -v node >/dev/null 2>&1; then
      local last_json; last_json="$(gh run list --workflow lattice-grow-check.yml --limit 1 --json status,conclusion,createdAt,databaseId 2>/dev/null || echo '[]')"
      local rendered
      rendered="$(printf '%s' "${last_json}" | node -e '
let s=""; process.stdin.on("data",d=>s+=d).on("end",()=>{
  try {
    const a=JSON.parse(s);
    if(!a || !a.length) { process.stdout.write("never"); return; }
    const r=a[0];
    const ts=r.createdAt || "?";
    const id=r.databaseId || "?";
    const verdict = r.conclusion || r.status || "?";
    process.stdout.write(`${ts}  ${verdict}  (id ${id})`);
  } catch(e){ process.stdout.write("(parse error)"); }
});')"
      echo "  last run:   ${rendered:-never}"
    fi
  else
    echo "  last run:   (gh not authed — \`gh auth login\` to fetch run history)"
  fi
}

_grow_schedule_uninstall() {
  local wf=".github/workflows/lattice-grow-check.yml"
  if [ ! -f "${wf}" ]; then
    echo "[${PROG}] grow schedule: nothing to uninstall (${wf} absent)"
    return 0
  fi
  printf "[${PROG}] grow schedule: remove %s? [y/N] " "${wf}"
  read -r ans
  case "${ans}" in y|Y|yes|YES) rm -f "${wf}"; echo "[${PROG}] removed ${wf}";; *) echo "[${PROG}] aborted";; esac
}

_grow_schedule_trigger() {
  command -v gh >/dev/null 2>&1 || die "grow schedule trigger: gh CLI required for workflow_dispatch"
  gh workflow run lattice-grow-check.yml 2>&1 | sed "s/^/[${PROG}] /"
  # v2.1.1 (#65): capture the new run ID and emit a concrete watch command.
  # GitHub takes 1-2s to register the new run; poll briefly.
  local run_id=""
  local attempt=0
  while [ "${attempt}" -lt 6 ] && [ -z "${run_id}" ]; do
    sleep 1
    run_id="$(gh run list --workflow lattice-grow-check.yml --limit 1 --json databaseId,status -q '.[0] | select(.status=="queued" or .status=="in_progress") | .databaseId' 2>/dev/null)"
    attempt=$((attempt + 1))
  done
  if [ -n "${run_id}" ]; then
    echo "[${PROG}] triggered run ${run_id}"
    echo "[${PROG}] watch:  gh run watch ${run_id}"
    echo "[${PROG}] view:   gh run view ${run_id}"
  else
    echo "[${PROG}] triggered (run ID not captured — GitHub still registering)"
    echo "[${PROG}] watch:  gh run watch    # picks from list"
  fi
}

_grow_close() {
  [ "$#" -ge 1 ] || die "grow close: usage: lattice grow close <slug> --result <won|lost|inconclusive>"
  local slug="$1"; shift
  local result="" rationale=""
  # v1.4.2 (#59): capture observed value at close time
  local observed_value=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --result)         result="$2"; shift 2 ;;
      --rationale)      rationale="$2"; shift 2 ;;
      --observed-value) observed_value="$2"; shift 2 ;;
      *) die "grow close: unknown flag: $1" ;;
    esac
  done
  [ -n "${result}" ] || die "grow close: --result <won|lost|inconclusive> required"
  case "${result}" in won|lost|inconclusive) ;; *) die "grow close: --result must be won|lost|inconclusive" ;; esac

  local src
  for state in running open; do
    [ -f ".lattice/hypotheses/${state}/${slug}.yml" ] && { src=".lattice/hypotheses/${state}/${slug}.yml"; break; }
  done
  [ -n "${src:-}" ] || die "grow close: hypothesis not found in open/ or running/: ${slug}"

  mkdir -p .lattice/hypotheses/closed 2>/dev/null
  local dst=".lattice/hypotheses/closed/${slug}.yml"
  local now; now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  awk -v now="${now}" -v r="${result}" -v rat="${rationale}" -v ov="${observed_value}" '
    /^state:/ { print "state: closed"; next }
    { print }
    END {
      print "closed_at: " now
      print "result: " r
      if (ov != "") print "observed_value: " ov
      if (rat != "") print "rationale: \"" rat "\""
    }
  ' "${src}" > "${dst}.tmp" && mv "${dst}.tmp" "${dst}"
  rm "${src}"
  echo "[${PROG}] grow: ${slug} -> closed (${result})"
}

# ---------------------------------------------------------------------------
# audit-infra — audit Claude Code infrastructure adequacy for the stack
# present in cwd. v1.3.0 (#36). Detects missing hooks, missing MCPs, missing
# protections based on what files/deps are present.
#
# Examples:
#   tsconfig.json + no PostToolUse type-check hook -> infra-missing-typecheck-hook
#   .env* present + no PreToolUse env-protect block -> infra-missing-env-protection
#   Next.js + no context7 MCP -> infra-missing-mcp-context7
#
# Usage:
#   lattice audit-infra [--path .] [--write]
# ---------------------------------------------------------------------------
cmd_audit_infra() {
  local target="." write=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --path)  target="$2"; shift 2 ;;
      --write) write=1; shift ;;
      --help|-h)
        cat <<'INFRA_HELP'
lattice audit-infra — audit Claude Code infrastructure adequacy

  --path <dir>   project root (default: .)
  --write        emit findings to .lattice/findings/open/ (default: stdout)

Detects:
  - missing PostToolUse type-check hook when tsconfig present
  - missing PreToolUse env-protect block when .env* files present
  - missing lockfile edit-block when package-lock.json present
  - missing supabase MCP when @supabase/supabase-js in deps
  - missing playwright MCP when Next.js + React detected
  - missing context7 MCP on bleeding-edge framework versions
INFRA_HELP
        return 0 ;;
      *) die "audit-infra: extra arg: $1" ;;
    esac
  done
  [ -d "${target}" ] || die "audit-infra: path not found: ${target}"

  command -v node >/dev/null 2>&1 || die "audit-infra: node required"

  local sweep_id="${LATTICE_SWEEP_ID:-$(date -u +%Y%m%d)$(printf '%06x' "$$" | tail -c6)}"
  local today; today="$(date -u +%Y-%m-%d)"
  if [ "${write}" -eq 1 ]; then
    ensure_project_dirs
    mkdir -p .lattice/findings/open
  fi

  node - "${target}" "${write}" "${sweep_id}" "${today}" <<'NODEJS'
const fs = require("fs");
const path = require("path");
// argv when using node -: [nodePath, "-", ...userArgs]
const [,, root, writeStr, sweepId, today] = process.argv;
const write = writeStr === "1";

function exists(p) { return fs.existsSync(path.join(root, p)); }
function readJSON(p) {
  try { return JSON.parse(fs.readFileSync(path.join(root, p), "utf8")); } catch { return null; }
}
function readText(p) {
  try { return fs.readFileSync(path.join(root, p), "utf8"); } catch { return ""; }
}
function hasDep(pkg, name) {
  if (!pkg) return false;
  return !!((pkg.dependencies && pkg.dependencies[name]) ||
            (pkg.devDependencies && pkg.devDependencies[name]) ||
            (pkg.peerDependencies && pkg.peerDependencies[name]));
}

// Load Claude Code settings (project-level + user-level + global)
const projectSettings = readJSON(".claude/settings.json") || readJSON(".claude/settings.local.json") || {};
const userSettings = (() => {
  const home = process.env.USERPROFILE || process.env.HOME;
  if (!home) return {};
  try { return JSON.parse(fs.readFileSync(path.join(home, ".claude/settings.json"), "utf8")); } catch { return {}; }
})();
const mergedSettings = { ...userSettings, ...projectSettings };
const hooks = mergedSettings.hooks || {};

const pkg = readJSON("package.json");
const findings = [];

function emit(slug, tier, rule, title, fix, exposure = "infra") {
  findings.push({ slug, tier, rule, title, fix, exposure });
}

// --- Detector: TypeScript without typecheck hook ---
if (exists("tsconfig.json") || exists("tsconfig.base.json")) {
  const post = hooks.PostToolUse || [];
  const hasTypecheck = post.some(g => (g?.hooks || []).some(h =>
    typeof h?.command === "string" && /tsc|type-?check|tsgo/i.test(h.command)
  ));
  if (!hasTypecheck) {
    emit("infra-missing-typecheck-hook", "MEDIUM", "infra-missing-typecheck-hook",
      "TypeScript project has no PostToolUse type-check hook in Claude settings",
      "Add a PostToolUse hook running `tsc --noEmit` so type regressions are caught on every edit. See claude-code-setup plugin reference."
    );
  }
}

// --- Detector: .env* present without PreToolUse protection ---
let hasEnvFiles = false;
try {
  for (const f of fs.readdirSync(root)) {
    if (/^\.env($|\.)/.test(f)) { hasEnvFiles = true; break; }
  }
} catch {}
if (hasEnvFiles) {
  const pre = hooks.PreToolUse || [];
  const hasEnvBlock = pre.some(g => {
    const matcher = g?.matcher || "";
    const cmds = (g?.hooks || []).map(h => h?.command || "").join(" ");
    return /env|secret/i.test(matcher) || /\.env/i.test(cmds);
  });
  if (!hasEnvBlock) {
    emit("infra-missing-env-protection", "HIGH", "infra-missing-env-protection",
      ".env files present but no PreToolUse block guards edits to env paths",
      "Add a PreToolUse Edit/Write matcher that blocks (or warns + requires confirmation) on .env* paths. Prevents secrets from being committed or rewritten without explicit consent."
    );
  }
}

// --- Detector: lockfile without edit protection ---
const lockfiles = ["package-lock.json", "yarn.lock", "pnpm-lock.yaml", "bun.lockb"];
const presentLock = lockfiles.find(f => exists(f));
if (presentLock) {
  const pre = hooks.PreToolUse || [];
  const hasLockBlock = pre.some(g => {
    const cmds = (g?.hooks || []).map(h => h?.command || "").join(" ");
    return /lock/i.test(cmds) || /package-lock|yarn\.lock|pnpm-lock/i.test(cmds);
  });
  if (!hasLockBlock) {
    emit("infra-missing-lockfile-protection", "LOW", "infra-missing-lockfile-protection",
      `${presentLock} present but no edit-block hook guards lockfile mutations`,
      "Add a PreToolUse hook that flags Edit/Write to the lockfile so Claude doesn't silently invalidate the dep tree."
    );
  }
}

// --- Detector: MCP servers based on deps ---
const mcpServers = mergedSettings.mcpServers || {};
const claudeDotJson = (() => {
  const home = process.env.USERPROFILE || process.env.HOME;
  if (!home) return {};
  try { return JSON.parse(fs.readFileSync(path.join(home, ".claude.json"), "utf8")); } catch { return {}; }
})();
const allMCP = { ...mcpServers, ...(claudeDotJson.mcpServers || {}) };

function hasMCP(name) {
  return !!allMCP[name] || Object.keys(allMCP).some(k => k.toLowerCase().includes(name.toLowerCase()));
}

if (hasDep(pkg, "@supabase/supabase-js") && !hasMCP("supabase")) {
  emit("infra-missing-mcp-supabase", "MEDIUM", "infra-missing-mcp-supabase",
    "@supabase/supabase-js in deps but no Supabase MCP wired",
    "Wire the Supabase MCP into ~/.claude.json so Claude can query schema, run migrations, and inspect RLS without fabricating."
  );
}

const isNext = hasDep(pkg, "next");
const isReact = hasDep(pkg, "react");
if (isNext && isReact && !hasMCP("playwright") && !hasMCP("puppeteer")) {
  emit("infra-missing-mcp-playwright", "MEDIUM", "infra-missing-mcp-playwright",
    "Next.js + React project without a browser-automation MCP (playwright / puppeteer)",
    "Wire Playwright MCP for frontend verification. Without it, Claude can't visually verify UI changes — the source of many `claimed-fix-but-broken-in-browser` regressions."
  );
}

// Bleeding-edge versions -> recommend context7 MCP
function isBleedingEdge(name, major) {
  if (!pkg) return false;
  const v = (pkg.dependencies?.[name] || pkg.devDependencies?.[name] || "").replace(/[^0-9.]/g, "");
  if (!v) return false;
  const m = parseInt(v.split(".")[0], 10);
  return Number.isFinite(m) && m >= major;
}
if ((isBleedingEdge("next", 15) || isBleedingEdge("react", 19)) && !hasMCP("context7")) {
  emit("infra-missing-mcp-context7", "MEDIUM", "infra-missing-mcp-context7",
    "Bleeding-edge framework (Next 15+ / React 19+) without context7 MCP",
    "Wire context7 MCP so Claude pulls live docs for new APIs instead of hallucinating. Without it, Claude often emits APIs from older Next.js versions."
  );
}

// --- Detector: Jest/pytest without test-on-edit hook ---
const hasJest = hasDep(pkg, "jest") || hasDep(pkg, "vitest");
const hasPytest = exists("pytest.ini") || exists("pyproject.toml") && /pytest/.test(readText("pyproject.toml"));
if ((hasJest || hasPytest) && !((hooks.PostToolUse || []).some(g =>
    (g?.hooks || []).some(h => /jest|vitest|pytest|test/i.test(h?.command || ""))
))) {
  emit("infra-missing-test-hook", "LOW", "infra-missing-test-hook",
    `Test runner detected (${hasJest ? "jest/vitest" : "pytest"}) but no PostToolUse hook re-runs related tests on edit`,
    "Add a PostToolUse hook that runs `jest --findRelatedTests` (or `pytest -k file`) on the edited file. Catches regressions before commit."
  );
}

// Emit
if (write) {
  for (const f of findings) {
    const filename = `.lattice/findings/open/${f.tier}-infra-${f.rule}.yml`;
    const yml = [
      `id: ${require("crypto").createHash("sha1").update(`infra:${f.rule}:${root}:${f.title}`).digest("hex").slice(0, 12)}`,
      `rule: ${f.rule}`,
      `dimension: infra`,
      `tier: ${f.tier}`,
      `module: infra`,
      `file: .claude/settings.json`,
      `line: 1`,
      `title: "${f.title.replace(/"/g, '\\"')}"`,
      `fix: "${f.fix.replace(/"/g, '\\"')}"`,
      `sweep_date: ${today}`,
      `sweep_id: ${sweepId}`,
      `auditor: lattice/audit-infra@1.3.0`,
      `status: open`,
      `exposure: ${f.exposure}`,
      ``
    ].join("\n");
    fs.writeFileSync(path.join(root, filename), yml, "utf8");
    process.stderr.write(`[lattice] emitted: ${filename}\n`);
  }
  process.stderr.write(`[lattice] audit-infra: ${findings.length} finding(s) written\n`);
} else {
  if (findings.length === 0) {
    process.stdout.write(`[lattice] audit-infra: 0 findings — infrastructure looks adequate for the detected stack\n`);
  } else {
    process.stdout.write(`tier      rule                              title\n`);
    for (const f of findings) {
      process.stdout.write(`${f.tier.padEnd(9)} ${f.rule.padEnd(33)} ${f.title}\n`);
    }
    process.stdout.write(`\n[lattice] audit-infra: ${findings.length} finding(s) (re-run with --write to emit YAMLs)\n`);
  }
}
NODEJS
}

# ---------------------------------------------------------------------------
# diff — diff two sweep manifests by their slug sets. v1.2.0 (#43).
# Surfaces what changed between two audit sweeps. The sweep manifest at
# .lattice/findings/sweeps/<sweep-id>.yml already carries opened / unchanged /
# closed_since_last / regressed arrays; this command renders the diff between
# two manifests as a single table.
#
# Usage:
#   lattice diff <sweep-id-a> <sweep-id-b>   # compare two specific sweeps
#   lattice diff <sweep-id>                  # compare against previous sweep
#   lattice diff --latest                    # compare last two sweeps
# ---------------------------------------------------------------------------
cmd_diff() {
  local a="" b=""
  case "${1:-}" in
    --latest|"")
      # Find the two most-recent sweep manifests
      mapfile -t _sweeps < <(ls -t .lattice/findings/sweeps/*.yml 2>/dev/null | head -2)
      [ "${#_sweeps[@]}" -lt 2 ] && die "diff: need at least 2 sweep manifests in .lattice/findings/sweeps/"
      b="$(basename "${_sweeps[0]}" .yml)"
      a="$(basename "${_sweeps[1]}" .yml)"
      ;;
    --help|-h)
      cat <<'DIFF_HELP'
lattice diff — compare two sweep manifests

  lattice diff <sweep-id-a> <sweep-id-b>   # compare two specific sweeps
  lattice diff <sweep-id>                  # compare against previous sweep
  lattice diff --latest                    # compare last two sweeps

Sweep manifests live at .lattice/findings/sweeps/<sweep-id>.yml.
Output: table of opened / closed / unchanged / regressed counts per dimension.
DIFF_HELP
      return 0 ;;
    *)
      if [ -n "${2:-}" ]; then
        a="$1"; b="$2"
      else
        # Single arg — compare against previous sweep on disk
        b="$1"
        mapfile -t _sweeps < <(ls -t .lattice/findings/sweeps/*.yml 2>/dev/null)
        local found=0
        for s in "${_sweeps[@]}"; do
          local stem; stem="$(basename "${s}" .yml)"
          if [ "${found}" -eq 1 ]; then a="${stem}"; break; fi
          [ "${stem}" = "${b}" ] && found=1
        done
        [ -z "${a}" ] && die "diff: no sweep older than ${b} found"
      fi
      ;;
  esac

  local fa=".lattice/findings/sweeps/${a}.yml"
  local fb=".lattice/findings/sweeps/${b}.yml"
  [ -f "${fa}" ] || die "diff: manifest not found: ${fa}"
  [ -f "${fb}" ] || die "diff: manifest not found: ${fb}"

  command -v node >/dev/null 2>&1 || die "diff: node required"

  node - "${fa}" "${fb}" <<'NODEJS'
const fs = require("fs");
// node - argv: [nodePath, "-", ...userArgs]
const [,, fa, fb] = process.argv;

function parseManifest(p) {
  const text = fs.readFileSync(p, "utf8");
  const lines = text.split(/\r?\n/);
  // Pull the slug arrays under opened:, unchanged:, closed_since_last:, regressed:
  const out = { opened: [], unchanged: [], closed_since_last: [], regressed: [], sweep_id: "", sweep_date: "", totals: {} };
  let curList = null;
  for (const raw of lines) {
    const line = raw.replace(/\r$/, "");
    if (line.match(/^opened:\s*$/)) { curList = "opened"; continue; }
    if (line.match(/^unchanged:\s*$/)) { curList = "unchanged"; continue; }
    if (line.match(/^closed_since_last:\s*$/)) { curList = "closed_since_last"; continue; }
    if (line.match(/^regressed:\s*$/)) { curList = "regressed"; continue; }
    if (line.match(/^sweep_id:\s*(.+)$/)) out.sweep_id = RegExp.$1.replace(/^["']|["']$/g, "");
    else if (line.match(/^sweep_date:\s*(.+)$/)) out.sweep_date = RegExp.$1.replace(/^["']|["']$/g, "");
    if (curList && line.match(/^\s+-\s+(.+)$/)) {
      out[curList].push(RegExp.$1.replace(/^["']|["']$/g, "").trim());
      continue;
    }
    // List ended — non-list line that isn't a continuation
    if (curList && /^\S/.test(line)) curList = null;
  }
  return out;
}

const A = parseManifest(fa);
const B = parseManifest(fb);

const setA = new Set(A.opened);
const setB = new Set(B.opened);

const newlyOpened = [...setB].filter(s => !setA.has(s));
const newlyClosed = [...setA].filter(s => !setB.has(s));
const stillOpen = [...setA].filter(s => setB.has(s));

console.log(`# Sweep diff: ${A.sweep_id || fa} -> ${B.sweep_id || fb}`);
console.log(`#   A: ${A.sweep_date}  (${A.opened.length} open)`);
console.log(`#   B: ${B.sweep_date}  (${B.opened.length} open)`);
console.log("");
console.log(`opened (B not in A): ${newlyOpened.length}`);
for (const s of newlyOpened) console.log(`  + ${s}`);
console.log("");
console.log(`closed (A not in B): ${newlyClosed.length}`);
for (const s of newlyClosed) console.log(`  - ${s}`);
console.log("");
console.log(`unchanged (in both): ${stillOpen.length}`);
if (stillOpen.length <= 10) {
  for (const s of stillOpen) console.log(`  = ${s}`);
} else {
  console.log(`  (${stillOpen.length} slugs — too many to list; pass --verbose to print)`);
}
NODEJS
}

# ---------------------------------------------------------------------------
# write-manifest — wrap scripts/lattice-write-manifest.sh so it's reachable
# from project dirs via the lattice dispatcher. v1.2.0 (#48). The audit-sweep
# skill's Step 3 instruction now points at `lattice write-manifest`, removing
# the broken "bash scripts/lattice-write-manifest.sh" reference.
# ---------------------------------------------------------------------------
cmd_write_manifest() {
  local helper="${SELF_DIR}/lattice-write-manifest.sh"
  if [ ! -f "${helper}" ]; then
    helper="${HOME}/.claude/lattice/scripts/lattice-write-manifest.sh"
  fi
  [ -f "${helper}" ] || die "write-manifest: helper not found at ${SELF_DIR}/ or ~/.claude/lattice/scripts/"
  bash "${helper}" "$@"
}

# ---------------------------------------------------------------------------
# normalize — walk .lattice/findings/open/*.yml and canonicalize each file's
# id + filename. Fixes two friction surfaces:
#   #44: leading-dot module paths (.claude/agents) producing slugs like
#        LOW-.claude-agents-...; sanitize leading dots in module segments.
#   #52: fabricated ids — subagents synthesize 16-hex ids instead of running
#        `lattice id-gen`. Normalize re-derives ids from the (dimension, rule,
#        file, line) tuple per the v0.7 algorithm.
#
# Usage:
#   lattice normalize                # dry-run: list files that would change
#   lattice normalize --apply        # rewrite ids in place + rename files
#
# v1.1.2 (#44 #52).
# ---------------------------------------------------------------------------
cmd_normalize() {
  local apply=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --apply) apply=1; shift ;;
      --help|-h)
        cat <<'NORM_HELP'
lattice normalize — canonicalize finding ids + filenames in .lattice/findings/open/

  (default)     dry-run: print what would be renamed/rewritten
  --apply       perform the renames + id rewrites

Fixes:
  - leading-dot module segments (".claude/agents" -> "claude-agents")
  - fabricated finding ids (re-derives via sha1 of dimension:rule:file:context)
NORM_HELP
        return 0 ;;
      -*) die "normalize: unknown flag: $1" ;;
      *)  die "normalize: extra arg: $1" ;;
    esac
  done

  command -v node >/dev/null 2>&1 || die "normalize: node required"
  [ -d .lattice/findings/open ] || die "normalize: no .lattice/findings/open/ in $(pwd) — run \`lattice setup\` first"

  # Delegate the heavy lifting to a Node helper that knows the v0.7 id algo
  # and the slug rules. Emits one line per change of the form:
  #   STATUS|old-path|new-path|old-id|new-id
  # STATUS = "rename" | "rewrite-id" | "both" | "ok"
  local plan
  plan="$(node - "${apply}" <<'NODEJS'
const fs = require("fs");
const path = require("path");
const crypto = require("crypto");
// v1.2.0: node - has argv[1] = "-"; first user arg is argv[2].
const apply = process.argv[2] === "1";
const root = ".lattice/findings/open";

function readTop(text) {
  const out = {};
  if (text.charCodeAt(0) === 0xFEFF) text = text.slice(1);
  for (const raw of text.split(/\r?\n/)) {
    const line = raw.replace(/\r$/, "");
    if (!line || line.startsWith("#")) continue;
    if (/^\s/.test(line)) continue; // nested = skip for top-level extraction
    const m = line.match(/^([a-zA-Z_][a-zA-Z0-9_]*)\s*:\s*(.*)$/);
    if (!m) continue;
    out[m[1]] = m[2].replace(/^["']|["']$/g, "");
  }
  return out;
}

function deriveId(dimension, rule, file, codeContext) {
  const normalized = (codeContext || "").replace(/\s+/g, " ").trim();
  const input = `${dimension}:${rule}:${file}:${normalized}`;
  return crypto.createHash("sha1").update(input).digest("hex").slice(0, 12);
}

function sanitizeModule(mod) {
  // Strip leading "./" or "."; replace internal slashes with "-"; strip any
  // remaining leading dots from path segments. (.claude/agents -> claude-agents)
  if (!mod) return "unknown";
  return mod
    .replace(/^\.+\/?/, "")
    .split("/")
    .map(seg => seg.replace(/^\.+/, ""))
    .filter(Boolean)
    .join("-") || "unknown";
}

function walk(dir) {
  const out = [];
  for (const e of fs.readdirSync(dir, { withFileTypes: true })) {
    const p = path.join(dir, e.name);
    if (e.isDirectory()) out.push(...walk(p));
    else if (e.isFile() && e.name.endsWith(".yml")) out.push(p);
  }
  return out;
}

let changes = 0;
for (const file of walk(root)) {
  let text;
  try { text = fs.readFileSync(file, "utf8"); } catch { continue; }
  const fields = readTop(text);
  const tier = (fields.tier || "UNKNOWN").toUpperCase();
  const rule = fields.rule || "";
  const dimension = fields.dimension || "";
  const module = fields.module || "";
  const filePath = fields.file || "";
  const line = fields.line || "";
  const currentId = fields.id || "";

  // Code-context: prefer the explicit `code_context` field; else fall back
  // to file:line as a stable stand-in. Audit-sweep emissions often skip
  // code_context entirely — using file:line keeps re-derivation stable.
  const codeContext = fields.code_context || `${filePath}:${line}`;
  const correctId = deriveId(dimension, rule, filePath, codeContext);

  const cleanModule = sanitizeModule(module);
  const expectedFilenameStem = `${tier}-${cleanModule}-${rule}`;
  const currentStem = path.basename(file, ".yml");
  const expectedPath = path.join(root, `${expectedFilenameStem}.yml`);

  const idMismatch = currentId && currentId !== correctId;
  const nameMismatch = currentStem !== expectedFilenameStem;

  if (!idMismatch && !nameMismatch && currentId) continue;

  let status = "ok";
  if (idMismatch && nameMismatch) status = "both";
  else if (idMismatch) status = "rewrite-id";
  else if (nameMismatch) status = "rename";
  else if (!currentId) status = "rewrite-id";

  changes++;
  console.log([status, file, expectedPath, currentId || "(missing)", correctId].join("|"));

  if (apply) {
    // Rewrite id in YAML (replace or insert)
    let next;
    if (/^id:\s*/m.test(text)) {
      next = text.replace(/^id:\s*.*$/m, `id: ${correctId}`);
    } else {
      // Insert id: as first key if missing
      next = `id: ${correctId}\n${text.replace(/^﻿/, "")}`;
    }
    // Atomic write to current path, then rename
    fs.writeFileSync(file, next, "utf8");
    if (nameMismatch) {
      // Don't clobber a different existing file at expectedPath
      if (!fs.existsSync(expectedPath)) {
        fs.renameSync(file, expectedPath);
      } else {
        console.log(["skip-rename-collision", file, expectedPath, "", ""].join("|"));
      }
    }
  }
}

console.log(`# total changes: ${changes}`);
NODEJS
)"

  echo "${plan}"
  local n
  n="$(printf '%s\n' "${plan}" | grep -c '^[a-z]' || true)"
  if [ "${apply}" -eq 0 ]; then
    if [ "${n:-0}" = "0" ]; then
      echo "[${PROG}] normalize: no changes needed"
    else
      echo ""
      echo "[${PROG}] normalize: ${n} change(s) proposed — re-run with --apply to write"
    fi
    return 0
  fi
  echo "[${PROG}] normalize: applied"
}

# ---------------------------------------------------------------------------
# setup — one-command per-project bootstrap. v1.0.3 (#2).
# Runs the canonical first-time sequence:
#   1. Ensure .lattice/findings/{open,closed,sweeps} exist
#   2. Ensure .lattice/config.yml exists (idempotent — preserves existing)
#   3. Ensure CLAUDE.md exists with the Lattice block
#   4. Suggest /audit-sweep as the next action
# Replaces the multi-step "doctor + config init + sync + restart" dance.
#
# Usage:
#   lattice setup [--global]   # --global runs install.sh + per-machine wiring
# ---------------------------------------------------------------------------
cmd_setup() {
  local global=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --global) global=1; shift ;;
      --help|-h)
        cat <<'SETUP_HELP'
lattice setup — one-command bootstrap

  (default)    per-project: create .lattice/ tree + config + CLAUDE.md
  --global     per-machine: prints the curl|bash install command and
               (if installed) runs wire-hooks + mcp setup wizard
SETUP_HELP
        return 0 ;;
      -*) die "setup: unknown flag: $1" ;;
      *)  die "setup: extra arg: $1" ;;
    esac
  done

  if [ "${global}" -eq 1 ]; then
    echo "[${PROG}] global setup — install Lattice across this machine:"
    echo ""
    echo "  curl -fsSL https://raw.githubusercontent.com/IsaamMJ/Lattice/main/scripts/install.sh | bash"
    echo ""
    echo "[${PROG}] After install, the script will prompt to auto-wire hooks + MCP."
    return 0
  fi

  echo "[${PROG}] setup: bootstrapping Lattice in $(pwd)"
  # 1. Findings tree
  mkdir -p .lattice/findings/open .lattice/findings/closed .lattice/findings/sweeps .lattice/cache 2>/dev/null
  echo "  [ok] .lattice/findings/{open,closed,sweeps}"

  # v1.1.2 (#53): drop .gitattributes to pin .lattice/ to LF newlines, so
  # Windows + git's default core.autocrlf=true doesn't emit a CRLF warning for
  # every YAML on every commit. Idempotent — preserve user content if present.
  if [ ! -f .lattice/.gitattributes ]; then
    cat > .lattice/.gitattributes <<'GITATTR'
# Lattice findings + manifests — keep LF on disk to avoid CRLF churn on Windows.
# Without this, every YAML emitted by audit skills triggers
# "LF will be replaced by CRLF" on git add, and content-hash ids drift.
* text=auto eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.jsonl text eol=lf
GITATTR
    echo "  [ok] .lattice/.gitattributes (LF pin for Windows CRLF safety)"
  else
    echo "  [ok] .lattice/.gitattributes already present (preserved)"
  fi

  # 2. Config (only if missing — never overwrite existing)
  if [ ! -f .lattice/config.yml ]; then
    cmd_config init >/dev/null 2>&1 || true
    if [ -f .lattice/config.yml ]; then
      echo "  [ok] .lattice/config.yml created"
    else
      echo "  [warn] could not create .lattice/config.yml (lattice config init failed)"
    fi
  else
    echo "  [ok] .lattice/config.yml already present (preserved)"
  fi

  # 3. CLAUDE.md (call sync to bootstrap)
  if [ ! -f CLAUDE.md ] || ! grep -q "lattice:checklist:start" CLAUDE.md 2>/dev/null; then
    cmd_sync >/dev/null 2>&1 || true
    if [ -f CLAUDE.md ] && grep -q "lattice:checklist:start" CLAUDE.md 2>/dev/null; then
      echo "  [ok] CLAUDE.md created with Lattice block"
    else
      echo "  [warn] could not create CLAUDE.md (lattice sync failed)"
    fi
  else
    echo "  [ok] CLAUDE.md already has lattice markers (preserved)"
  fi

  echo ""
  echo "[${PROG}] setup complete. Next:"
  echo "  - In Claude Code:  /audit-sweep ."
  echo "  - Or CLI:          lattice list      (will be empty until first audit)"
  return 0
}

# ---------------------------------------------------------------------------
# v2.2 — onboard — multi-project setup collapse (#77).
#
# Wraps the full per-project sequence into one command so adding Lattice to a
# new repo goes from ~3h (setup + wire-hooks + mcp + grow init + schedule +
# secrets) to ~30s.
#
# Steps:
#   1. lattice setup                              (findings tree, config, CLAUDE.md)
#   2. lattice wire-hooks --apply --yes           (SessionStart + statusLine + Stop)
#   3. lattice mcp setup --apply --yes            (MCP server, if not already)
#   4. lattice grow init                          (hypotheses tree + README)
#   5. lattice grow schedule install              (workflow + manifest)
#   6. Prints required GH secrets + next-step prompt
#
# Defaults match maintainer's standard cadence: github-actions transport,
# Monday 09:00 local. Override via --time / --day / --transport.
# ---------------------------------------------------------------------------
cmd_onboard() {
  local time="09:00" day="mon" transport="github-actions" skip_mcp=0 skip_schedule=0 utc="" auto_action=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --time)      time="$2"; shift 2 ;;
      --day)       day="$2"; shift 2 ;;
      --transport) transport="$2"; shift 2 ;;
      --utc)       utc="--utc"; shift ;;
      --auto-action) auto_action="--auto-action"; shift ;;
      --skip-mcp)      skip_mcp=1; shift ;;
      --skip-schedule) skip_schedule=1; shift ;;
      --help|-h)
        cat <<'ONBOARD_HELP'
lattice onboard — collapse per-project setup into one command (v2.2 #77)

Usage:
  lattice onboard [--time HH:MM] [--day mon..sun] [--transport github-actions|local-cron]
                  [--utc] [--skip-mcp] [--skip-schedule]

Runs: setup → wire-hooks → mcp setup → grow init → grow schedule install.
Prints GH secret list and next-step `/audit-sweep .` prompt at the end.

Defaults: --time 09:00 --day mon --transport github-actions
ONBOARD_HELP
        return 0 ;;
      *) die "onboard: unknown flag: $1" ;;
    esac
  done

  echo "[${PROG}] onboard: bootstrapping Lattice in $(pwd)"
  echo ""

  # Step 1 — setup (idempotent)
  echo "[1/5] lattice setup"
  cmd_setup 2>&1 | sed 's/^/      /'
  echo ""

  # Step 2 — wire-hooks
  echo "[2/5] lattice wire-hooks --apply --yes"
  if cmd_wire_hooks --apply --yes 2>&1 | sed 's/^/      /'; then :; else
    echo "      [warn] wire-hooks reported issues — continuing"
  fi
  echo ""

  # Step 3 — mcp setup (optional, only if node/npm available)
  if [ "${skip_mcp}" -eq 1 ]; then
    echo "[3/5] mcp setup — SKIPPED (--skip-mcp)"
  elif ! command -v node >/dev/null 2>&1; then
    echo "[3/5] mcp setup — SKIPPED (node not on PATH)"
  else
    echo "[3/5] lattice mcp setup --apply --yes"
    cmd_mcp setup --apply --yes 2>&1 | sed 's/^/      /' || echo "      [warn] mcp setup reported issues — continuing"
  fi
  echo ""

  # Step 4 — grow init
  echo "[4/5] lattice grow init"
  cmd_grow init 2>&1 | sed 's/^/      /'
  echo ""

  # Step 5 — grow schedule install
  if [ "${skip_schedule}" -eq 1 ]; then
    echo "[5/5] grow schedule install — SKIPPED (--skip-schedule)"
  else
    echo "[5/5] lattice grow schedule install --time ${time} --day ${day} --transport ${transport} ${utc} ${auto_action}"
    # shellcheck disable=SC2086
    cmd_grow schedule install --time "${time}" --day "${day}" --transport "${transport}" ${utc} ${auto_action} 2>&1 | sed 's/^/      /' || true
  fi
  echo ""

  # Closing pointers
  echo "[${PROG}] onboard complete."
  echo ""
  echo "Next steps:"
  echo "  1. (REQUIRED if transport=github-actions) set repo secrets so the"
  echo "     scheduled measure can reach your metric endpoints + Telegram:"
  echo "       gh secret set LATTICE_TELEGRAM_TOKEN   --body \"\$(read -sp 'token: ' x; echo \"\$x\")\""
  echo "       gh secret set LATTICE_TELEGRAM_CHAT_ID --body \"<chat-id>\""
  echo '     Any extra ${LATTICE_FETCH_HEADER_FOO} you reference in hypothesis'
  echo "     YAML headers must also be added as repo secrets."
  echo ""
  echo "  2. Populate findings — in Claude Code, run:"
  echo "       /audit-sweep ."
  echo ""
  echo "  3. Verify scheduled job: lattice grow schedule status"
  echo "  4. List open findings:   lattice list   (empty until step 2)"
}

# ---------------------------------------------------------------------------
# ci-check-dead — fail if any subcommand has 0 invocations across global usage
# log. Used as a release-time check to enforce dead-feature pruning practice.
# v1.0.3 (#7). Same exit-code shape as `lattice ci-check`.
# ---------------------------------------------------------------------------
cmd_ci_check_dead() {
  local days=14 fail=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --days) days="$2"; shift 2 ;;
      --help|-h)
        echo "lattice ci-check-dead [--days N]  # exit 1 if any subcmd has 0 invocations in last N days (default 14)"
        return 0 ;;
      *) die "ci-check-dead: unknown arg: $1" ;;
    esac
  done

  local global_log="${HOME}/.claude/lattice/usage/global.jsonl"
  if [ ! -f "${global_log}" ]; then
    echo "[${PROG}] ci-check-dead: no global usage log (${global_log}) — skipping"
    return 0
  fi

  command -v node >/dev/null 2>&1 || die "ci-check-dead: node required for log parsing"

  local subs="${_KNOWN_SUBS}"
  local dead
  dead="$(node -e '
const fs = require("fs");
// node -e argv: [nodePath, ...userArgs] — no script slot when using -e
const [, log, daysStr, subsStr] = process.argv;
const days = parseInt(daysStr, 10);
const subs = subsStr.split(/\s+/).filter(Boolean);
const since = Date.now() - days * 86400000;
const used = new Set();
try {
  for (const line of fs.readFileSync(log, "utf8").split("\n")) {
    if (!line) continue;
    let ev; try { ev = JSON.parse(line); } catch { continue; }
    const ts = ev.ts ? Date.parse(ev.ts) : NaN;
    if (!Number.isFinite(ts) || ts < since) continue;
    if (ev.command) used.add(ev.command);
  }
} catch {}
// Whitelist: subcommands intentionally rare/CI-only OR aliases of others.
// Aliases (ls/cat/regenerate) share a cmd_* function but log under the alias
// name; flagging them as dead would be a false positive.
const whitelist = new Set([
  "help", "version", "doctor", "uninstall", "setup",
  "ci-check", "ci-check-dead", "validate",
  "claude-md-restore", "claude-md-tune", "project-restore",
  "wire-hooks", "mcp",
  "report",
  "migrate", "migrate-status", "migrate-v0.7",
  // Aliases — keep
  "ls", "cat", "regenerate",
]);
const dead = subs.filter(s => !used.has(s) && !whitelist.has(s));
process.stdout.write(dead.join("\n"));
' "${global_log}" "${days}" "${subs}")"

  if [ -z "${dead}" ]; then
    echo "[${PROG}] ci-check-dead: all subcommands used within last ${days} days (or whitelisted)"
    return 0
  fi

  echo "[${PROG}] ci-check-dead: subcommands with 0 invocations in last ${days} days:"
  printf '  - %s\n' ${dead}
  echo ""
  echo "[${PROG}] consider pruning these (delete from dispatcher, _KNOWN_SUBS, usage()) before release."
  echo "[${PROG}] to suppress a specific subcommand permanently, add it to the whitelist in cmd_ci_check_dead."
  return 1
}

# ---------------------------------------------------------------------------
# uninstall — remove Lattice from the current project (default) or globally
# (--global). Always lists what will be deleted; requires --yes to actually
# remove. Backs up CLAUDE.md before deletion. v1.0.2 (#9).
#
# Usage:
#   lattice uninstall                      # remove .lattice/ + CLAUDE.md block from cwd, dry-run
#   lattice uninstall --yes                # actually remove
#   lattice uninstall --global             # remove global install (~/.claude/lattice + commands)
#   lattice uninstall --global --yes       # actually remove globally
#   lattice uninstall --global --purge     # also remove shims, hooks, mcp wiring
# ---------------------------------------------------------------------------
cmd_uninstall() {
  local scope="project" yes=0 purge=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --global) scope="global"; shift ;;
      --yes|-y) yes=1; shift ;;
      --purge)  purge=1; shift ;;
      --help|-h)
        cat <<'UNINSTALL_HELP'
lattice uninstall — remove Lattice from this project or globally

  (default)             remove .lattice/ + CLAUDE.md Lattice block from cwd
  --global              remove the global install (commands, scripts, docs)
  --global --purge      also remove shims, settings.json hooks, mcp wiring
  --yes                 actually remove (default is dry-run)

Always dry-runs first; backs up CLAUDE.md before deletion. Use --global
to wipe the install for a fully from-scratch test.
UNINSTALL_HELP
        return 0 ;;
      -*) die "uninstall: unknown flag: $1" ;;
      *)  die "uninstall: extra arg: $1" ;;
    esac
  done

  local items=()
  if [ "${scope}" = "project" ]; then
    [ -d .lattice ] && items+=(".lattice/")
    if [ -f CLAUDE.md ] && grep -q "lattice:checklist:start" CLAUDE.md 2>/dev/null; then
      # Detect lattice-only CLAUDE.md (we'll just delete) vs mixed (we'll strip block)
      local non_lattice
      non_lattice="$(grep -cvE '^(<!--|##? |\s*$|- )' CLAUDE.md 2>/dev/null || echo 0)"
      if [ "${non_lattice}" -le 1 ]; then
        items+=("CLAUDE.md  (lattice-only, full delete)")
      else
        items+=("CLAUDE.md  (strip block between lattice:checklist:start/end markers)")
      fi
    fi
  else
    [ -d "${HOME}/.claude/lattice" ] && items+=("${HOME}/.claude/lattice/")
    for cmd in audit audit-sweep close flow-audit lattice-fix scale-audit security-audit; do
      [ -f "${HOME}/.claude/commands/${cmd}.md" ] && items+=("${HOME}/.claude/commands/${cmd}.md")
    done
    if [ "${purge}" -eq 1 ]; then
      for shim in "${HOME}/bin/lattice" "${HOME}/.local/bin/lattice" "${HOME}/.local/lattice/bin/lattice"; do
        [ -e "${shim}" ] && items+=("${shim}")
      done
      for cmdshim in "${HOME}/bin/lattice.cmd" "${HOME}/.local/bin/lattice.cmd" "${HOME}/.local/lattice/bin/lattice.cmd"; do
        [ -e "${cmdshim}" ] && items+=("${cmdshim}")
      done
      [ -f "${HOME}/.claude/settings.json" ] && items+=("${HOME}/.claude/settings.json  (Lattice hooks + statusLine will be stripped)")
      [ -f "${HOME}/.claude.json" ] && grep -q '"lattice"' "${HOME}/.claude.json" 2>/dev/null && items+=("${HOME}/.claude.json  (mcpServers.lattice will be stripped)")
    fi
  fi

  if [ "${#items[@]}" -eq 0 ]; then
    echo "[${PROG}] uninstall: nothing to remove (Lattice is not installed at ${scope} scope)"
    return 0
  fi

  echo "[${PROG}] uninstall (${scope} scope) — the following will be removed:"
  for item in "${items[@]}"; do
    echo "  - ${item}"
  done
  echo ""

  if [ "${yes}" -ne 1 ]; then
    echo "[${PROG}] DRY RUN — re-run with --yes to actually remove"
    return 0
  fi

  # Apply
  if [ "${scope}" = "project" ]; then
    if [ -d .lattice ]; then
      rm -rf .lattice
      echo "[${PROG}] removed .lattice/"
    fi
    if [ -f CLAUDE.md ] && grep -q "lattice:checklist:start" CLAUDE.md 2>/dev/null; then
      cp CLAUDE.md "CLAUDE.md.lattice-backup-$(date -u +%Y%m%dT%H%M%SZ)"
      local non_lattice
      non_lattice="$(grep -cvE '^(<!--|##? |\s*$|- )' CLAUDE.md 2>/dev/null || echo 0)"
      if [ "${non_lattice}" -le 1 ]; then
        rm -f CLAUDE.md
        echo "[${PROG}] removed CLAUDE.md (lattice-only)"
      else
        # Strip just the block — keep the user's other content
        awk '/lattice:checklist:start/{f=1;next} /lattice:checklist:end/{f=0;next} !f{print}' CLAUDE.md > CLAUDE.md.tmp && mv CLAUDE.md.tmp CLAUDE.md
        echo "[${PROG}] stripped lattice block from CLAUDE.md (backup written)"
      fi
    fi
  else
    rm -rf "${HOME}/.claude/lattice"
    for cmd in audit audit-sweep close flow-audit lattice-fix scale-audit security-audit; do
      rm -f "${HOME}/.claude/commands/${cmd}.md"
    done
    echo "[${PROG}] removed global commands + scripts"
    if [ "${purge}" -eq 1 ]; then
      for shim in "${HOME}/bin/lattice" "${HOME}/.local/bin/lattice" "${HOME}/.local/lattice/bin/lattice" \
                  "${HOME}/bin/lattice.cmd" "${HOME}/.local/bin/lattice.cmd" "${HOME}/.local/lattice/bin/lattice.cmd"; do
        rm -f "${shim}"
      done
      echo "[${PROG}] removed shims"
      # Strip hooks + statusline from settings.json
      if [ -f "${HOME}/.claude/settings.json" ] && command -v node >/dev/null 2>&1; then
        node -e '
const fs = require("fs");
const p = process.argv[1];
let cfg; try { cfg = JSON.parse(fs.readFileSync(p, "utf8")); } catch { process.exit(0); }
const sentinel = (c) => typeof c === "string" && (c.endsWith("lattice-session-start.mjs") || c.endsWith("lattice-statusline.mjs"));
let changed = false;
if (cfg.hooks?.SessionStart) {
  const filtered = cfg.hooks.SessionStart.filter(g => !(g?.hooks?.some(h => sentinel(h?.command))));
  if (filtered.length !== cfg.hooks.SessionStart.length) { cfg.hooks.SessionStart = filtered; changed = true; }
}
if (cfg.statusLine && sentinel(cfg.statusLine.command)) { delete cfg.statusLine; changed = true; }
if (changed) {
  const ts = new Date().toISOString().replace(/[:.]/g, "-");
  fs.copyFileSync(p, p + ".lattice-backup-" + ts);
  fs.writeFileSync(p, JSON.stringify(cfg, null, 2) + "\n", "utf8");
  console.log("stripped");
}
' "${HOME}/.claude/settings.json" 2>/dev/null && echo "[${PROG}] stripped Lattice hooks + statusLine from settings.json"
      fi
      # Strip mcpServers.lattice from ~/.claude.json
      if [ -f "${HOME}/.claude.json" ] && command -v node >/dev/null 2>&1; then
        node -e '
const fs = require("fs");
const p = process.argv[1];
let cfg; try { cfg = JSON.parse(fs.readFileSync(p, "utf8")); } catch { process.exit(0); }
if (cfg.mcpServers?.lattice) {
  delete cfg.mcpServers.lattice;
  const ts = new Date().toISOString().replace(/[:.]/g, "-");
  fs.copyFileSync(p, p + ".lattice-backup-" + ts);
  fs.writeFileSync(p, JSON.stringify(cfg, null, 2) + "\n", "utf8");
  console.log("stripped");
}
' "${HOME}/.claude.json" 2>/dev/null && echo "[${PROG}] stripped mcpServers.lattice from ~/.claude.json"
      fi
    fi
  fi
  echo "[${PROG}] uninstall complete"
  return 0
}

# ---------------------------------------------------------------------------
# mcp — manage the Lattice MCP server (v1.0.0).
# Subcommands:
#   lattice mcp setup [--apply] [--yes] [--scope user|project]
#   lattice mcp serve   # convenience: exec the built MCP server on stdio
#   lattice mcp build   # rebuild dist/ in mcp/ via tsc
#   lattice mcp status  # show whether the server is wired and reachable
#
# Wires `mcpServers.lattice` into ~/.claude.json (user scope) or .mcp.json
# (project scope). Same backup + dry-run + idempotent discipline as
# wire-hooks. The entry uses node + the absolute path to dist/index.js;
# LATTICE_BIN is passed through env so the server can find the bash CLI on
# machines where lattice isn't on PATH yet.
# ---------------------------------------------------------------------------
cmd_mcp() {
  local sub="${1:-}"; shift || true
  case "${sub}" in
    setup)  _mcp_setup "$@" ;;
    serve)  _mcp_serve "$@" ;;
    build)  _mcp_build "$@" ;;
    status) _mcp_status "$@" ;;
    ""|--help|-h)
      cat <<'MCPHELP'
lattice mcp — Lattice MCP server (v1.0.0)

  setup [--apply] [--yes] [--scope user|project]
                  Wire `mcpServers.lattice` into ~/.claude.json (user) or
                  .mcp.json (project). Dry-run by default; --apply writes
                  after y/N confirm. Always backs up before mutation.
                  Idempotent.

  serve           Exec the built MCP server on stdio (for direct testing).
                  Reads LATTICE_BIN if set, otherwise resolves `lattice`
                  via PATH.

  build           Rebuild dist/index.js in mcp/ via tsc. Requires Node 18+.

  status          Show whether the server is wired in ~/.claude.json and
                  whether dist/index.js exists.
MCPHELP
      return 0 ;;
    *) die "mcp: unknown subcommand: ${sub} (try: setup | serve | build | status)" ;;
  esac
}

# Resolve the absolute path to the built MCP server. The path is relative to
# this script's location (works in both the source repo and the installed
# location ~/.claude/lattice/scripts/, provided the mcp/ tree is copied
# alongside scripts/ at install time).
_mcp_dist_path() {
  local d
  d="$(cd "${SELF_DIR}/../mcp" 2>/dev/null && pwd)" || return 1
  printf '%s/dist/index.js' "${d}"
}

_mcp_build() {
  local mcp_dir="${SELF_DIR}/../mcp"
  [ -d "${mcp_dir}" ] || die "mcp build: mcp/ directory not found at ${mcp_dir}"
  command -v node >/dev/null 2>&1 || die "mcp build: node required (>=18)"
  command -v npm >/dev/null 2>&1 || die "mcp build: npm required"
  ( cd "${mcp_dir}" && {
      [ -d node_modules ] || npm install --silent
      npx --yes tsc
    } ) || die "mcp build: failed"
  echo "[${PROG}] mcp build: ok ($(_mcp_dist_path))"
}

_mcp_serve() {
  local dist
  dist="$(_mcp_dist_path)" || die "mcp serve: cannot resolve mcp/dist path"
  [ -f "${dist}" ] || die "mcp serve: ${dist} missing — run \`lattice mcp build\` first"
  exec node "${dist}" "$@"
}

_mcp_status() {
  local dist settings wired="no" cli="no"
  dist="$(_mcp_dist_path 2>/dev/null || true)"
  settings="${HOME}/.claude.json"
  if [ -f "${dist:-/nonexistent}" ]; then cli="yes"; fi
  if [ -f "${settings}" ] && command -v node >/dev/null 2>&1; then
    wired="$(node -e '
try {
  const cfg = JSON.parse(require("fs").readFileSync(process.argv[1], "utf8"));
  process.stdout.write((cfg.mcpServers && cfg.mcpServers.lattice) ? "yes" : "no");
} catch (e) { process.stdout.write("err"); }
' "${settings}" 2>/dev/null)"
  fi
  printf "[%s] mcp status:\n  built:  %s%s\n  wired:  %s (~/.claude.json mcpServers.lattice)\n" \
    "${PROG}" "${cli}" "${dist:+ (${dist})}" "${wired}"
}

_mcp_setup() {
  local apply=0 auto_yes=0 scope="user"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --apply) apply=1; shift ;;
      --yes|-y) auto_yes=1; shift ;;
      --scope) [ -z "${2:-}" ] && die "mcp setup: --scope requires user|project"
               scope="$2"; shift 2 ;;
      -*) die "mcp setup: unknown flag: $1" ;;
      *)  die "mcp setup: extra arg: $1" ;;
    esac
  done
  case "${scope}" in user|project) ;; *) die "mcp setup: --scope must be user or project" ;; esac

  local dist
  dist="$(_mcp_dist_path)" || die "mcp setup: cannot resolve mcp/dist path"
  if [ ! -f "${dist}" ]; then
    echo "[${PROG}] mcp setup: dist/index.js missing — building first..."
    _mcp_build || die "mcp setup: build failed"
  fi
  command -v node >/dev/null 2>&1 || die "mcp setup: node required"

  local target
  if [ "${scope}" = "user" ]; then
    target="${CLAUDE_CONFIG_DIR:-${HOME}}/.claude.json"
  else
    target="$(pwd)/.mcp.json"
  fi
  mkdir -p "$(dirname "${target}")" 2>/dev/null || true
  [ -f "${target}" ] || echo "{}" > "${target}"

  # Compute LATTICE_BIN to embed so the MCP server can find the bash CLI even
  # when `lattice` isn't on PATH for the spawned MCP process.
  local lattice_bin_value="${SELF_DIR}/lattice"

  local out
  out="$(node - "${target}" "${dist}" "${lattice_bin_value}" "${apply}" <<'NODEJS'
const fs = require('fs');
const [,, settingsPath, distPath, latticeBinValue, applyStr] = process.argv;
const apply = applyStr === '1';

let raw;
try { raw = fs.readFileSync(settingsPath, 'utf8'); }
catch (e) { console.log('STATUS=malformed'); console.log('cannot read: ' + e.message); process.exit(2); }
let cfg;
try { cfg = raw.trim() === '' ? {} : JSON.parse(raw); }
catch (e) { console.log('STATUS=malformed'); console.log('JSON parse error: ' + e.message); process.exit(2); }

cfg.mcpServers ??= {};
const entry = {
  command: 'node',
  args: [distPath],
  env: { LATTICE_BIN: latticeBinValue },
};
const before = JSON.stringify(cfg.mcpServers.lattice ?? null);
cfg.mcpServers.lattice = entry;
const after = JSON.stringify(cfg.mcpServers.lattice);

if (before === after) {
  console.log('STATUS=noop');
  console.log('Lattice MCP already wired in ' + settingsPath);
  process.exit(0);
}

const rendered = JSON.stringify(cfg, null, 2);
console.log('STATUS=wired');
console.log('--- diff (preview)');
console.log('mcpServers.lattice would be:');
console.log(JSON.stringify(entry, null, 2));
console.log('--- full settings preview (truncated to first 60 lines)');
console.log(rendered.split('\n').slice(0, 60).join('\n'));

if (apply) {
  const ts = new Date().toISOString().replace(/[:.]/g, '-');
  const backup = settingsPath + '.lattice-backup-' + ts;
  fs.copyFileSync(settingsPath, backup);
  fs.writeFileSync(settingsPath, rendered + '\n', 'utf8');
  console.log('--- applied');
  console.log('backup: ' + backup);
}
NODEJS
)" || {
    rc=$?
    echo "${out}"
    [ "${rc}" -eq 2 ] && die "mcp setup: ${target} is malformed JSON — fix or delete it, then re-run"
    die "mcp setup: node helper exited ${rc}"
  }

  # v1.4.2 (#58): initialize defensively — under `set -euo pipefail`, an empty
  # ${out} or a pipefail in the substitution leaves body/status unset and the
  # next `echo "${body}"` trips "unbound variable". Initialize-then-assign
  # makes both defined no matter what the substitution does.
  local status="" body=""
  status="$(printf '%s\n' "${out:-}" | head -1 | sed -E 's/^STATUS=//' || true)"
  body="$(printf '%s\n' "${out:-}" | tail -n +2 || true)"

  case "${status}" in
    noop)
      echo "[${PROG}] mcp setup: already wired — no changes needed"
      return 0
      ;;
    wired)
      echo "${body}"
      if [ "${apply}" -ne 1 ]; then
        echo ""
        echo "[${PROG}] mcp setup: DRY RUN — re-run with --apply to write"
        return 0
      fi
      if [ "${auto_yes}" -ne 1 ]; then
        printf "[${PROG}] write changes to %s? [y/N] " "${target}"
        read -r ans
        case "${ans}" in y|Y|yes|YES) ;; *) echo "[${PROG}] aborted"; return 0 ;; esac
      fi
      node - "${target}" "${dist}" "${lattice_bin_value}" <<'NODEJS_APPLY' >/dev/null
const fs = require('fs');
const [,, settingsPath, distPath, latticeBinValue] = process.argv;
const cfg = JSON.parse(fs.readFileSync(settingsPath, 'utf8'));
cfg.mcpServers ??= {};
cfg.mcpServers.lattice = {
  command: 'node',
  args: [distPath],
  env: { LATTICE_BIN: latticeBinValue },
};
const ts = new Date().toISOString().replace(/[:.]/g, '-');
fs.copyFileSync(settingsPath, settingsPath + '.lattice-backup-' + ts);
fs.writeFileSync(settingsPath, JSON.stringify(cfg, null, 2) + '\n', 'utf8');
NODEJS_APPLY
      echo "[${PROG}] mcp setup: applied — backup at ${target}.lattice-backup-<ts>"
      echo "[${PROG}] restart Claude Code to load the MCP server"
      return 0
      ;;
    *)
      echo "${out}"
      die "mcp setup: unexpected helper status: ${status}"
      ;;
  esac
}

# ---------------------------------------------------------------------------
# main
# ---------------------------------------------------------------------------
if [ "$#" -eq 0 ]; then
  usage
  exit 0
fi

# MAT entry capture (v0.9.6) — snapshot before subcommand dispatch so the EXIT
# trap can write a complete trace event regardless of where execution ended.
# _LATTICE_ARGV holds the FULL argv (subcommand + flags) for the trace log.
_LATTICE_ARGV=( "$@" )
_LATTICE_START_NS="$(date +%s%N 2>/dev/null || echo 0)"
# Filter the bogus `%N` literal Git Bash on Windows can return when nanos
# aren't supported — keeps duration_ms a clean integer downstream.
case "${_LATTICE_START_NS}" in
  *N|*n) _LATTICE_START_NS=0 ;;
esac
# Invocation-method detector: "fullpath" when the user (or a Claude session)
# ran `~/.claude/lattice/scripts/lattice ...` instead of the PATH-resolved
# `lattice`. That string is a primary friction signal — see v0.9.7 predicates.
_LATTICE_INVOKED_VIA="path"
case "${BASH_SOURCE[0]:-$0}" in
  */.claude/lattice/scripts/lattice|*/.claude/lattice/scripts/lattice.sh)
    _LATTICE_INVOKED_VIA="fullpath" ;;
esac

sub="$1"; shift || true
# Dedicated subcommand global for EXIT-time handlers. Some subcommands
# (cmd_doctor) use `for sub in ...` without local-scoping, clobbering the
# top-level `sub`. _LATTICE_SUBCMD is only set here, never reassigned.
_LATTICE_SUBCMD="${sub}"
trap _on_telemetry_exit EXIT
_maybe_show_telemetry_disclosure
maybe_update_check "${sub}" || true
case "${sub}" in
  # v0.9.15: statusline + sessions + review excluded from usage logging.
  # These are tick-invoked or read-only commands; logging them on every tick
  # was a meaningful contributor to the orphan bash.exe pile-up (each log
  # event appended to global.jsonl, which on Windows + Git Bash adds latency).
  help|--help|-h|version|--version|-v|doctor|statusline|sessions|review) ;;
  *) log_usage_event "${sub}" "$@" || true ;;
esac
case "${sub}" in
  close)              cmd_close "$@" ;;
  link)               cmd_link "$@" ;;
  reopen)             cmd_reopen "$@" ;;
  sync|regenerate)    cmd_sync "$@" ;;
  defer)              cmd_defer "$@" ;;
  list|ls)            cmd_list "$@" ;;
  show|cat)           cmd_show "$@" ;;
  bulk-close)         cmd_bulk_close "$@" ;;
  handoff)            cmd_handoff "$@" ;;
  next)               cmd_next "$@" ;;
  verify)             cmd_verify "$@" ;;
  ci-check)           cmd_ci_check "$@" ;;
  wire-hooks)         cmd_wire_hooks "$@" ;;
  mcp)                cmd_mcp "$@" ;;
  uninstall)          cmd_uninstall "$@" ;;
  setup)              cmd_setup "$@" ;;
  onboard)            cmd_onboard "$@" ;;
  ci-check-dead)      cmd_ci_check_dead "$@" ;;
  release-notes)      cmd_release_notes "$@" ;;
  normalize)          cmd_normalize "$@" ;;
  diff)               cmd_diff "$@" ;;
  write-manifest)     cmd_write_manifest "$@" ;;
  audit-infra)        cmd_audit_infra "$@" ;;
  profile)            cmd_profile "$@" ;;
  grow)               cmd_grow "$@" ;;
  usage)              cmd_usage "$@" ;;
  update)             cmd_update "$@" ;;
  config)             cmd_config "$@" ;;
  validate)           cmd_validate "$@" ;;
  sweeps)             cmd_sweeps "$@" ;;
  sweep-id)           cmd_sweep_id ;;
  id-gen)             cmd_id_gen "$@" ;;
  doctor)             cmd_doctor "$@" ;;
  export)             cmd_export "$@" ;;
  changelog)          cmd_changelog "$@" ;;
  resolve-pending)    cmd_resolve_pending "$@" ;;
  test-fixture)       cmd_test_fixture "$@" ;;
  install-hooks)      cmd_install_hooks "$@" ;;
  stats)              cmd_stats "$@" ;;
  mode)               cmd_mode "$@" ;;
  decide)             cmd_decide "$@" ;;
  decisions)          cmd_decisions "$@" ;;
  invariants)         cmd_invariants "$@" ;;
  context)            cmd_context "$@" ;;
  report)             cmd_report "$@" ;;
  sessions)           cmd_sessions "$@" ;;
  review)             cmd_review "$@" ;;
  audit-env-contract) cmd_audit_env_contract "$@" ;;
  claude-md-tune)     cmd_claude_md_tune "$@" ;;
  claude-md-restore)  cmd_claude_md_restore "$@" ;;
  project-init)       cmd_project_init "$@" ;;
  project-sync)       cmd_project_sync "$@" ;;
  project-restore)    cmd_project_restore "$@" ;;
  statusline)         cmd_statusline "$@" ;;
  version|--version|-v) cmd_version ;;
  help|--help|-h)     usage ;;
  *)                  echo "[${PROG}] error: unknown subcommand: ${sub}" >&2; usage >&2; exit 2 ;;
esac
